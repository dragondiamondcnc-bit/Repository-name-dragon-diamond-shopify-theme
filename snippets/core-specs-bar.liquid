{% comment %}
  Core Specs Bar for DRAGON DIAMOND Laser Cutting Machine
{% endcomment %}

<div class="core-specs-bar-section" style="background-color: #1A1A1B; border-bottom: 2px solid #008F5A; padding: 15px 0;">
  <div class="page-width">
    <div class="specs-bar-container" style="display: flex; justify-content: space-around; align-items: center; flex-wrap: wrap; gap: 20px;">
      
      <div class="spec-item" style="display: flex; align-items: center; gap: 10px; color: #FFFFFF;">
        <span class="spec-icon" style="color: #008F5A; font-size: 20px;">📏</span>
        <div class="spec-text">
          <strong style="display: block; font-size: 14px;">INDUSTRIAL 1390 SIZE</strong>
          <span style="font-size: 12px; color: #CCCCCC;">1300 x 900 mm Working Area</span>
        </div>
      </div>

      <div class="spec-item" style="display: flex; align-items: center; gap: 10px; color: #FFFFFF;">
        <span class="spec-icon" style="color: #008F5A; font-size: 20px;">⚖️</span>
        <div class="spec-text">
          <strong style="display: block; font-size: 14px;">400KG+ HEAVY CHASSIS</strong>
          <span style="font-size: 12px; color: #CCCCCC;">Vibration-Free Stability</span>
        </div>
      </div>

      <div class="spec-item" style="display: flex; align-items: center; gap: 10px; color: #FFFFFF;">
        <span class="spec-icon" style="color: #008F5A; font-size: 20px;">🛤️</span>
        <div class="spec-text">
          <strong style="display: block; font-size: 14px;">TAIWAN HIWIN™ GUIDES</strong>
          <span style="font-size: 12px; color: #CCCCCC;">0.01mm Precision Motion</span>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
.core-specs-bar-section {
  z-index: 5;
  position: relative;
}
@media screen and (max-width: 749px) {
  .specs-bar-container {
    flex-direction: column;
    align-items: flex-start;
    padding-left: 20px;
  }
}
</style>
