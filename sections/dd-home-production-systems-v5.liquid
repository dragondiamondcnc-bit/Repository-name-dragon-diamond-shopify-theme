<section
  id="DDProductionSystems-{{ section.id }}"
  class="dd-production-systems"
  data-dd-production-systems
>
  <div class="dd-production-systems__container">
    <header class="dd-production-systems__header">
      <span class="dd-production-systems__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="dd-production-systems__heading">{{ section.settings.heading }}</h2>
      <p class="dd-production-systems__description">{{ section.settings.description }}</p>
    </header>

    <div class="dd-production-systems__layout">
      <div class="dd-production-systems__navigation" role="tablist" aria-label="Production systems">
        {% for block in section.blocks %}
          <button
            class="dd-production-systems__tab{% if forloop.first %} is-active{% endif %}"
            type="button"
            role="tab"
            id="DDProductionTab-{{ section.id }}-{{ block.id }}"
            aria-controls="DDProductionPanel-{{ section.id }}-{{ block.id }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            data-dd-system-tab="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <span class="dd-production-systems__number">{{ forloop.index | prepend: '0' }} //</span>
            <span class="dd-production-systems__tab-title">{{ block.settings.title }}</span>
          </button>
        {% endfor %}
      </div>

      <div class="dd-production-systems__evidence">
        {% for block in section.blocks %}
          {% case forloop.index %}
            {% when 1 %}
              {% assign production_asset = 'section05-co2-production.jpg' %}
            {% when 2 %}
              {% assign production_asset = 'section05-cnc-production.jpg' %}
            {% when 3 %}
              {% assign production_asset = 'section05-fiber-production.jpg' %}
            {% else %}
              {% assign production_asset = 'section05-uv-production.jpg' %}
          {% endcase %}

          <article
            class="dd-production-systems__panel{% if forloop.first %} is-active{% endif %}"
            id="DDProductionPanel-{{ section.id }}-{{ block.id }}"
            role="tabpanel"
            aria-labelledby="DDProductionTab-{{ section.id }}-{{ block.id }}"
            data-dd-system-panel="{{ block.id }}"
            {% unless forloop.first %}hidden{% endunless %}
          >
            <div class="dd-production-systems__media">
              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 1800
                  | image_tag:
                    class: 'dd-production-systems__image',
                    loading: 'lazy',
                    widths: '640, 960, 1280, 1600, 1800',
                    sizes: '(min-width: 990px) calc(100vw - 420px), 100vw',
                    alt: block.settings.title
                }}
              {% else %}
                <img
                  class="dd-production-systems__image"
                  src="{{ production_asset | asset_url }}"
                  alt="{{ block.settings.title | escape }}"
                  width="1600"
                  height="900"
                  loading="lazy"
                >
              {% endif %}
            </div>

            <div class="dd-production-systems__content">
              <div class="dd-production-systems__intro">
                <span>PRODUCTION SYSTEM //</span>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.short_description | newline_to_br }}</p>
              </div>

              <dl class="dd-production-systems__details">
                <div>
                  <dt>Production Purpose //</dt>
                  <dd>{{ block.settings.purpose }}</dd>
                </div>
                <div>
                  <dt>Applications //</dt>
                  <dd class="dd-production-systems__applications">{{ block.settings.applications }}</dd>
                </div>
                <div>
                  <dt>Core Equipment //</dt>
                  <dd>{{ block.settings.equipment }}</dd>
                </div>
              </dl>

              {% if block.settings.link != blank %}
                <a class="dd-production-systems__link" href="{{ block.settings.link }}">
                  {{ block.settings.cta }} <span aria-hidden="true">&rarr;</span>
                </a>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
  .dd-production-systems {
    --dd-production-accent: #00A3AD;
    --dd-production-white: #FFFFFF;
    --dd-production-muted: rgba(255, 255, 255, 0.66);
    --dd-production-line: rgba(255, 255, 255, 0.11);
    box-sizing: border-box;
    overflow: hidden;
    padding: 88px 0 96px;
    background: #0F1115;
    color: var(--dd-production-white);
  }

  .dd-production-systems *,
  .dd-production-systems *::before,
  .dd-production-systems *::after {
    box-sizing: border-box;
  }

  .dd-production-systems__container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding-right: 32px;
    padding-left: 32px;
  }

  .dd-production-systems__header {
    max-width: 820px;
    margin-bottom: 52px;
  }

  .dd-production-systems__eyebrow,
  .dd-production-systems__intro > span {
    display: block;
    color: var(--dd-production-accent);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .dd-production-systems__eyebrow {
    margin-bottom: 16px;
  }

  .dd-production-systems__heading {
    max-width: 760px;
    margin: 0 0 18px;
    color: var(--dd-production-white);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: clamp(40px, 4vw, 64px);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.98;
    text-transform: uppercase;
  }

  .dd-production-systems__description {
    max-width: 720px;
    margin: 0;
    color: var(--dd-production-muted);
    font-size: 16px;
    line-height: 1.6;
  }

  .dd-production-systems__layout {
    display: grid;
    grid-template-columns: 320px minmax(0, 1fr);
    border-top: 1px solid var(--dd-production-line);
    border-bottom: 1px solid var(--dd-production-line);
  }

  .dd-production-systems__navigation {
    border-right: 1px solid var(--dd-production-line);
  }

  .dd-production-systems__tab {
    position: relative;
    display: grid;
    width: 100%;
    grid-template-columns: 48px minmax(0, 1fr);
    gap: 16px;
    align-items: start;
    padding: 25px 24px 25px 0;
    border: 0;
    border-bottom: 1px solid var(--dd-production-line);
    background: transparent;
    color: var(--dd-production-white);
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .dd-production-systems__tab:last-child {
    border-bottom: 0;
  }

  .dd-production-systems__tab::before {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 2px;
    background: transparent;
    content: '';
  }

  .dd-production-systems__tab:hover,
  .dd-production-systems__tab:focus-visible,
  .dd-production-systems__tab.is-active {
    color: var(--dd-production-accent);
  }

  .dd-production-systems__tab.is-active::before {
    background: var(--dd-production-accent);
  }

  .dd-production-systems__tab:focus-visible {
    outline: 1px solid var(--dd-production-accent);
    outline-offset: -4px;
  }

  .dd-production-systems__number {
    color: var(--dd-production-accent);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.2;
  }

  .dd-production-systems__tab-title {
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.08;
    text-transform: uppercase;
  }

  .dd-production-systems__evidence {
    min-width: 0;
    padding-left: 32px;
  }

  .dd-production-systems__panel[hidden] {
    display: none;
  }

  .dd-production-systems__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #15191E;
  }

  .dd-production-systems__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dd-production-systems__content {
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) minmax(300px, 1.25fr);
    column-gap: 44px;
    padding: 30px 0 34px;
  }

  .dd-production-systems__intro > span {
    margin-bottom: 13px;
    font-size: 10px;
  }

  .dd-production-systems__intro h3 {
    max-width: 420px;
    margin: 0 0 14px;
    color: var(--dd-production-white);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 30px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    text-transform: uppercase;
  }

  .dd-production-systems__intro p {
    max-width: 390px;
    margin: 0;
    color: var(--dd-production-muted);
    font-size: 15px;
    line-height: 1.55;
  }

  .dd-production-systems__details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
    margin: 0;
  }

  .dd-production-systems__details > div {
    padding-top: 14px;
    border-top: 1px solid var(--dd-production-line);
  }

  .dd-production-systems__details > div:first-child {
    grid-column: 1 / -1;
  }

  .dd-production-systems__details dt {
    margin-bottom: 8px;
    color: var(--dd-production-accent);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .dd-production-systems__details dd {
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 13px;
    line-height: 1.5;
  }

  .dd-production-systems__applications ul {
    display: grid;
    gap: 5px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .dd-production-systems__applications li {
    position: relative;
    padding-left: 13px;
  }

  .dd-production-systems__applications li::before {
    position: absolute;
    top: 0.7em;
    left: 0;
    width: 5px;
    height: 1px;
    background: var(--dd-production-accent);
    content: '';
  }

  .dd-production-systems__link {
    display: inline-flex;
    grid-column: 1 / -1;
    align-items: center;
    justify-self: start;
    gap: 11px;
    margin-top: 30px;
    color: var(--dd-production-accent);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
  }

  .dd-production-systems__link:focus-visible {
    outline: 1px solid var(--dd-production-accent);
    outline-offset: 5px;
  }

  @media (max-width: 990px) {
    .dd-production-systems__layout {
      grid-template-columns: 260px minmax(0, 1fr);
    }

    .dd-production-systems__evidence {
      padding-left: 24px;
    }

    .dd-production-systems__content {
      grid-template-columns: 1fr;
      row-gap: 28px;
    }
  }

  @media (max-width: 760px) {
    .dd-production-systems {
      padding: 64px 0 70px;
    }

    .dd-production-systems__container {
      padding-right: 20px;
      padding-left: 20px;
    }

    .dd-production-systems__header {
      margin-bottom: 34px;
    }

    .dd-production-systems__heading {
      font-size: 40px;
      line-height: 1.02;
    }

    .dd-production-systems__description {
      font-size: 15px;
    }

    .dd-production-systems__layout {
      grid-template-columns: 1fr;
    }

    .dd-production-systems__navigation {
      border-right: 0;
      border-bottom: 1px solid var(--dd-production-line);
    }

    .dd-production-systems__tab {
      grid-template-columns: 42px minmax(0, 1fr);
      padding: 19px 0;
    }

    .dd-production-systems__tab-title {
      font-size: 18px;
    }

    .dd-production-systems__evidence {
      padding: 24px 0 0;
    }

    .dd-production-systems__content {
      padding-bottom: 30px;
    }

    .dd-production-systems__intro h3 {
      font-size: 27px;
    }
  }

  @media (max-width: 480px) {
    .dd-production-systems__heading {
      font-size: 36px;
    }

    .dd-production-systems__details {
      grid-template-columns: 1fr;
    }

    .dd-production-systems__details > div:first-child {
      grid-column: auto;
    }
  }
</style>

<script>
  (() => {
    const section = document.getElementById('DDProductionSystems-{{ section.id }}');

    if (!section || section.dataset.initialized === 'true') return;

    section.dataset.initialized = 'true';

    const tabs = Array.from(section.querySelectorAll('[data-dd-system-tab]'));
    const panels = Array.from(section.querySelectorAll('[data-dd-system-panel]'));

    const activateSystem = (blockId, focusTab = false) => {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.ddSystemTab === blockId;
        tab.classList.toggle('is-active', isActive);
        tab.setAttribute('aria-selected', String(isActive));
        tab.setAttribute('tabindex', isActive ? '0' : '-1');

        if (isActive && focusTab) tab.focus();
      });

      panels.forEach((panel) => {
        const isActive = panel.dataset.ddSystemPanel === blockId;
        panel.classList.toggle('is-active', isActive);
        panel.hidden = !isActive;
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activateSystem(tab.dataset.ddSystemTab));

      tab.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowDown' && event.key !== 'ArrowUp') return;

        event.preventDefault();
        const currentIndex = tabs.indexOf(tab);
        const direction = event.key === 'ArrowDown' ? 1 : -1;
        const nextIndex = (currentIndex + direction + tabs.length) % tabs.length;
        activateSystem(tabs[nextIndex].dataset.ddSystemTab, true);
      });
    });

    section.addEventListener('shopify:block:select', (event) => {
      activateSystem(event.detail.blockId);
    });

    if (tabs[0]) activateSystem(tabs[0].dataset.ddSystemTab);
  })();
</script>

{% schema %}
{
  "name": "DD Production Systems",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "MANUFACTURING CAPABILITY SYSTEMS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Production Systems"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Integrated production systems designed around the manufacturing capabilities your operation needs to build."
    }
  ],
  "blocks": [
    {
      "type": "system",
      "name": "Production system",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "System name",
          "default": "Production System"
        },
        {
          "type": "textarea",
          "id": "short_description",
          "label": "Short description",
          "default": "Production capability for industrial manufacturing."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Production evidence image"
        },
        {
          "type": "textarea",
          "id": "purpose",
          "label": "Production purpose",
          "default": "Build repeatable production capacity for the required manufacturing workflow."
        },
        {
          "type": "richtext",
          "id": "applications",
          "label": "Applications",
          "default": "<ul><li>Manufacturing application</li><li>Production application</li></ul>"
        },
        {
          "type": "text",
          "id": "equipment",
          "label": "Core equipment",
          "default": "Production Equipment"
        },
        {
          "type": "url",
          "id": "link",
          "label": "System link"
        },
        {
          "type": "text",
          "id": "cta",
          "label": "CTA label",
          "default": "Explore System"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DD Production Systems",
      "blocks": [
        { "type": "system" },
        { "type": "system" },
        { "type": "system" },
        { "type": "system" }
      ]
    }
  ]
}
{% endschema %}
