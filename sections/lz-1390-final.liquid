<style>
  .p-1390-wrapper { background: #fff; font-family: 'Archivo Narrow', sans-serif; }
  .p-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .p-1390-hero { padding: 40px 0; }
  .p-hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .main-img-wrapper { border: 1px solid #eee; margin-bottom: 10px; }
  .main-img-wrapper img { width: 100%; height: auto; display: block; }
  .thumb-grid-v2 { display: flex; gap: 10px; overflow-x: auto; padding-bottom: 5px; }
  .thumb-v2 { width: 70px; height: 70px; border: 1px solid #ddd; cursor: pointer; }
  .thumb-v2.active { border-color: #006841; border-width: 2px; }
  .p-title { font-size: 26px; font-weight: bold; color: #1a1a1a; margin-bottom: 15px; }
  .info-list { padding-left: 20px; }
  .btn-primary-v2 { background: #004d30; color: #fff; padding: 15px 40px; text-decoration: none; font-weight: bold; display: inline-block; }
  .p-trust-bar-v2 { background: #f8f8f8; padding: 30px 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee; margin-bottom: 50px; }
  .trust-grid-v2 { display: grid; grid-template-columns: repeat(4, 1fr); text-align: center; }
  .section-title { font-size: 22px; font-weight: bold; border-left: 5px solid #006841; padding-left: 15px; margin-bottom: 30px; }
  .material-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 15px; margin-bottom: 60px; }
  .material-card { border: 1px solid #eee; text-align: center; padding: 10px; background: #fff; }
  .material-card img { width: 100%; height: auto; margin-bottom: 10px; }
  
  /* SPEC TABLE STYLE (Matching Image Hcc403398636142de9c940fbcf0680cace) */
  .spec-header-image { 
    background: linear-gradient(to right, #2a75bb, #68a0d4); 
    color: #fff; 
    padding: 10px 20px; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    border-radius: 4px 4px 0 0;
  }
  .header-main { font-size: 24px; font-weight: bold; text-shadow: 1px 1px 2px rgba(0,0,0,0.2); }
  .header-brand { font-size: 16px; font-weight: bold; opacity: 0.9; }
  .spec-table-wrapper { border: 1px solid #333; border-top: none; }
  .spec-zebra-table { width: 100%; border-collapse: collapse; }
  .spec-zebra-table td { padding: 12px 20px; border: 1px solid #333; color: #333; font-size: 15px; text-align: center; }
  .spec-zebra-table tr td:first-child { width: 40%; font-weight: bold; }
  .spec-zebra-table tr:nth-child(even) { background: #f9f9f9; }

  @media (max-width: 768px) { .p-hero-grid, .trust-grid-v2, .material-grid { grid-template-columns: 1fr; } }
</style>

<script>
function changeImg(el) { 
  document.getElementById('main-product-img').src = el.src; 
  document.querySelectorAll('.thumb-v2').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}
</script>
