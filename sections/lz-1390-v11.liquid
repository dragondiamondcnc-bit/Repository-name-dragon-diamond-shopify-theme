<style>
  .p-1390-wrapper { background: #fff; font-family: 'Archivo Narrow', sans-serif; color: #333; }
  .p-container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
  .p-1390-hero { padding: 40px 0; }
  .p-hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
  .main-img-wrapper { border: 1px solid #eee; margin-bottom: 10px; }
  .main-img-wrapper img { width: 100%; height: auto; display: block; }
  .thumb-grid-v2 { display: flex; gap: 10px; overflow-x: auto; }
  .thumb-v2 { width: 70px; height: 70px; border: 1px solid #ddd; cursor: pointer; object-fit: cover; }
  .thumb-v2.active { border-color: #006841; border-width: 2px; }
  .p-title { font-size: 28px; font-weight: 800; margin-bottom: 15px; line-height: 1.2; }
  .p-description { font-size: 15px; color: #666; margin-bottom: 25px; line-height: 1.6; }
  .info-header { font-size: 16px; font-weight: 800; margin-bottom: 10px; color: #1a1a1a; }
  .info-list { padding-left: 20px; margin-bottom: 30px; }
  .btn-primary-v2 { background: #004d30; color: #fff; padding: 15px 40px; text-decoration: none; font-weight: 800; display: inline-block; border-radius: 2px; }
  .p-trust-bar-v2 { background: #f9f9f9; padding: 40px 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee; margin-bottom: 50px; }
  .trust-grid-v2 { display: grid; grid-template-columns: repeat(4, 1fr); text-align: center; gap: 20px; }
  .trust-item strong { display: block; font-size: 16px; font-weight: 800; margin-bottom: 8px; }
  .trust-item p { font-size: 13px; color: #666; margin: 0; }
  .section-title { font-size: 22px; font-weight: 800; border-left: 5px solid #006841; padding-left: 15px; margin-bottom: 30px; text-transform: uppercase; }
  .material-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 15px; margin-bottom: 60px; }
  .material-card { border: 1px solid #eee; text-align: center; padding: 15px; background: #fff; transition: 0.3s; }
  .material-card:hover { border-color: #006841; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
  .material-card img { width: 100%; height: auto; margin-bottom: 10px; }
  
  /* SPEC TABLE CSS */
  .spec-header-custom { 
    background: linear-gradient(to right, #2a75bb, #68a0d4); 
    color: #fff; 
    padding: 12px 25px; 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    border-radius: 4px 4px 0 0;
  }
  .header-main { font-size: 24px; font-weight: 800; text-transform: uppercase; }
  .header-brand { font-size: 16px; font-weight: bold; }
  .spec-table-container { border: 1px solid #333; border-top: none; overflow-x: auto; }
  .spec-zebra-v11 { width: 100%; border-collapse: collapse; min-width: 600px; }
  .spec-zebra-v11 td { padding: 12px 20px; border: 1px solid #333; font-size: 15px; text-align: center; }
  .spec-zebra-v11 tr td:first-child { width: 40%; font-weight: 800; background: #fdfdfd; }
  .spec-zebra-v11 tr:nth-child(even) { background: #f9f9f9; }

  @media (max-width: 900px) { .p-hero-grid { grid-template-columns: 1fr; } .material-grid { grid-template-columns: repeat(3, 1fr); } .trust-grid-v2 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .material-grid { grid-template-columns: repeat(2, 1fr); } .trust-grid-v2 { grid-template-columns: 1fr; } }
</style>

<script>
function changeImg(el) { 
  document.getElementById('main-product-img').src = el.src; 
  document.querySelectorAll('.thumb-v2').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}
</script>
