    letter-spacing: 1px !important;
  }

  @media (max-width: 1100px) {
    .v-english-v10 .success-card { width: calc(50% - 10px) !important; }
  }
  @media (max-width: 600px) {
    .v-english-v10 .success-card { width: 100% !important; }
  }
</style>

