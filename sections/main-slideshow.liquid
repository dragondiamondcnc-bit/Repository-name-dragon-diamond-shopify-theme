  Optimized for full viewport width with a 1.77:1 aspect ratio.
{% endcomment %}

<div class="main-slideshow-section">
  
  <div class="slideshow-container">
    
    <!-- Slide 1: CO2 Laser Showcase (V3.8 - Composite Master - 16:9 - White Text) -->
    <div class="slide-item">
      <div class="image-ratio-wrapper">
        <img src="https://sc01.alicdn.com/kf/H83d7abd45bb245dc8cfd1c61900f5648R.png" 
             alt="DRAGON DIAMOND CO2 Laser Cutting Machine - V3.8 Composite Master Final">
      </div>
      <a href="/products/lz-1390-industrial-co2-laser-cutting-machine" class="slide-link">Explore LZ-1390</a>
    </div>

    <!-- Slide 2: Manufacturing Mastery (16:9) -->
    <div class="slide-item">
      <div class="image-ratio-wrapper">
        <img src="https://sc02.alicdn.com/kf/Aa1fe8b6b0b0e439e8ecfff756a2af698a.png" 
             alt="13+ Years of Excellence">
      </div>
      <a href="/pages/about-us" class="slide-link">About Us</a>
    </div>

    <!-- Slide 3: Global Support (16:9) -->
    <div class="slide-item">
      <div class="image-ratio-wrapper">
        <img src="https://sc02.alicdn.com/kf/A38e74dcb0f8d4535ab5f1f4c80ee1651Z.png" 
             alt="24/7 Global Engineering Support">
      </div>
      <a href="/pages/contact-us" class="slide-link">Get Support</a>
