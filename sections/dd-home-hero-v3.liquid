{% comment %}
  DD Home Hero V3 - Documentary Evidence Grid
  Layout: 40/60 Split (Identity / Evidence Grid)
  Target: Sign Manufacturing Authority
{% endcomment %}

<section class="dd-hero-v3">
  <div class="dd-container">
    <div class="dd-hero-grid">
      <!-- LEFT COLUMN: IDENTITY (40%) -->
      <div class="dd-hero-content">
        <span class="dd-sub">IDENTITY // SIGN_MANUFACTURING_SYSTEMS</span>
        <h1 class="dd-hero-title">SIGN MANUFACTURING<br>LASER SYSTEMS</h1>
        <p class="dd-hero-lead">CO2, CNC and Fiber laser systems for acrylic signage production and industrial fabrication.</p>
        
        <div class="dd-proof-strip">
          <div class="dd-proof-item"><span>✓</span> Verified Global Deployments</div>
          <div class="dd-proof-item"><span>✓</span> Factory Verification Available</div>
          <div class="dd-proof-item"><span>✓</span> Remote Installation Support</div>
          <div class="dd-proof-item"><span>✓</span> Production Launch Assistance</div>
        </div>

        <div class="dd-hero-actions">
          <a href="#v2-workflows" class="dd-btn-solid">EXPLORE SOLUTIONS //</a>
          <a href="/pages/case-studies" class="dd-btn-outline">VIEW CASE STUDIES</a>
          <a href="/pages/contact" class="dd-btn-tertiary">TALK TO ENGINEER //</a>
        </div>
      </div>

      <!-- RIGHT COLUMN: EVIDENCE GRID (60%) -->
      <div class="dd-hero-evidence">
        <div class="dd-evidence-2x2">
          <!-- TILE 01: ISRAEL -->
          <div class="dd-tile">
            <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/A18c03dcd05e243b68b0373b5f9af58d4U.webp?v=1775467444" alt="Israel Factory Verification" loading="eager">
            <div class="dd-tile-overlay">
              <span class="dd-tile-country">ISRAEL</span>
              <div class="dd-tile-meta">
                <span class="dd-tile-title">Factory Verification</span>
                <span class="dd-tile-system">LZ-1325 CNC Router</span>
              </div>
            </div>
          </div>

          <!-- TILE 02: UGANDA -->
          <div class="dd-tile">
            <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/A66c8105148f34f9cbebffa8488a9068a8.webp?v=1775467444" alt="Uganda Sign Manufacturing" loading="eager">
            <div class="dd-tile-overlay">
              <span class="dd-tile-country">UGANDA</span>
              <div class="dd-tile-meta">
                <span class="dd-tile-title">Sign Manufacturing</span>
                <span class="dd-tile-system">CO2 Laser System</span>
              </div>
            </div>
          </div>

          <!-- TILE 03: GEORGIA -->
          <div class="dd-tile">
            <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/A67650eef2fc749ff87a30ad3becfbb398.webp?v=1775467444" alt="Georgia Furniture Production" loading="lazy">
            <div class="dd-tile-overlay">
              <span class="dd-tile-country">GEORGIA</span>
              <div class="dd-tile-meta">
                <span class="dd-tile-title">Furniture Production</span>
                <span class="dd-tile-system">LZ-2030 ATC CNC</span>
              </div>
            </div>
          </div>

          <!-- TILE 04: ETHIOPIA -->
          <div class="dd-tile">
            <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/Af74a3729e0dd46beaa75f9ebe36d9a3cc.webp?v=1775467444" alt="Ethiopia Deployment" loading="lazy">
            <div class="dd-tile-overlay">
              <span class="dd-tile-country">ETHIOPIA</span>
              <div class="dd-tile-meta">
                <span class="dd-tile-title">Deployment In Progress</span>
                <span class="dd-tile-system">Production Expansion</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .dd-hero-v3 { padding: 120px 0; background: #FFF; overflow: hidden; }
  .dd-hero-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 80px; align-items: start; }
  .dd-hero-content { padding-left: 40px; }
  
  /* Left Column Content */
  .dd-hero-title { font-size: 64px; line-height: 0.95; font-weight: 800; letter-spacing: -3px; margin: 0 0 32px; text-transform: uppercase; color: #111; font-family: 'Archivo Narrow', sans-serif; }
  .dd-hero-lead { font-size: 18px; line-height: 1.6; color: rgba(15,17,21,0.6); max-width: 500px; margin-bottom: 48px; }
  
  .dd-proof-strip { display: grid; grid-template-columns: 1fr; gap: 14px; margin-bottom: 56px; }
  .dd-proof-item { font-size: 13px; font-weight: 700; color: #111; letter-spacing: 1px; display: flex; gap: 10px; align-items: center; text-transform: uppercase; }
  .dd-proof-item span { color: #00A3AD; font-size: 16px; }

  .dd-hero-actions { display: flex; flex-direction: column; gap: 12px; }
  .dd-btn-solid { background: #111; color: #FFF; padding: 18px 40px; text-decoration: none; font-weight: 700; letter-spacing: 1.5px; display: block; text-align: center; font-size: 11px; text-transform: uppercase; }
  .dd-btn-outline { border: 1px solid rgba(15,17,21,0.2); padding: 18px 40px; text-decoration: none; font-weight: 700; letter-spacing: 1.5px; color: #111; display: block; text-align: center; font-size: 11px; text-transform: uppercase; }
  .dd-btn-tertiary { background: transparent; color: #00A3AD; padding: 10px 0; text-decoration: none; font-weight: 800; letter-spacing: 1.5px; display: block; text-align: left; font-size: 11px; text-transform: uppercase; }
  .dd-btn-solid:hover { background: #00A3AD; }

  /* Right Column Evidence Grid */
  .dd-evidence-2x2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; background: #F5F5F5; padding: 0; }
  .dd-tile { position: relative; aspect-ratio: 1/1; overflow: hidden; background: #000; }
  .dd-tile img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1), opacity 0.3s ease; }
  .dd-tile:hover img { transform: scale(1.05); opacity: 1; }

  .dd-tile-overlay { position: absolute; inset: 0; padding: 24px; display: flex; flex-direction: column; justify-content: space-between; pointer-events: none; }
  .dd-tile-country { background: #00A3AD; color: #FFF; padding: 4px 12px; font-size: 10px; font-weight: 700; letter-spacing: 2px; align-self: start; }
  
  .dd-tile-meta { display: flex; flex-direction: column; gap: 4px; }
  .dd-tile-title { color: #FFF; font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: -0.5px; }
  .dd-tile-system { color: rgba(255,255,255,0.6); font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }

  @media (max-width: 1024px) {
    .dd-hero-grid { grid-template-columns: 1fr; gap: 64px; }
    .dd-hero-title { font-size: 48px; }
    .dd-evidence-2x2 { gap: 8px; }
    .dd-tile-overlay { padding: 16px; }
    .dd-tile-title { font-size: 14px; }
  }
</style>

{% schema %}
{
  "name": "DD Home Hero V3",
  "settings": [],
  "presets": [{"name": "DD Home Hero V3"}]
}
{% endschema %}
