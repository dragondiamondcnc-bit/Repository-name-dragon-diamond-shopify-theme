<!-- Custom Hero Banner V2.9 - Operational Excellence Edition -->
{{ 'home-v2.css' | asset_url | stylesheet_tag }}

<section class="hero-banner-v2">
  <!-- Application Background Layer (Visual Evidence Layer) -->
  <div class="hero-application-proof"></div>

  <div class="hero-content-wrap">
    <!-- Left Text Content (Conversion Focused) -->
    <div class="hero-text-side">
      <span class="hero-sub-label">FACTORY DIRECT | DRAGON DIAMOND</span>
      <h1 class="hero-main-title">Precision<br>Meets Power</h1>
      <p class="hero-description">
        Elevate your production with Tier-1 industrial laser systems. Specialized in CO2 Laser & CNC Equipment for global precision manufacturing.
      </p>
      
      <!-- DNA Components Backing -->
      <div class="hero-trust-line">
        <span>RECI CO2 TUBE</span> <span class="trust-sep">|</span>
        <span>RUIDA CONTROLLER</span> <span class="trust-sep">|</span>
        <span>LEADSHINE STEPPER</span>
      </div>

      <div class="hero-cta-group">
        <a href="/collections/all" class="btn-primary-hero">Explore Products</a>
        <a href="/pages/contact" class="btn-secondary-hero">Request Quote</a>
      </div>
    </div>

    <!-- Right Side - REAL MACHINE DISPLAY -->
    <div class="hero-image-side">
      <div class="machine-container">
        <!-- Intelligent Mask for Logo Removal -->
        <div class="logo-mask"></div>
        <img src="https://gzddlaser.com/cdn/shop/files/A2d9725cf4a494c0abf67d1febb0c36e9u.webp" alt="LZ-1390 Real Machine Display" class="hero-machine-img">
      </div>
    </div>
  </div>

  <!-- Operational Excellence Trust Bar (B2B Value Proposition) -->
  <div class="hero-trust-bar">
    <div class="trust-bar-container">
      <!-- Item 1: Factory Direct -->
      <div class="trust-item">
        <div class="trust-icon">🏭</div>
        <div class="trust-text">
          <h4>Factory Direct</h4>
          <p>Ex-factory pricing from GZ, China.</p>
        </div>
      </div>
      
      <!-- Item 2: Certified Quality -->
      <div class="trust-item">
        <div class="trust-icon">✅</div>
        <div class="trust-text">
          <h4>Global Standards</h4>
          <p>CE, FDA & ISO 9001 Certified.</p>
        </div>
      </div>

      <!-- Item 3: Fast Logistics -->
      <div class="trust-item">
        <div class="trust-icon">✈️</div>
        <div class="trust-text">
          <h4>Global Shipping</h4>
          <p>Safe delivery to 120+ countries.</p>
        </div>
      </div>

      <!-- Item 4: Expert Support -->
      <div class="trust-item">
        <div class="trust-icon">🛠️</div>
        <div class="trust-text">
          <h4>Expert Support</h4>
          <p>24/7 technical live assistance.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner V2",
  "settings": [],
  "presets": [
    {
      "name": "Hero Banner V2"
    }
  ]
}
{% endschema %}
