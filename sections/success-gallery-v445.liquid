<section class="success-gallery-section v444-forced" id="section-{{ section.id }}">
  <div class="container-v2">
    <div class="section-header-v2">
      <h2 class="section-title-v2">GLOBAL SUCCESS STORIES</h2>
      <p class="section-subtitle-v2">Driving industrial excellence across 50+ countries with Dragon Diamond's Industrial 4.0 solutions.</p>
    </div>

    <div class="success-grid">
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc02.alicdn.com/kf/Af71f3081b8b84dcf86ce227ba253176aD.png" alt="Signage" loading="lazy">
        </div>
        <div class="card-info">
          <h3 class="card-title">Signage Excellence</h3>
          <p class="card-desc">Nigeria retail boom with high-precision 3D signage production.</p>
          <a href="/pages/contact" class="card-link">View Solution →</a>
        </div>
      </div>

      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc02.alicdn.com/kf/A3698887968394e2293021f478e7185ccY.png" alt="Textile" loading="lazy">
        </div>
        <div class="card-info">
          <h3 class="card-title">Textile Precision</h3>
          <p class="card-desc">Integrated embroidery & laser cutting workflows for Central Asia.</p>
          <a href="/pages/contact" class="card-link">View Solution →</a>
        </div>
      </div>

      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc02.alicdn.com/kf/A82b4507b97e949988a6d0c2e36504a79T.png" alt="Furniture" loading="lazy">
        </div>
        <div class="card-info">
          <h3 class="card-title">Bespoke Furniture</h3>
          <p class="card-desc">Standard large-format CNC solutions for Caucasus furniture leaders.</p>
          <a href="/pages/contact" class="card-link">View Solution →</a>
        </div>
      </div>

      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc02.alicdn.com/kf/Ad7d2d6028786478597ffc38ceba42428P.png" alt="Acrylic" loading="lazy">
        </div>
        <div class="card-info">
          <h3 class="card-title">Acrylic Design</h3>
          <p class="card-desc">Precision UV print & cut integration for European design studios.</p>
          <a href="/pages/contact" class="card-link">View Solution →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  html body .success-gallery-section.v444-forced {
    background: #ffffff !important;
    padding: 80px 0 !important;
    border-top: 1px solid #f0f0f0 !important;
    font-family: 'Archivo Narrow', sans-serif !important;
    display: block !important;
  }
  html body .v444-forced .container-v2 {
    max-width: 1300px !important;
    margin: 0 auto !important;
    width: 90% !important;
    display: block !important;
  }
  html body .v444-forced .success-grid {
    display: grid !important;
    grid-template-columns: repeat(4, 1fr) !important;
    gap: 30px !important;
  }
  html body .v444-forced .success-card {
    background: #ffffff !important;
    border: 1px solid #f0f0f0 !important;
    padding: 20px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
    text-decoration: none !important;
  }
  html body .v444-forced .card-image-wrapper {
    width: 150px !important;
    height: 150px !important;
    margin-bottom: 20px !important;
    margin-right: 0 !important;
    border-radius: 8px !important;
    overflow: hidden !important;
    flex-shrink: 0 !important;
    border: 1px solid #f5f5f5 !important;
    display: block !important;
  }
  html body .v444-forced .card-image-wrapper img {
    width: 150px !important;
    height: 150px !important;
    object-fit: cover !important;
    display: block !important;
  }
  html body .v444-forced .card-title {
    font-family: 'Archivo Narrow', sans-serif !important;
    font-size: 18px !important;
    font-weight: 800 !important;
    color: #1a1a1a !important;
    margin-bottom: 10px !important;
    text-transform: uppercase !important;
    display: block !important;
  }
  html body .v444-forced .card-desc {
    font-size: 12px !important;
    line-height: 1.5 !important;
    color: #666 !important;
    margin-bottom: 20px !important;
    min-height: 36px !important;
    display: block !important;
  }
  html body .v444-forced .card-link {
    font-size: 11px !important;
    font-weight: 900 !important;
    color: #006841 !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
    display: block !important;
  }

  @media (max-width: 990px) {
    html body .v444-forced .success-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>

