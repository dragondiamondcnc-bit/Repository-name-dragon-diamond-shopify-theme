<script>
  (function() {
    const data = {
      "t1": "�������� (����)", "m1": "����: ���� / �������� / ������", "d1": "���������������������� 3D ��������������������",
      "t2": "�������� (������������)", "m2": "����: ������������ / ���� / ������", "d2": "��������������������������������������������",
      "t3": "�������� (��������)", "m3": "����: �������� / �������� (Gocha ����)", "d3": "ATC �������� CNC ��������������������������������",
      "t4": "���������� (������)", "m4": "����: ������ / ������ / ��������", "d4": "�������� UV ������������������������������������"
    };
    function inject() {
      document.querySelectorAll('[data-gid]').forEach(el => {
        const id = el.getAttribute('data-gid');
        if (data[id]) el.textContent = data[id];
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', inject);
    } else {
      inject();
    }
  })();
</script>

<style>
  .success-gallery-section.v-nuclear-v8 {
    background: #ffffff !important;
    padding: 80px 0 !important;
    font-family: "Archivo Narrow", "Microsoft YaHei", "PingFang SC", sans-serif !important;
    display: block !important;
    overflow-x: hidden !important;
  }
  .v-nuclear-v8 .container-v2 {
    max-width: 1200px !important;
    margin: 0 auto !important;
    width: 95% !important;
  }
  .v-nuclear-v8 .section-header-v2 {
    text-align: center !important;
    margin-bottom: 50px !important;
  }
  .v-nuclear-v8 .section-title-v2 {
    font-size: 32px !important;
    font-weight: 800 !important;
    color: #1a1a1a !important;
    letter-spacing: 2px !important;
    text-transform: uppercase !important;
    margin: 0 0 10px 0 !important;
  }
  .v-nuclear-v8 .section-subtitle-v2 {
    font-size: 14px !important;
    color: #888 !important;
    max-width: 700px !important;
    margin: 0 auto !important;
  }
  .v-nuclear-v8 .success-grid {
    display: flex !important;
    flex-wrap: wrap !important;
    justify-content: center !important;
    gap: 20px !important;
    width: 100% !important;
  }
  .v-nuclear-v8 .success-card {
    background: #ffffff !important;
    border: 1px solid #f0f0f0 !important;
    padding: 20px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
    transition: all 0.3s ease !important;
    text-decoration: none !important;
    /* FIX: Ensure 4 cards fit in 1200px (1200/4 - gap) */
    width: calc(25% - 15px) !important;
    min-width: 250px !important;
    box-sizing: border-box !important;
  }
  .v-nuclear-v8 .success-card:hover {
    border-color: #006841 !important;
    transform: translateY(-5px) !important;
  }
  .v-nuclear-v8 .card-image-wrapper {
    position: relative !important;
    width: 180px !important;
    height: 180px !important;
    margin-bottom: 20px !important;
    border-radius: 8px !important;
    overflow: hidden !important;
    border: 1px solid #f5f5f5 !important;
    background: #f9f9f9 !important;
  }
  .v-nuclear-v8 .card-image-wrapper img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
  .v-nuclear-v8 .industry-tag {
    position: absolute !important;
    top: 8px !important;
    left: 8px !important;
    background: #006841 !important;
    color: #ffffff !important;
    font-size: 9px !important;
    font-weight: 700 !important;
    padding: 4px 10px !important;
    border-radius: 2px !important;
    text-transform: uppercase !important;
    z-index: 10 !important;
  }
  .v-nuclear-v8 .card-title {
    font-size: 16px !important;
    font-weight: 700 !important;
    color: #1a1a1a !important;
    margin: 0 0 8px 0 !important;
    min-height: 40px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    line-height: 1.2 !important;
  }
  .v-nuclear-v8 .card-market {
    font-size: 11px !important;
    color: #006841 !important;
    font-weight: 700 !important;
    margin-bottom: 10px !important;
  }
  .v-nuclear-v8 .card-desc {
    font-size: 12px !important;
    line-height: 1.5 !important;
    color: #666 !important;
    margin-bottom: 20px !important;
    min-height: 54px !important;
  }
  .v-nuclear-v8 .card-link {
    font-size: 11px !important;
    font-weight: 700 !important;
    color: #006841 !important;
    text-decoration: none !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
  }

  @media (max-width: 1100px) {
    .v-nuclear-v8 .success-card { width: calc(50% - 10px) !important; }
  }
  @media (max-width: 600px) {
    .v-nuclear-v8 .success-card { width: 100% !important; }
  }
</style>

