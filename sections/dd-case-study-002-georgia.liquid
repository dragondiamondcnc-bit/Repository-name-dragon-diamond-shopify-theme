    border-right: 1px solid rgba(255,255,255,.06);
    text-align: center;
  }

  .dd-overview-item:last-child {
    border-right: none;
  }

  .dd-overview-item span {
    display: block;
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 11px;
    letter-spacing: 2px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .dd-overview-item strong {
    font-size: 18px;
    font-weight: 850;
  }

  .dd-grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 42px;
    margin-top: 56px;
  }

  .dd-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 34px;
    margin-top: 56px;
  }

  .dd-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 56px;
  }

  .dd-evidence-card {
    background: #171A20;
    border: 1px solid rgba(255,255,255,.07);
  }

  .dd-section-light .dd-evidence-card {
    background: #F5F6F7;
    border-color: rgba(0,0,0,.08);
  }

  .dd-img-frame {
    position: relative;
    height: 320px;
    overflow: hidden;
    background: #181B20;
  }

  .dd-img-frame.tall {
    height: 320px;
  }

  .dd-img-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dd-img-frame.contain img {
    object-fit: contain;
    background: #11141A;
  }

  .dd-label {
    position: absolute;
    left: 14px;
    top: 14px;
    z-index: 2;
    padding: 7px 11px;
    background: rgba(15,17,21,.84);
    border: 1px solid rgba(0,163,173,.48);
    color: #fff;
    font-family: "Archivo Narrow", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
  }

  .dd-card-body {
    padding: 24px;
  }

  .dd-card-title {
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .dd-card-text {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255,255,255,.62) !important;
  }

  .dd-section-light .dd-card-text {
    color: #555555 !important;
  }

  .dd-timeline {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .dd-step {
    background: #171A20;
    border: 1px solid rgba(255,255,255,.07);
    padding: 24px 18px;
    min-height: 170px;
  }

  .dd-step-num {
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .dd-step-title {
    font-size: 17px;
    font-weight: 850;
    margin-bottom: 10px;
  }

  .dd-step-copy {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255,255,255,.58);
  }

  .dd-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 48px;
  }

  .dd-related-card {
    display: block;
    text-decoration: none;
    color: #fff;
    background: #171A20;
    border: 1px solid rgba(255,255,255,.07);
    padding: 28px;
  }

  .dd-related-card span {
    display: block;
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .dd-related-card strong {
    font-size: 22px;
    line-height: 1.25;
  }

  /* Section 02 Visual Focal Point Refinement */
  .dd-referral-grid .dd-img-frame.tall {
    height: 360px;
  }
  .dd-referral-grid .dd-card-body {
    padding: 14px 24px 18px;
  }

  /* Section 10 Asymmetric Grid */
  .dd-asymmetric-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: 60px;
    margin-top: 56px;
  }

  @media (max-width: 1024px) {
    .dd-container { padding: 0 22px; }
    .dd-title { font-size: 42px; }
    .dd-h2 { font-size: 32px; }
    .dd-hero { min-height: 450px; }
    .dd-overview-grid,
    .dd-grid-2,
    .dd-grid-3,
    .dd-grid-4,
    .dd-asymmetric-grid,
    .dd-timeline,
    .dd-related-grid {
      grid-template-columns: 1fr;
    }
    .dd-img-frame,
    .dd-img-frame.tall {
      height: 260px !important;
      max-height: 260px !important;
    }
    .dd-img-frame img {
      height: 100% !important;
      object-fit: cover !important;
      display: block;
    }
    .dd-section { padding: 76px 0; }
  }
</style>

<div class="dd-georgia-case">

