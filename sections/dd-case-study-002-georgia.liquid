    color: #ffffff !important;
  }

  .dd-btn-secondary {
    border: 1px solid rgba(255,255,255,.28) !important;
    color: #ffffff !important;
    background: transparent !important;
  }

  .dd-overview {
    background: #11141A !important;
  }

