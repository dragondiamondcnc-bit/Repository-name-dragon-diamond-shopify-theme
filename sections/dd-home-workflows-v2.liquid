{% comment %}
  Dragon Diamond Industries & Production Applications V5
  Final Lock: Industry Representative Images + 2+3 Compact Matrix
  Style: Cold Industrial // Evidence First // Decision Driven
{% endcomment %}

<section class="dd-home-applications" id="v2_1_applications">
  <div class="dd-container">
    <!-- Header -->
    <div class="dd-matrix-header">
      <span class="dd-sub">INDUSTRIES // PRODUCTION_SCENARIOS</span>
      <h2 class="dd-title">Industries & Production Applications</h2>
      <p class="dd-lead">Select the production scenario closest to your business. Dragon Diamond maps real production needs to CO2 laser, CNC router, fiber laser, and UV printing systems.</p>
    </div>
    
    <div class="dd-app-matrix-grid">
      
      <!-- TOP ROW: 2 PRIORITY CARDS (Sign & Event) -->
      <!-- CARD 01: Sign Fabrication -->
      <div class="dd-app-item card-priority">
        <div class="dd-app-media priority-height">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/He090c30b17f04f96bc455dabb2de31e8X.webp?v=1782717917" alt="Sign Fabrication Production Systems" loading="lazy" class="card-01-crop">
          <span class="dd-app-num">01</span>
        </div>
        <div class="dd-app-content">
          <h3 class="dd-app-h3">Sign Fabrication</h3>
          <p class="dd-app-obj">Build acrylic letters, lightboxes, and advertising components with repeatable accuracy.</p>
          <div class="dd-app-tags">
            <span>Acrylic signage</span><span>Channel letters</span><span>Display boards</span>
          </div>
          <div class="dd-app-fit"><strong>SYSTEM FIT:</strong> CO2 Laser · UV Flatbed · CNC Router</div>
          <a href="/pages/case-uganda-sign-factory" class="dd-app-evidence">RELATED DEPLOYMENT: UGANDA //</a>
        </div>
      </div>

      <!-- CARD 02: Display & Event Production -->
      <div class="dd-app-item card-priority">
        <div class="dd-app-media priority-height">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/H5bf5558293914756adf2289583de056av.webp?v=1782717924" alt="Display & Event Production Systems" loading="lazy">
          <span class="dd-app-num">02</span>
        </div>
        <div class="dd-app-content">
          <h3 class="dd-app-h3">Display & Event Production</h3>
          <p class="dd-app-obj">Produce exhibition backdrops, themed panels, and props for commercial display projects.</p>
          <div class="dd-app-tags">
            <span>Backdrop panels</span><span>Exhibition displays</span><span>Event props</span>
          </div>
          <div class="dd-app-fit"><strong>SYSTEM FIT:</strong> CNC Router · CO2 Laser</div>
          <a href="/pages/case-study-israel" class="dd-app-evidence">RELATED DEPLOYMENT: ISRAEL //</a>
        </div>
      </div>

      <!-- BOTTOM ROW: 3 COMPACT CARDS (Textile, CNC Panel, Craft) -->
      <!-- CARD 03: Textile & Soft Material -->
      <div class="dd-app-item card-compact">
        <div class="dd-app-media compact-height">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/H19bea8c47d134db0b70c569a4ad4b451K.webp?v=1782717931" alt="Textile & Soft Material Production" loading="lazy">
          <span class="dd-app-num">03</span>
        </div>
        <div class="dd-app-content">
          <h3 class="dd-app-h3">Textile & Soft Material</h3>
          <p class="dd-app-obj">Cut fabric banners and flexible display materials with clean edges.</p>
          <div class="dd-app-fit"><strong>FIT:</strong> CO2 Laser</div>
          <span class="dd-app-evidence">CATEGORY: SOFT MATERIAL</span>
        </div>
      </div>

      <!-- CARD 04: CNC Panel Fabrication -->
      <div class="dd-app-item card-compact">
        <div class="dd-app-media compact-height">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/H3710b1bbacfa48fead720536281d0b03y.webp?v=1782717938" alt="CNC Panel & Wood Fabrication" loading="lazy">
          <span class="dd-app-num">04</span>
        </div>
        <div class="dd-app-content">
          <h3 class="dd-app-h3">CNC Panel Fabrication</h3>
          <p class="dd-app-obj">Process MDF, PVC, and wood panels for signage and cabinet projects.</p>
          <div class="dd-app-fit"><strong>FIT:</strong> ATC / Heavy CNC</div>
          <a href="/pages/case-study-georgia" class="dd-app-evidence">DEPLOYMENT: GEORGIA //</a>
        </div>
      </div>

      <!-- CARD 05: Craft & Custom Fabrication -->
      <div class="dd-app-item card-compact">
        <div class="dd-app-media compact-height">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/H4de10854c3314de5a6661510a8052b1eX.webp?v=1782717946" alt="UV Flatbed Custom Fabrication" loading="lazy">
          <span class="dd-app-num">05</span>
        </div>
        <div class="dd-app-content">
          <h3 class="dd-app-h3">Craft & Custom Fabrication</h3>
          <p class="dd-app-obj">Support small-batch customization and mixed-material engraving.</p>
          <div class="dd-app-fit"><strong>FIT:</strong> CO2 / CNC / UV</div>
          <span class="dd-app-evidence">APPLICATION: MIXED-MATERIAL</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .dd-home-applications { padding: 56px 0 80px; background: #FFF; border-top: 1px solid #EEE; }
  .dd-home-applications .dd-container {
    max-width: 1240px;
    margin: 0 auto;
    padding-left: 32px;
    padding-right: 32px;
  }
  
  .dd-matrix-header { margin-bottom: 64px; }
  .dd-matrix-header .dd-sub { font-size: 11px; font-weight: 700; letter-spacing: 4px; color: #00A3AD; text-transform: uppercase; }
  .dd-matrix-header .dd-title { font-size: 42px; margin: 12px 0; font-weight: 850; letter-spacing: -2px; text-transform: uppercase; color: #111; }
  .dd-matrix-header .dd-lead { font-size: 16px; color: #666; max-width: 700px; line-height: 1.5; margin: 0; }

  /* 2+3 Grid Matrix */
  .dd-app-matrix-grid { 
    display: grid; 
    grid-template-columns: repeat(6, 1fr); 
    gap: 24px; 
  }

  .dd-app-item { background: #F9FAFB; border: 1px solid #EEE; display: flex; flex-direction: column; transition: border-color 0.3s; }
  .dd-app-item:hover { border-color: #00A3AD; }
  
  /* Layout Logic */
  .card-priority { grid-column: span 3; }
  .card-compact { grid-column: span 2; }

  /* Height Constraints */
  .dd-app-media { position: relative; overflow: hidden; background: #000; width: 100%; }
  .priority-height { height: 400px; }
  .compact-height { height: 310px; }
  
  .dd-app-media img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.1) contrast(1.02); opacity: 0.9; }
  .card-01-crop { object-position: center 25%; }
  .dd-app-num { position: absolute; top: 15px; left: 15px; font-family: 'Archivo Narrow', sans-serif; font-weight: 800; font-size: 11px; color: #FFF; background: var(--dd-cyan); padding: 4px 8px; }

  .dd-app-content { padding: 32px; display: flex; flex-direction: column; gap: 20px; flex-grow: 1; }
  .dd-app-h3 { font-size: 20px; font-weight: 800; margin: 0; text-transform: uppercase; letter-spacing: -0.5px; color: #111; line-height: 1.2; }
  .dd-app-obj { font-size: 13px; line-height: 1.5; color: #666; margin: 0; height: 3em; overflow: hidden; }

  .dd-app-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .dd-app-tags span { font-size: 9px; font-weight: 700; color: #111; background: #EEE; padding: 4px 10px; text-transform: uppercase; letter-spacing: 0.5px; }

  .dd-app-fit { font-size: 11px; color: #999; border-top: 1px solid #EEE; padding-top: 16px; margin-top: auto; }
  .dd-app-fit strong { color: var(--dd-cyan); font-family: 'Archivo Narrow', sans-serif; letter-spacing: 1px; }

  .dd-app-evidence { font-size: 10px; font-weight: 800; color: #111; text-decoration: none; letter-spacing: 1px; transition: color 0.2s; }
  .dd-app-evidence:hover { color: var(--dd-cyan); }
  span.dd-app-evidence { color: #BBB; font-weight: 700; }

  @media (max-width: 1200px) {
    .dd-app-h3 { font-size: 18px; }
    .priority-height { height: 320px; }
    .compact-height { height: 240px; }
  }
  @media (max-width: 1024px) {
    .dd-app-matrix-grid { grid-template-columns: 1fr; }
    .card-priority, .card-compact { grid-column: span 1; }
    .dd-app-h3 { font-size: 22px; }
    .dd-app-obj { height: auto; }
    .priority-height, .compact-height { height: 300px; }
  }
  @media (max-width: 640px) {
    .dd-home-applications .dd-container {
      padding-left: 20px;
      padding-right: 20px;
    }

    .dd-home-applications .dd-matrix-header .dd-title {
      font-size: 31px !important;
      line-height: 1.08 !important;
    }
  }
</style>

{% schema %}
{
  "name": "DD Home Workflows V2",
  "settings": [],
  "presets": [{"name": "DD Home Workflows V2"}]
}
{% endschema %}
