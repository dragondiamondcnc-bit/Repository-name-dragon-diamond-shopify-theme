{% comment %}
  Dragon Diamond Homepage Section 02 V2
  Production scenario decision layer
{% endcomment %}

<section class="dd-home-applications" id="v2_1_applications">
  <div class="dd-container">
    <div class="dd-scenario-header">
      <span class="dd-scenario-eyebrow">PRODUCTION SCENARIOS // INDUSTRY APPLICATIONS</span>
      <h2 class="dd-scenario-title">Choose Your Production Scenario</h2>
      <p class="dd-scenario-lead">
        Select the production workflow that matches your business.
        Dragon Diamond systems are configured around real fabrication requirements.
      </p>
    </div>

    <div class="dd-scenario-grid">
      <article class="dd-scenario-card dd-scenario-card--large">
        <div class="dd-scenario-media dd-scenario-media--large">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/He090c30b17f04f96bc455dabb2de31e8X.webp?v=1782717917" alt="Sign Fabrication Production Systems" loading="lazy" class="dd-scenario-image--sign">
          <span class="dd-scenario-number">01</span>
        </div>
        <div class="dd-scenario-body">
          <h3 class="dd-scenario-card-title">Sign Fabrication</h3>
          <dl class="dd-scenario-specs">
            <div>
              <dt>Production Intent:</dt>
              <dd>Build acrylic letters, lightboxes, and advertising components with repeatable accuracy.</dd>
            </div>
            <div>
              <dt>Recommended System:</dt>
              <dd>CO2 Laser + UV Flatbed + CNC Router</dd>
            </div>
            <div>
              <dt>Verified Reference:</dt>
              <dd><a href="/pages/case-uganda-sign-factory">Uganda sign factory deployment</a></dd>
            </div>
          </dl>
        </div>
      </article>

      <article class="dd-scenario-card dd-scenario-card--large">
        <div class="dd-scenario-media dd-scenario-media--large">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/H5bf5558293914756adf2289583de056av.webp?v=1782717924" alt="Display & Event Production Systems" loading="lazy">
          <span class="dd-scenario-number">02</span>
        </div>
        <div class="dd-scenario-body">
          <h3 class="dd-scenario-card-title">Display & Event Production</h3>
          <dl class="dd-scenario-specs">
            <div>
              <dt>Production Intent:</dt>
              <dd>Produce exhibition backdrops, themed panels, and props for commercial display projects.</dd>
            </div>
            <div>
              <dt>Recommended System:</dt>
              <dd>CNC Router + CO2 Laser</dd>
            </div>
            <div>
              <dt>Verified Reference:</dt>
              <dd><a href="/pages/case-study-israel">Israel event production deployment</a></dd>
            </div>
          </dl>
        </div>
      </article>

      <article class="dd-scenario-card dd-scenario-card--compact">
        <div class="dd-scenario-media dd-scenario-media--compact">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/H19bea8c47d134db0b70c569a4ad4b451K.webp?v=1782717931" alt="Textile & Soft Material Production" loading="lazy">
          <span class="dd-scenario-number">03</span>
        </div>
        <div class="dd-scenario-body">
          <h3 class="dd-scenario-card-title">Textile & Soft Material</h3>
          <dl class="dd-scenario-specs">
            <div>
              <dt>Production Intent:</dt>
              <dd>Cut fabric banners and flexible display materials with clean edges.</dd>
            </div>
            <div>
              <dt>Recommended System:</dt>
              <dd>CO2 Laser</dd>
            </div>
            <div>
              <dt>Verified Reference:</dt>
              <dd>Soft material production workflow</dd>
            </div>
          </dl>
        </div>
      </article>

      <article class="dd-scenario-card dd-scenario-card--compact">
        <div class="dd-scenario-media dd-scenario-media--compact">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/H3710b1bbacfa48fead720536281d0b03y.webp?v=1782717938" alt="CNC Panel & Wood Fabrication" loading="lazy">
          <span class="dd-scenario-number">04</span>
        </div>
        <div class="dd-scenario-body">
          <h3 class="dd-scenario-card-title">CNC Panel Fabrication</h3>
          <dl class="dd-scenario-specs">
            <div>
              <dt>Production Intent:</dt>
              <dd>Process MDF, PVC, and wood panels for signage and cabinet projects.</dd>
            </div>
            <div>
              <dt>Recommended System:</dt>
              <dd>ATC CNC Router + Heavy CNC Platform</dd>
            </div>
            <div>
              <dt>Verified Reference:</dt>
              <dd><a href="/pages/case-study-georgia">Georgia CNC routing deployment</a></dd>
            </div>
          </dl>
        </div>
      </article>

      <article class="dd-scenario-card dd-scenario-card--compact">
        <div class="dd-scenario-media dd-scenario-media--compact">
          <img src="https://cdn.shopify.com/s/files/1/0824/6319/5356/files/H4de10854c3314de5a6661510a8052b1eX.webp?v=1782717946" alt="UV Flatbed Custom Fabrication" loading="lazy">
          <span class="dd-scenario-number">05</span>
        </div>
        <div class="dd-scenario-body">
          <h3 class="dd-scenario-card-title">Craft & Custom Fabrication</h3>
          <dl class="dd-scenario-specs">
            <div>
              <dt>Production Intent:</dt>
              <dd>Support small-batch customization and mixed-material engraving.</dd>
            </div>
            <div>
              <dt>Recommended System:</dt>
              <dd>CO2 Laser + CNC Router + UV Flatbed</dd>
            </div>
            <div>
              <dt>Verified Reference:</dt>
              <dd>Mixed-material fabrication workflow</dd>
            </div>
          </dl>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .dd-home-applications {
    padding: 88px 0 96px;
    background:
      linear-gradient(180deg, #050608 0%, #0B0E12 58%, #080A0D 100%);
    color: #FFFFFF;
  }

  .dd-home-applications .dd-container {
    max-width: 1240px;
    margin: 0 auto;
    padding-left: 32px;
    padding-right: 32px;
  }

  .dd-scenario-header {
    max-width: 760px;
    margin-bottom: 54px;
  }

  .dd-scenario-eyebrow {
    display: block;
    margin-bottom: 16px;
    color: var(--dd-cyan);
    font-family: 'Archivo Narrow', sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 3px;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .dd-scenario-title {
    margin: 0 0 18px;
    color: #FFFFFF;
    font-family: 'Archivo Narrow', sans-serif;
    font-size: clamp(38px, 4vw, 64px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 0.98;
    text-transform: uppercase;
  }

  .dd-scenario-lead {
    max-width: 640px;
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 17px;
    line-height: 1.55;
  }

  .dd-scenario-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 24px;
  }

  .dd-scenario-card {
    position: relative;
    display: flex;
    min-width: 0;
    flex-direction: column;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.045);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    transition: transform 0.28s ease, box-shadow 0.28s ease, background 0.28s ease;
  }

  .dd-scenario-card:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.065);
    box-shadow: inset 0 0 0 1px rgba(0, 163, 173, 0.42), 0 22px 52px rgba(0, 0, 0, 0.28);
  }

  .dd-scenario-card--large {
    grid-column: span 3;
  }

  .dd-scenario-card--compact {
    grid-column: span 2;
  }

  .dd-scenario-media {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #000000;
  }

  .dd-scenario-media--large {
    height: 360px;
  }

  .dd-scenario-media--compact {
    height: 250px;
  }

  .dd-scenario-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.16) contrast(1.08) brightness(0.78);
    opacity: 0.94;
    transition: transform 0.5s ease, filter 0.5s ease;
  }

  .dd-scenario-card:hover .dd-scenario-media img {
    transform: scale(1.035);
    filter: grayscale(0.08) contrast(1.12) brightness(0.86);
  }

  .dd-scenario-image--sign {
    object-position: center 25%;
  }

  .dd-scenario-number {
    position: absolute;
    top: 18px;
    left: 18px;
    color: #FFFFFF;
    font-family: 'Archivo Narrow', sans-serif;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.12em;
  }

  .dd-scenario-number::after {
    content: "";
    display: block;
    width: 34px;
    height: 2px;
    margin-top: 9px;
    background: var(--dd-cyan);
  }

  .dd-scenario-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 28px;
  }

  .dd-scenario-card-title {
    margin: 0 0 24px;
    color: #FFFFFF;
    font-family: 'Archivo Narrow', sans-serif;
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    text-transform: uppercase;
  }

  .dd-scenario-specs {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 18px;
    margin: 0;
  }

  .dd-scenario-specs div {
    display: grid;
    gap: 6px;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.09);
  }

  .dd-scenario-specs dt {
    color: var(--dd-cyan);
    font-family: 'Archivo Narrow', sans-serif;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  .dd-scenario-specs dd {
    margin: 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 14px;
    line-height: 1.45;
  }

  .dd-scenario-specs a {
    color: #FFFFFF;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .dd-scenario-specs a:hover {
    color: var(--dd-cyan);
  }

  @media (max-width: 1200px) {
    .dd-scenario-card-title {
      font-size: 21px;
    }

    .dd-scenario-media--large {
      height: 320px;
    }

    .dd-scenario-media--compact {
      height: 230px;
    }
  }

  @media (max-width: 1024px) {
    .dd-home-applications {
      padding: 72px 0 80px;
    }

    .dd-scenario-grid {
      grid-template-columns: 1fr;
    }

    .dd-scenario-card--large,
    .dd-scenario-card--compact {
      grid-column: span 1;
    }

    .dd-scenario-media--large,
    .dd-scenario-media--compact {
      height: 300px;
    }

    .dd-scenario-card-title {
      font-size: 24px;
    }
  }

  @media (max-width: 640px) {
    .dd-home-applications {
      padding: 58px 0 64px;
    }

    .dd-home-applications .dd-container {
      width: 100%;
      padding-left: 20px;
      padding-right: 20px;
    }

    .dd-scenario-header {
      width: 100%;
      max-width: none;
      margin-bottom: 32px;
    }

    .dd-scenario-eyebrow {
      width: 100%;
      font-size: 10px;
      letter-spacing: 2px;
      word-break: normal;
      overflow-wrap: normal;
    }

    .dd-scenario-title {
      width: 100%;
      max-width: none;
      font-size: 34px;
      line-height: 1.02;
      white-space: normal;
      word-break: normal;
      overflow-wrap: normal;
    }

    .dd-scenario-lead {
      width: 100%;
      max-width: none;
      font-size: 15px;
      white-space: normal;
      word-break: normal;
      overflow-wrap: normal;
    }

    .dd-scenario-grid,
    .dd-scenario-card {
      width: 100%;
      min-width: 0;
    }

    .dd-scenario-media--large,
    .dd-scenario-media--compact {
      height: 218px;
    }

    .dd-scenario-body {
      padding: 21px;
    }
  }
</style>

{% schema %}
{
  "name": "DD Home Workflows V2",
  "settings": [],
  "presets": [{"name": "DD Home Workflows V2"}]
}
{% endschema %}
