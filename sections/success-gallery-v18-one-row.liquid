<section class="success-gallery-section v-english-v18-row" id="success-gallery-{{ section.id }}">
  <div class="container-v2">
    <div class="section-header-v2">
      <h2 class="section-title-v2">SUCCESS CASE GALLERY</h2>
      <p class="section-subtitle-v2">Explore how Dragon Diamond's Industrial 4.0 solutions empower global signage, textile, and furniture manufacturers.</p>
    </div>

    <div class="success-grid">
      <!-- Card 1 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H724740e42dd24a6f93f4c7d211467496j.png" alt="Signage Excellence (Africa)" loading="lazy">
          <span class="industry-tag">SIGNAGE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Signage Excellence (Africa)</h3>
          <p class="card-market">Market: Africa / Uganda / Kampala</p>
          <p class="card-desc">High-precision acrylic cutting for 3D premium branding and display solutions.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/Hbb59fa86a8404b7f9ffa7a197985b759t.png" alt="Textile Precision (Asia)" loading="lazy">
          <span class="industry-tag">TEXTILE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Textile Precision (Asia)</h3>
          <p class="card-market">Market: Uzbekistan / Central Asia / Tashkent</p>
          <p class="card-desc">Automated laser tailoring for large-format textile processing and efficiency gains.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H5592889fd05a4926af9c895580fc0a58l.png" alt="Custom Furniture (Europe)" loading="lazy">
          <span class="industry-tag">FURNITURE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Custom Furniture (Europe)</h3>
          <p class="card-market">Market: Georgia / Tbilisi (Mr. Gocha)</p>
          <p class="card-desc">ATC Auto-tool change CNC solution for high-end furniture customization.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H909e78c2eeb54708a31b02b6b4ca8e9aQ.png" alt="Acrylic Design (Europe)" loading="lazy">
          <span class="industry-tag">ACRYLIC</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Acrylic Design (Europe)</h3>
          <p class="card-market">Market: Italy / Venice / Industrial Design</p>
          <p class="card-desc">Equipped with 100W-200W dedicated UV system for complex high-speed acrylic cutting.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* V18 Forced Row Layout - 280px Images */
  .success-gallery-section.v-english-v18-row {
    background: #ffffff !important;
    padding: 100px 0 !important;
    font-family: 'Archivo Narrow', sans-serif !important;
    display: block !important;
    overflow-x: hidden !important;
  }
  .v-english-v18-row .container-v2 {
    max-width: 1650px !important; /* Increased slightly to accommodate 280px + gaps */
    margin: 0 auto !important;
    width: 98% !important;
  }
  .v-english-v18-row .section-header-v2 {
    text-align: center !important;
    margin-bottom: 60px !important;
  }
  .v-english-v18-row .section-title-v2 {
    font-size: 42px !important;
    font-weight: 800 !important;
    color: #1a1a1a !important;
    letter-spacing: 2px !important;
    text-transform: uppercase !important;
    margin: 0 0 15px 0 !important;
  }
  .v-english-v18-row .section-subtitle-v2 {
    font-size: 20px !important;
    line-height: 1.5 !important;
    color: #444 !important;
    max-width: 1000px !important;
    margin: 0 auto !important;
  }
  .v-english-v18-row .success-grid {
    display: flex !important;
    flex-wrap: nowrap !important; /* FORCE ONE ROW */
    justify-content: center !important;
    gap: 25px !important; /* Tightened gap slightly for row fit */
    width: 100% !important;
  }
  .v-english-v18-row .success-card {
    background: #ffffff !important;
    border: 1px solid #eeeeee !important;
    padding: 25px !important; /* Tightened padding for row fit */
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
    transition: all 0.4s ease !important;
    flex: 1 !important; /* Distribute evenly */
    max-width: 380px !important; /* Prevent excessive stretching */
    min-width: 300px !important; /* Allow some shrinking before wrapping on smaller desktop */
    box-sizing: border-box !important;
    box-shadow: 0 5px 20px rgba(0,0,0,0.02) !important;
  }
  .v-english-v18-row .success-card:hover {
    transform: translateY(-8px) !important;
    box-shadow: 0 15px 40px rgba(0,0,0,0.08) !important;
    border-color: #006841 !important;
  }
  .v-english-v18-row .card-image-wrapper {
    position: relative !important;
    width: 280px !important; /* Maintained 280px */
    height: 280px !important;
    margin-bottom: 25px !important;
    border-radius: 15px !important;
    overflow: hidden !important;
    border: 1px solid #f0f0f0 !important;
  }
  .v-english-v18-row .card-image-wrapper img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
  .v-english-v18-row .industry-tag {
    position: absolute !important;
    top: 12px !important;
    left: 12px !important;
    background: #006841 !important;
    color: #ffffff !important;
    font-size: 10px !important;
    font-weight: 700 !important;
    padding: 6px 14px !important;
    border-radius: 4px !important;
    text-transform: uppercase !important;
    z-index: 10 !important;
  }
  .v-english-v18-row .card-title {
    font-size: 18px !important; /* Slightly smaller for row fit */
    font-weight: 700 !important;
    color: #1a1a1a !important;
    margin: 0 0 12px 0 !important;
    min-height: 44px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    line-height: 1.2 !important;
  }
  .v-english-v18-row .card-market {
    font-size: 12px !important;
    color: #006841 !important;
    font-weight: 700 !important;
    margin-bottom: 12px !important;
    text-transform: uppercase !important;
  }
  .v-english-v18-row .card-desc {
    font-size: 14px !important;
    line-height: 1.5 !important;
    color: #555 !important;
    margin-bottom: 25px !important;
    min-height: 64px !important;
  }
  .v-english-v18-row .card-link {
    font-size: 12px !important;
    font-weight: 700 !important;
    color: #006841 !important;
    text-decoration: none !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
  }

  /* Responsive handling to keep it looking good */
  @media (max-width: 1400px) {
    .v-english-v18-row .success-grid { gap: 15px !important; }
    .v-english-v18-row .success-card { padding: 20px !important; min-width: 280px !important; }
    .v-english-v18-row .card-image-wrapper { width: 240px !important; height: 240px !important; }
  }

  @media (max-width: 1200px) {
    .v-english-v18-row .success-grid { flex-wrap: wrap !important; } /* Allow wrap only on tablet/mobile */
    .v-english-v18-row .success-card { width: calc(50% - 10px) !important; flex: none !important; }
  }

  @media (max-width: 700px) {
    .v-english-v18-row .success-card { width: 100% !important; }
    .v-english-v18-row .card-image-wrapper { width: 100% !important; height: auto !important; aspect-ratio: 1/1 !important; }
  }
</style>

{% schema %}
{
  "name": "SG V18 One Row",
  "settings": [],
  "presets": [{ "name": "SG V18 One Row" }]
}
{% endschema %}
