{% comment %}
  DD Home Deployments V2 - Verified Production Deployments
  Section 04 - Deep proof layer after worldwide footprint
{% endcomment %}

<section id="v2-deployments" class="dd-home-deployments">
  <div class="dd-container">
    <div class="dd-section-header">
      <span class="dd-sub">EVIDENCE // CASE_STUDIES</span>
      <h2 class="dd-title">Verified Production Deployments</h2>
      <p class="dd-lead">Selected customer deployments showing system configuration, delivery evidence, and production outcomes across signage, display, advertising, and CNC routing applications.</p>
    </div>

    {% assign uganda_image = 'https://cdn.shopify.com/s/files/1/0824/6319/5356/files/dd-section04-uganda-signage-output.webp?v=1782870242' %}
    {% assign ethiopia_image = 'https://cdn.shopify.com/s/files/1/0824/6319/5356/files/dd-section04-ethiopia-machine-testing.webp?v=1782870267' %}
    {% assign israel_image = 'https://cdn.shopify.com/s/files/1/0824/6319/5356/t/1/assets/israel-factory-visit-hero.jpg?v=1780650886' %}
    {% assign georgia_image = 'https://cdn.shopify.com/s/files/1/0824/6319/5356/files/dd-section04-georgia-workshop-installed.jpg?v=1782883817' %}

    {% assign case_numbers = '01||02||03||04' | split: '||' %}
    {% assign case_tags = 'UGANDA||ETHIOPIA||ISRAEL||GEORGIA' | split: '||' %}
    {% assign case_titles = 'Uganda Sign Factory Deployment||Ethiopia Advertising Production Deployment||Israel Display & Event Production Deployment||Georgia CNC Routing Production Reference' | split: '||' %}
    {% assign case_scenarios = 'Sign fabrication workshop producing acrylic letters, lightboxes, and advertising components.||Advertising and signage business expanding production capacity with a multi-system setup.||Event decoration producer requiring CNC-routed commercial display structures.||CNC routing and panel fabrication operation with long-term production use.' | split: '||' %}
    {% assign case_systems = 'CO2 Laser System||CO2 Laser + CNC Router||Heavy-Duty CNC Router||ATC CNC Router' | split: '||' %}
    {% assign case_evidence = 'Workshop output||Factory training + export logistics||Machine inspection||Long-term production reference' | split: '||' %}
    {% assign case_outcomes = 'Production-ready sign fabrication capability for repeated customer orders.||Completed deployment for advertising production and fabrication workflows.||CNC routing capability for commercial event and display production.||Long-term reference for stable panel fabrication and routing work.' | split: '||' %}
    {% assign case_links = '/pages/case-uganda-sign-factory||/pages/case-study-ethiopia||/pages/case-study-israel||/pages/case-study-georgia' | split: '||' %}
    {% assign case_images = uganda_image | append: '||' | append: ethiopia_image | append: '||' | append: israel_image | append: '||' | append: georgia_image | split: '||' %}

    <div class="dd-case-grid">
      {% for i in (0..3) %}
        <article class="dd-case-card">
          <div class="dd-card-media">
            <img class="dd-case-image dd-case-image-{{ forloop.index }}" src="{{ case_images[i] }}" alt="{{ case_titles[i] }}" loading="eager">
            <div class="dd-card-tag">
              <span>{{ case_numbers[i] }}</span>
              {{ case_tags[i] }}
            </div>
          </div>

          <div class="dd-card-info">
            <h3 class="dd-card-name">{{ case_titles[i] }}</h3>

            <div class="dd-card-proof">
              <div class="dd-proof-row">
                <span>Scenario</span>
                <p>{{ case_scenarios[i] }}</p>
              </div>
              <div class="dd-proof-row">
                <span>System</span>
                <p>{{ case_systems[i] }}</p>
              </div>
              <div class="dd-evidence-token" aria-label="Evidence tag">
                <span></span>
                {{ case_evidence[i] }}
              </div>
              <div class="dd-proof-row">
                <span>Outcome</span>
                <p>{{ case_outcomes[i] }}</p>
              </div>
            </div>

            <a href="{{ case_links[i] }}" class="dd-case-link">View Case Study</a>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .dd-home-deployments {
    padding: 112px 0;
    background: #F9FAFB;
  }

  .dd-home-deployments .dd-section-header {
    max-width: 820px;
    margin-bottom: 54px;
  }

  .dd-home-deployments .dd-title {
    margin: 16px 0 16px;
    color: #111;
    font-size: 48px;
    font-weight: 850;
    letter-spacing: -1.5px;
    line-height: 1;
    text-transform: uppercase;
  }

  .dd-home-deployments .dd-lead {
    max-width: 760px;
    margin: 0;
    color: #666;
    font-size: 16px;
    line-height: 1.6;
  }

  .dd-case-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .dd-case-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    background: #FFF;
    border: 1px solid #EEE;
  }

  .dd-card-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #111;
  }

  .dd-card-media .dd-case-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .dd-card-media .dd-case-image-1 {
    object-position: center 38%;
  }

  .dd-card-media .dd-case-image-2 {
    object-position: center 48%;
  }

  .dd-card-media .dd-case-image-3 {
    object-position: center 36%;
  }

  .dd-card-media .dd-case-image-4 {
    object-position: center 50%;
  }

  .dd-card-tag {
    position: absolute;
    top: 18px;
    left: 18px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #00A3AD;
    color: #FFF;
    padding: 7px 13px;
    font-size: 10px;
    font-weight: 850;
    letter-spacing: 1.6px;
    text-transform: uppercase;
  }

  .dd-card-tag span {
    color: rgba(255,255,255,0.72);
  }

  .dd-card-info {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 30px;
  }

  .dd-card-name {
    margin: 0 0 24px;
    color: #111;
    font-size: 22px;
    font-weight: 850;
    letter-spacing: -0.4px;
    line-height: 1.08;
    text-transform: uppercase;
  }

  .dd-card-proof {
    display: flex;
    flex-direction: column;
    gap: 13px;
  }

  .dd-proof-row {
    border-top: 1px solid #EEE;
    padding-top: 13px;
  }

  .dd-proof-row span {
    display: block;
    margin-bottom: 6px;
    color: #00A3AD;
    font-family: 'Archivo Narrow', sans-serif;
    font-size: 10px;
    font-weight: 850;
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }

  .dd-proof-row p {
    margin: 0;
    color: #555;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.45;
  }

  .dd-proof-row:nth-child(1) p,
  .dd-proof-row:nth-child(2) p {
    color: #6D6D6D;
    font-weight: 550;
  }

  .dd-proof-row:nth-child(4) p {
    color: #4E4E4E;
    font-weight: 650;
  }

  .dd-evidence-token {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 9px;
    margin-top: 2px;
    border: 1px solid rgba(0,163,173,0.35);
    background: rgba(0,163,173,0.09);
    color: #007E86;
    padding: 9px 12px;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 1.2px;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .dd-evidence-token span {
    width: 7px;
    height: 7px;
    flex: 0 0 7px;
    border-radius: 50%;
    background: #00A3AD;
    box-shadow: 0 0 0 4px rgba(0,163,173,0.13);
  }

  .dd-case-link {
    display: inline-flex;
    width: fit-content;
    margin-top: 26px;
    border-bottom: 2px solid #111;
    color: #111;
    font-size: 10px;
    font-weight: 850;
    letter-spacing: 1.4px;
    text-decoration: none;
    text-transform: uppercase;
  }

  .dd-case-link:hover {
    border-color: #00A3AD;
    color: #00A3AD;
  }

  @media (max-width: 1024px) {
    .dd-case-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .dd-home-deployments {
      padding: 116px 0 84px;
    }

    .dd-home-deployments .dd-section-header {
      margin-bottom: 38px;
    }

    .dd-home-deployments .dd-title {
      font-size: 34px;
      line-height: 1.04;
    }

    .dd-home-deployments .dd-lead {
      font-size: 15px;
    }

    .dd-card-info {
      padding: 18px 20px 20px;
    }

    .dd-card-media {
      aspect-ratio: 4 / 3;
    }

    .dd-card-tag {
      top: 12px;
      left: 12px;
      gap: 8px;
      padding: 6px 10px;
      font-size: 9px;
    }

    .dd-card-name {
      font-size: 20px;
      margin-bottom: 16px;
    }

    .dd-card-proof {
      gap: 7px;
    }

    .dd-proof-row {
      padding-top: 8px;
    }

    .dd-proof-row span {
      margin-bottom: 4px;
    }

    .dd-proof-row p {
      color: #666;
      font-size: 12.5px;
      line-height: 1.36;
    }

    .dd-evidence-token {
      margin: 4px 0 3px;
      padding: 8px 10px;
      font-size: 10px;
      letter-spacing: 1px;
    }

    .dd-evidence-token span {
      width: 6px;
      height: 6px;
      flex-basis: 6px;
    }

    .dd-case-link {
      margin-top: 18px;
    }
  }
</style>

{% schema %}
{
  "name": "DD Home Deployments",
  "settings": [],
  "presets": [{"name": "DD Home Deployments"}]
}
{% endschema %}
