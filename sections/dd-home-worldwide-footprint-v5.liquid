<section class="dd-home-footprint-v5" id="worldwide-customer-footprint">
  <div class="dd-container">
    <header class="dd-footprint-header">
      <span class="dd-footprint-eyebrow">GLOBAL PRODUCTION REFERENCES</span>
      <h2 class="dd-footprint-title">Verified Global Production References</h2>
      <p class="dd-footprint-lead">
        Explore documented production deployments, factory visits, and customer production references across multiple international markets.
      </p>
    </header>

    <div class="dd-footprint-metrics" aria-label="Global production reference metrics">
      <div class="dd-footprint-metric">
        <strong>4</strong>
        <span>Verified Markets</span>
      </div>
      <div class="dd-footprint-metric">
        <strong>4</strong>
        <span>Production References</span>
      </div>
      <div class="dd-footprint-metric">
        <strong>3+</strong>
        <span>Years Running</span>
      </div>
      <div class="dd-footprint-metric">
        <strong>Remote</strong>
        <span>Training &amp; Support</span>
      </div>
    </div>

    {% assign country_numbers = '01||02||03||04' | split: '||' %}
    {% assign country_names = 'Uganda||Israel||Georgia||Ethiopia' | split: '||' %}
    {% assign country_statuses = 'Active Production||Production Launch Completed||3+ Years Running Production||Production Commissioned' | split: '||' %}
    {% assign country_systems = 'CO2 Laser System||Heavy-Duty CNC Router||ATC CNC Router||CO2 Laser + CNC Router' | split: '||' %}
    {% assign country_applications = 'Sign Fabrication||Display & Event Production||CNC Routing & Panel Fabrication||Advertising & Signage Production' | split: '||' %}
    {% assign country_links = '/pages/case-uganda-sign-factory||/pages/case-study-israel||/pages/case-study-georgia||/pages/case-study-ethiopia' | split: '||' %}

    <div class="dd-reference-grid" aria-label="Verified production references by market">
      {% for country in country_names %}
        <article class="dd-reference-record">
          <span class="dd-reference-number">{{ country_numbers[forloop.index0] }}</span>
          <h3 class="dd-reference-country">{{ country }}</h3>

          <p class="dd-reference-status">
            <span aria-hidden="true"></span>
            {{ country_statuses[forloop.index0] }}
          </p>

          <dl class="dd-reference-details">
            <div>
              <dt>Installed System</dt>
              <dd>{{ country_systems[forloop.index0] }}</dd>
            </div>
            <div>
              <dt>Application</dt>
              <dd>{{ country_applications[forloop.index0] }}</dd>
            </div>
          </dl>

          <a
            class="dd-reference-link"
            href="{{ country_links[forloop.index0] }}"
            aria-label="View {{ country }} case study"
          >
            View Case Study <span aria-hidden="true">→</span>
          </a>
        </article>
      {% endfor %}
    </div>

    <div class="dd-footprint-transition" aria-label="Next section">
      <span>NEXT</span>
      <strong>Verified Deployment Evidence</strong>
    </div>
  </div>
</section>

<style>
  .dd-home-footprint-v5 {
    --dd-footprint-cyan: #00A3AD;
    --dd-footprint-white: #FFFFFF;
    --dd-footprint-muted: rgba(255, 255, 255, 0.66);
    --dd-footprint-line: rgba(255, 255, 255, 0.14);
    box-sizing: border-box;
    overflow: hidden;
    padding: 72px 0 80px;
    background: #0F1115;
    color: var(--dd-footprint-white);
  }

  .dd-home-footprint-v5 *,
  .dd-home-footprint-v5 *::before,
  .dd-home-footprint-v5 *::after {
    box-sizing: border-box;
  }

  .dd-home-footprint-v5 .dd-container {
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    padding-right: 32px;
    padding-left: 32px;
  }

  .dd-footprint-header {
    max-width: 820px;
    margin-bottom: 48px;
  }

  .dd-footprint-eyebrow {
    display: block;
    margin-bottom: 16px;
    color: var(--dd-footprint-cyan);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .dd-footprint-title {
    max-width: 760px;
    margin: 0 0 18px;
    color: var(--dd-footprint-white);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 48px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    text-transform: uppercase;
  }

  .dd-footprint-lead {
    max-width: 720px;
    margin: 0;
    color: var(--dd-footprint-muted);
    font-size: 16px;
    line-height: 1.6;
  }

  .dd-footprint-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-bottom: 64px;
    border-top: 1px solid var(--dd-footprint-line);
    border-bottom: 1px solid var(--dd-footprint-line);
  }

  .dd-footprint-metric {
    min-width: 0;
    padding: 24px;
  }

  .dd-footprint-metric + .dd-footprint-metric {
    border-left: 1px solid var(--dd-footprint-line);
  }

  .dd-footprint-metric strong {
    display: block;
    margin-bottom: 7px;
    color: var(--dd-footprint-white);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 30px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    text-transform: uppercase;
  }

  .dd-footprint-metric span {
    display: block;
    color: var(--dd-footprint-muted);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .dd-reference-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--dd-footprint-line);
    border-bottom: 1px solid var(--dd-footprint-line);
  }

  .dd-reference-record {
    display: flex;
    min-width: 0;
    min-height: 400px;
    flex-direction: column;
    padding: 30px 26px 28px;
  }

  .dd-reference-record + .dd-reference-record {
    border-left: 1px solid var(--dd-footprint-line);
  }

  .dd-reference-number {
    margin-bottom: 38px;
    color: rgba(255, 255, 255, 0.4);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
  }

  .dd-reference-country {
    margin: 0 0 14px;
    color: var(--dd-footprint-white);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 30px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
    text-transform: uppercase;
  }

  .dd-reference-status {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    min-height: 42px;
    margin: 0 0 30px;
    color: rgba(255, 255, 255, 0.88);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.4;
  }

  .dd-reference-status > span {
    width: 7px;
    height: 7px;
    flex: 0 0 7px;
    margin-top: 5px;
    border-radius: 50%;
    background: var(--dd-footprint-cyan);
  }

  .dd-reference-details {
    display: grid;
    gap: 20px;
    margin: 0 0 32px;
  }

  .dd-reference-details div {
    padding-top: 15px;
    border-top: 1px solid rgba(255, 255, 255, 0.09);
  }

  .dd-reference-details dt {
    margin-bottom: 7px;
    color: var(--dd-footprint-cyan);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .dd-reference-details dd {
    margin: 0;
    color: var(--dd-footprint-muted);
    font-size: 14px;
    line-height: 1.45;
  }

  .dd-reference-link {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 10px;
    margin-top: auto;
    color: var(--dd-footprint-cyan);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.2;
    text-decoration: none;
    text-transform: uppercase;
  }

  .dd-reference-link span {
    transition: transform 0.2s ease;
  }

  .dd-reference-link:hover span,
  .dd-reference-link:focus-visible span {
    transform: translateX(4px);
  }

  .dd-reference-link:focus-visible {
    outline: 1px solid var(--dd-footprint-cyan);
    outline-offset: 5px;
  }

  .dd-footprint-transition {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 24px;
    margin-top: 58px;
    padding-top: 26px;
    border-top: 1px solid var(--dd-footprint-line);
  }

  .dd-footprint-transition span {
    color: var(--dd-footprint-cyan);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1;
  }

  .dd-footprint-transition strong {
    color: rgba(255, 255, 255, 0.82);
    font-family: 'Archivo Narrow', 'Arial Narrow', Arial, sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.2;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .dd-footprint-metrics,
    .dd-reference-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .dd-footprint-metric:nth-child(3),
    .dd-footprint-metric:nth-child(4),
    .dd-reference-record:nth-child(3),
    .dd-reference-record:nth-child(4) {
      border-top: 1px solid var(--dd-footprint-line);
    }

    .dd-footprint-metric:nth-child(3),
    .dd-reference-record:nth-child(3) {
      border-left: 0;
    }

    .dd-reference-record {
      min-height: 350px;
    }
  }

  @media (max-width: 900px) {
    .dd-home-footprint-v5 {
      padding: 72px 0 70px;
    }

    .dd-footprint-title {
      font-size: 40px;
    }
  }

  @media (max-width: 640px) {
    .dd-home-footprint-v5 {
      padding: 64px 0 58px;
    }

    .dd-home-footprint-v5 .dd-container {
      padding-right: 20px;
      padding-left: 20px;
    }

    .dd-footprint-header {
      width: 100%;
      margin-bottom: 36px;
    }

    .dd-footprint-title {
      width: 100%;
      font-size: 34px;
      line-height: 1.02;
    }

    .dd-footprint-lead {
      width: 100%;
      font-size: 15px;
    }

    .dd-footprint-metrics,
    .dd-reference-grid {
      grid-template-columns: 1fr;
    }

    .dd-footprint-metrics {
      margin-bottom: 48px;
    }

    .dd-footprint-metric {
      padding: 18px 0;
    }

    .dd-footprint-metric + .dd-footprint-metric,
    .dd-footprint-metric:nth-child(3),
    .dd-footprint-metric:nth-child(4) {
      border-top: 1px solid var(--dd-footprint-line);
      border-left: 0;
    }

    .dd-footprint-metric strong {
      font-size: 26px;
    }

    .dd-reference-record {
      min-height: 0;
      padding: 26px 0 28px;
    }

    .dd-reference-record + .dd-reference-record,
    .dd-reference-record:nth-child(3),
    .dd-reference-record:nth-child(4) {
      border-top: 1px solid var(--dd-footprint-line);
      border-left: 0;
    }

    .dd-reference-number {
      margin-bottom: 24px;
    }

    .dd-reference-country {
      font-size: 27px;
    }

    .dd-reference-status {
      min-height: 0;
      margin-bottom: 24px;
    }

    .dd-footprint-transition {
      grid-template-columns: 1fr;
      gap: 8px;
      margin-top: 42px;
      padding-top: 22px;
    }
  }
</style>

{% schema %}
{
  "name": "DD Worldwide Footprint",
  "settings": [],
  "presets": [{"name": "DD Worldwide Footprint"}]
}
{% endschema %}
