        <!-- Navigation with Product Dropdown -->
        <nav class="dd-nav-center">
          <a href="/">HOME</a>
          <a href="/#v2-workflows">SOLUTIONS</a>
          
          <div class="dd-nav-dropdown-wrap">
            <a href="/collections/all" class="dd-nav-trigger">PRODUCTS</a>
            <div class="dd-dropdown-panel">
              <div class="dd-dropdown-grid">
                <a href="/collections/co2-laser" class="dd-drop-item">
                  <span class="dd-drop-title">CO2 Laser Cutting Machines</span>
                  <span class="dd-drop-desc">Precision signage & acrylic production.</span>
                </a>
                <a href="/collections/fiber-laser" class="dd-drop-item">
                  <span class="dd-drop-title">Fiber Laser Cutting Machines</span>
                  <span class="dd-drop-desc">High-speed industrial metal fabrication.</span>
                </a>
                <a href="/collections/cnc-router" class="dd-drop-item">
                  <span class="dd-drop-title">CNC Router Machines</span>
                  <span class="dd-drop-desc">Heavy-duty routing & furniture setup.</span>
                </a>
                <a href="/collections/laser-marking" class="dd-drop-item">
                  <span class="dd-drop-title">Laser Marking Machines</span>
                  <span class="dd-drop-desc">Permanent industrial identification.</span>
                </a>
                <a href="/collections/laser-welding" class="dd-drop-item">
                  <span class="dd-drop-title">Laser Welding Machines</span>
                  <span class="dd-drop-desc">Precision metal joining systems.</span>
                </a>
                <a href="/collections/uv-printer" class="dd-drop-item">
                  <span class="dd-drop-title">UV Flatbed Printers</span>
                  <span class="dd-drop-desc">Direct-to-substrate graphic printing.</span>
                </a>
                <a href="/collections/parts-components" class="dd-drop-item">
                  <span class="dd-drop-title">Parts & Components</span>
                  <span class="dd-drop-desc">Industrial toolkits and deployment support.</span>
                </a>
              </div>
            </div>
          </div>

          <a href="/pages/case-studies">CASE STUDIES</a>
          <a href="/pages/support">SUPPORT</a>
          <a href="/pages/about-us">ABOUT US</a>
          <a href="/pages/contact">CONTACT</a>
        </nav>

        <!-- Mobile Toggle -->
        <button class="dd-toggle-v3" aria-label="Menu">
          <span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  (() => {
    const header = document.querySelector('.dd-header-v4-9');
    if (!header) return;

    const syncHeaderState = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 30);
    };

    syncHeaderState();
    window.addEventListener('scroll', syncHeaderState, { passive: true });
  })();
</script>

<style>
  :root {
    --dd-dark: #0F1115;
    --dd-cyan: #00A3AD;
    --dd-border: rgba(15, 17, 21, 0.08);
  }

  .dd-header-v4-9 {
    width: 100%;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 3000;
    background: linear-gradient(180deg, rgba(0,0,0,0.52) 0%, rgba(0,0,0,0.2) 62%, rgba(0,0,0,0) 100%);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    border: 0;
    transition: background 0.28s ease, backdrop-filter 0.28s ease;
  }

  .dd-header-v4-9.is-scrolled {
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* LAYER 1: TOP UTILITY BAR */
  .dd-top-utility { display: none; }
  .dd-top-utility .dd-container { max-width: 1240px; width: 100%; margin: 0 auto; padding: 0 32px; }
  .dd-top-utility-inner { display: flex; justify-content: space-between; align-items: center; width: 100%; }
  
  .dd-top-social { display: flex; gap: 20px; align-items: center; }
  .dd-top-social svg { width: 18px; height: 18px; fill: rgba(255,255,255,0.4); transition: fill 0.3s; }
  .dd-top-social a:hover svg { fill: var(--dd-cyan); }

  .dd-top-right-group { display: flex; gap: 24px; align-items: center; }
  .dd-top-lang { display: flex; gap: 10px; align-items: center; font-family: 'Archivo Narrow', sans-serif; }
  .dd-top-lang a { font-size: 11px; font-weight: 800; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.3s; letter-spacing: 0.5px; }
  .dd-top-lang a:hover, .dd-top-lang a.active { color: var(--dd-cyan); }
  .dd-top-lang .sep { font-size: 10px; color: rgba(255,255,255,0.1); font-weight: 300; }
  .dd-top-search svg { width: 18px; height: 18px; color: rgba(255,255,255,0.4); transition: color 0.3s; display: block; }
  .dd-top-search a:hover svg { color: var(--dd-cyan); }

  /* LAYER 2: MAIN HEADER */
  .dd-main-header { background: transparent; border: 0; }
  .dd-main-header .dd-container { max-width: 1240px; width: 100%; margin: 0 auto; padding: 0 32px; }
  .dd-main-inner {
    height: 96px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    transition: height 0.28s ease;
  }
  .dd-header-v4-9.is-scrolled .dd-main-inner { height: 88px; }

  /* Brand Identity */
  .dd-brand-main { display: flex; align-items: center; gap: 16px; text-decoration: none; transition: opacity 0.3s; }
  .dd-brand-main:hover { opacity: 0.82; }
  .dd-brand-icon { width: 64px; height: 64px; border-radius: 0; overflow: hidden; background: transparent; flex-shrink: 0; }
  .dd-brand-icon img { width: 100%; height: 100%; object-fit: cover; }
  .dd-brand-text { display: flex; flex-direction: column; gap: 2px; }
  .dd-brand-name { font-size: 20px; font-weight: 700; color: #FFFFFF; letter-spacing: 0.5px; line-height: 1.1; font-family: 'Archivo Narrow', sans-serif; }
  .dd-brand-slogan { font-size: 11px; font-weight: 700; color: var(--dd-cyan); text-transform: uppercase; letter-spacing: 1.2px; opacity: 0.8; }

  /* Navigation Center */
  .dd-nav-center { 
    display: flex; 
    gap: 32px; 
    margin-left: auto; 
    margin-right: 40px;
    align-items: center;
  }
  .dd-nav-center > a, .dd-nav-trigger {
    font-size: 11px; font-weight: 700; color: #FFFFFF; text-decoration: none; letter-spacing: 1.2px;
    opacity: 0.92; transition: opacity 0.3s, color 0.3s; position: relative; padding: 10px 0; white-space: nowrap; cursor: pointer;
  }
  .dd-nav-center > a:hover, .dd-nav-center > a.active, .dd-nav-trigger:hover { opacity: 1; color: var(--dd-cyan); }
  
  /* Dropdown Logic */
  .dd-nav-dropdown-wrap { position: relative; display: flex; align-items: center; }
  .dd-dropdown-panel {
    position: absolute; top: 100%; left: 0; width: 600px;
    background: rgba(0,0,0,0.88); border: 0;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 30px; box-sizing: border-box;
    opacity: 0; visibility: hidden; transform: translateY(10px);
    transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    z-index: 100;
  }
  .dd-nav-dropdown-wrap:hover .dd-dropdown-panel { opacity: 1; visibility: visible; transform: translateY(0); }
  
  .dd-dropdown-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .dd-drop-item { text-decoration: none; border-left: 1.5px solid #EEE; padding-left: 15px; display: flex; flex-direction: column; gap: 4px; transition: 0.3s; }
  .dd-drop-item:hover { border-left-color: var(--dd-cyan); }
  .dd-drop-title { font-size: 13px; font-weight: 800; color: #FFFFFF; text-transform: uppercase; display: block; }
  .dd-drop-desc { font-size: 10px; color: rgba(255,255,255,0.62); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* Underline Feedback */
  .dd-nav-center a:after, .dd-nav-trigger:after {
    content: ''; position: absolute; bottom: -5px; left: 0; width: 0; height: 2px;
    background: var(--dd-cyan); transition: width 0.3s;
  }
  .dd-nav-center a:hover:after, .dd-nav-center a.active:after, .dd-nav-trigger:hover:after { width: 100%; }

  /* Mobile Toggle */
  .dd-toggle-v3 { display: none; background: none; border: none; flex-direction: column; gap: 6px; cursor: pointer; }
  .dd-toggle-v3 span { width: 20px; height: 2px; background: #FFFFFF; }

  @media (max-width: 1366px) {
    .dd-nav-center { position: static; transform: none; margin: 0 40px; }
  }

  @media (max-width: 1024px) {
    .dd-nav-center, .dd-top-utility { display: none; }
    .dd-main-inner { height: 80px; }
    .dd-brand-icon { width: 60px; height: 60px; }
    .dd-toggle-v3 { display: flex; }
  }
</style>

{% schema %}
{
  "name": "Header V2",
  "settings": []
}
{% endschema %}
