  <!-- LAYER 2: MAIN HEADER -->
  <div class="dd-main-header">
    <div class="dd-container">
      <div class="dd-main-inner">
        <!-- Logo Area -->
        <div class="dd-brand-identity">
          <a href="/" class="dd-brand-main">
            <div class="dd-brand-icon">
              <img src="https://sc01.alicdn.com/kf/H5e7d57adb8584ee697446dbc5303863cL.jpg" alt="Dragon Icon">
