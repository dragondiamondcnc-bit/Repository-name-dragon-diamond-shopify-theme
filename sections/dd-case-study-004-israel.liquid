<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;500;600;700&display=swap');

  .dd-israel-case {
    background: #0F1115;
    color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    overflow-x: hidden;
  }

  .dd-container {
    max-width: 1240px;
    margin: 0 auto;
    padding-left: 32px;
    padding-right: 32px;
  }

  .dd-kicker {
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 18px;
    display: block;
  }

  .dd-section {
    padding: 110px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .dd-section-light {
    background: #fff;
    color: #111;
  }

  .dd-section-dark {
    background: #0F1115;
  }

  .dd-section-mid {
    background: #11141A;
  }

  .dd-title {
    font-size: 54px;
    line-height: 1.05;
    font-weight: 850;
    letter-spacing: -2px;
    margin: 0 0 28px;
  }

  .dd-h2 {
    font-size: 42px;
    line-height: 1.12;
    font-weight: 850;
    letter-spacing: -1px;
    margin: 0 0 24px;
  }

  .dd-copy {
    max-width: 780px;
    font-size: 18px;
    line-height: 1.75;
    color: rgba(255,255,255,0.68);
  }

  .dd-section-light .dd-copy {
    color: #555;
  }

  .dd-hero {
    position: relative;
    min-height: 86vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .dd-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .dd-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: .55;
  }

  .dd-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(15,17,21,.96) 0%, rgba(15,17,21,.72) 48%, rgba(15,17,21,.18) 100%);
    z-index: 1;
  }

  .dd-hero-inner {
    position: relative;
    z-index: 2;
    max-width: 850px;
  }

  .dd-hero-sub {
    font-size: 21px;
    line-height: 1.6;
    color: rgba(255,255,255,.76);
    max-width: 760px;
    margin-bottom: 42px;
  }

  .dd-hero-cta {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .dd-btn-primary,
  .dd-btn-secondary {
    display: inline-block;
    padding: 18px 32px;
    font-size: 13px;
    font-weight: 850;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
  }

  .dd-btn-primary {
    background: #00A3AD;
    color: #fff;
  }

  .dd-btn-secondary {
    border: 1px solid rgba(255,255,255,.28);
    color: #fff;
  }

  .dd-overview {
    background: #11141A;
  }

  .dd-overview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .dd-overview-item {
    padding: 44px 26px;
    border-right: 1px solid rgba(255,255,255,.06);
    text-align: center;
  }

  .dd-overview-item:last-child {
    border-right: none;
  }

  .dd-overview-item span {
    display: block;
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 11px;
    letter-spacing: 2px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .dd-overview-item strong {
    font-size: 18px;
    font-weight: 850;
  }

  .dd-grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 42px;
    margin-top: 56px;
  }

  .dd-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 34px;
    margin-top: 56px;
  }

  .dd-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
    margin-top: 56px;
  }

  .dd-evidence-card {
    background: #171A20;
    border: 1px solid rgba(255,255,255,.07);
  }

  .dd-section-light .dd-evidence-card {
    background: #F5F6F7;
    border-color: rgba(0,0,0,.08);
  }

  .dd-img-frame {
    position: relative;
    height: 360px;
    overflow: hidden;
    background: #181B20;
  }

  .dd-img-frame.tall {
    height: 520px;
  }

  .dd-img-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dd-img-frame.contain img {
    object-fit: contain;
    background: #11141A;
  }

  .dd-label {
    position: absolute;
    left: 14px;
    top: 14px;
    z-index: 2;
    padding: 7px 11px;
    background: rgba(15,17,21,.84);
    border: 1px solid rgba(0,163,173,.48);
    color: #fff;
    font-family: "Archivo Narrow", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
  }

  .dd-card-body {
    padding: 24px;
  }

  .dd-card-title {
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .dd-card-text {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(255,255,255,.62);
  }

  .dd-section-light .dd-card-text {
    color: #555;
  }

  .dd-timeline {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 14px;
  }

  .dd-step {
    background: #171A20;
    border: 1px solid rgba(255,255,255,.07);
    padding: 24px 18px;
    min-height: 170px;
  }

  .dd-step-num {
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .dd-step-title {
    font-size: 17px;
    font-weight: 850;
    margin-bottom: 10px;
  }

  .dd-step-copy {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255,255,255,.58);
  }

  .dd-equipment-panel {
    margin-top: 56px;
    display: grid;
    grid-template-columns: 1.15fr .85fr;
    gap: 40px;
    background: #171A20;
    border: 1px solid rgba(255,255,255,.07);
    padding: 46px;
  }

  .dd-equipment-name {
    font-size: 34px;
    line-height: 1.12;
    font-weight: 850;
    margin-bottom: 20px;
  }

  .dd-spec-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
    margin-top: 34px;
  }

  .dd-spec {
    border-top: 1px solid rgba(255,255,255,.1);
    padding-top: 16px;
  }

  .dd-spec span {
    display: block;
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .dd-spec strong {
    font-size: 16px;
  }

  .dd-quote-box {
    margin-top: 56px;
    background: #171A20;
    border-left: 4px solid #00A3AD;
    padding: 44px;
  }

  .dd-quote {
    font-size: 30px;
    line-height: 1.35;
    font-weight: 750;
    letter-spacing: -0.5px;
    margin-bottom: 20px;
  }

  .dd-quote-source {
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
  }

  .dd-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 48px;
  }

  .dd-related-card {
    display: block;
    text-decoration: none;
    color: #fff;
    background: #171A20;
    border: 1px solid rgba(255,255,255,.07);
    padding: 28px;
  }

  .dd-related-card span {
    display: block;
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .dd-related-card strong {
    font-size: 22px;
    line-height: 1.25;
  }

  @media (max-width: 1024px) {
    .dd-container { padding: 0 22px; }
    .dd-title { font-size: 42px; }
    .dd-h2 { font-size: 32px; }
    .dd-hero { min-height: 78vh; }
    .dd-overview-grid,
    .dd-grid-2,
    .dd-grid-3,
    .dd-grid-4,
    .dd-timeline,
    .dd-equipment-panel,
    .dd-spec-grid,
    .dd-related-grid {
      grid-template-columns: 1fr;
    }
    .dd-img-frame,
    .dd-img-frame.tall {
      height: auto;
      max-height: none;
    }
    .dd-img-frame img {
      height: auto;
      display: block;
    }
    .dd-section { padding: 76px 0; }
  }
</style>

<div class="dd-israel-case">

  <!-- HERO -->
  <header class="dd-hero">
    <div class="dd-hero-bg">
      <img
        src="{{ 'israel-factory-visit-hero.jpg' | asset_url }}"
        alt="Israel customer visiting Dragon Diamond factory for CNC router verification"
        loading="eager"
      >
    </div>

    <div class="dd-container">
      <div class="dd-hero-inner">
        <span class="dd-kicker">CASE STUDY: ISRAEL · EVENT DECORATION</span>
        <h1 class="dd-title">From Factory Visit To Production Launch: Israel CNC Router Case Study</h1>
        <p class="dd-hero-sub">
          How an Israeli event decoration company evaluated, tested, received, and launched a Dragon Diamond LZ-1325 CNC router for commercial decorative panel production.
        </p>

        <div class="dd-hero-cta">
          <a href="#consultation" class="dd-btn-primary">Request Similar CNC Solution</a>
          <a href="/products/lz-1325-cnc-router" class="dd-btn-secondary">View CNC Router Specs</a>
        </div>
      </div>
    </div>
  </header>

  <!-- OVERVIEW -->
  <section class="dd-overview">
    <div class="dd-container">
      <div class="dd-overview-grid">
        <div class="dd-overview-item">
          <span>Location</span>
          <strong>Israel</strong>
        </div>
        <div class="dd-overview-item">
          <span>Industry</span>
          <strong>Event Decoration</strong>
        </div>
        <div class="dd-overview-item">
          <span>Machine</span>
          <strong>LZ-1325 CNC Router</strong>
        </div>
        <div class="dd-overview-item">
          <span>Evidence Chain</span>
          <strong>Visit · Test · Ship · Use</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- CUSTOMER CHALLENGE -->
  <section class="dd-section dd-section-light">
    <div class="dd-container">
      <span class="dd-kicker">01. CUSTOMER APPLICATION</span>
      <h2 class="dd-h2">Event decoration production needs more than a standard CNC router.</h2>
      <p class="dd-copy">
        The customer produces customized event decoration assets, including printed foam board displays, themed panels, birthday and Bat Mitzvah backdrops, and decorative structures. Their challenge was not simply buying a machine — they needed a stable production system that could support real commercial event work.
      </p>

      <div class="dd-grid-2">
        <div class="dd-evidence-card">
          <div class="dd-img-frame tall">
            <span class="dd-label">FINAL APPLICATION</span>
            <img
              src="{{ 'israel-application-bat-mitzvah.jpg' | asset_url }}"
              alt="Bat Mitzvah event decoration produced with CNC cut panels in Israel"
              loading="lazy"
            >
          </div>
          <div class="dd-card-body">
            <div class="dd-card-title">Bat Mitzvah Decoration</div>
            <div class="dd-card-text">Finished decorative panels used in a real event environment after machine launch.</div>
          </div>
        </div>

        <div class="dd-evidence-card">
          <div class="dd-img-frame tall">
            <span class="dd-label">EVENT BACKDROP</span>
            <img
              src="{{ 'israel-application-event-backdrop.jpg' | asset_url }}"
              alt="Custom event backdrop panels produced by Israel customer using CNC router"
              loading="lazy"
            >
          </div>
          <div class="dd-card-body">
            <div class="dd-card-title">Commercial Event Output</div>
            <div class="dd-card-text">The machine supports customized decorative structures and printed panel cutting for event production.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DECISION TIMELINE -->
  <section class="dd-section dd-section-mid">
    <div class="dd-container">
      <span class="dd-kicker">02. PROCUREMENT JOURNEY</span>
      <h2 class="dd-h2">A documented decision path from inquiry to production launch.</h2>
      <p class="dd-copy">
        This case is valuable because the complete buying process was documented: technical communication, factory visit, machine testing, configuration confirmation, shipment, remote support, and final production.
      </p>

      <div class="dd-timeline">
        <div class="dd-step">
          <div class="dd-step-num">STEP 01</div>
          <div class="dd-step-title">Customer Inquiry</div>
          <div class="dd-step-copy">The customer contacted Dragon Diamond while evaluating CNC solutions for event decoration production.</div>
        </div>
        <div class="dd-step">
          <div class="dd-step-num">STEP 02</div>
          <div class="dd-step-title">Technical Evaluation</div>
          <div class="dd-step-copy">The team reviewed materials, cutting needs, software workflow, and tooling requirements.</div>
        </div>
        <div class="dd-step">
          <div class="dd-step-num">STEP 03</div>
          <div class="dd-step-title">Factory Visit</div>
          <div class="dd-step-copy">The customer visited Dragon Diamond in Guangzhou to verify capability before purchase.</div>
        </div>
        <div class="dd-step">
          <div class="dd-step-num">STEP 04</div>
          <div class="dd-step-title">Sample Testing</div>
          <div class="dd-step-copy">On-site cutting and machine inspection helped confirm the right configuration.</div>
        </div>
        <div class="dd-step">
          <div class="dd-step-num">STEP 05</div>
          <div class="dd-step-title">Shipment</div>
          <div class="dd-step-copy">The machine was packed in export-grade wooden crating for international delivery.</div>
        </div>
        <div class="dd-step">
          <div class="dd-step-num">STEP 06</div>
          <div class="dd-step-title">Remote Support</div>
          <div class="dd-step-copy">Technical guidance supported software, tooling, and operation after arrival.</div>
        </div>
        <div class="dd-step">
          <div class="dd-step-num">STEP 07</div>
          <div class="dd-step-title">Production Launch</div>
          <div class="dd-step-copy">The customer began producing real event decoration assets in Israel.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FACTORY VERIFICATION -->
  <section class="dd-section dd-section-dark">
    <div class="dd-container">
      <span class="dd-kicker">03. FACTORY VERIFICATION</span>
      <h2 class="dd-h2">The customer flew to Guangzhou to verify the factory, the team, and the machine.</h2>
      <p class="dd-copy">
        Instead of relying only on online communication, the customer inspected Dragon Diamond’s factory, discussed production requirements face to face, and checked machine performance before final confirmation.
      </p>

      <div class="dd-grid-3">
        <div class="dd-evidence-card">
          <div class="dd-img-frame">
            <span class="dd-label">TECHNICAL MEETING</span>
            <img src="{{ 'israel-factory-meeting.jpg' | asset_url }}" alt="Israel customer technical meeting at Dragon Diamond factory" loading="lazy">
          </div>
          <div class="dd-card-body">
            <div class="dd-card-title">Requirement Discussion</div>
            <div class="dd-card-text">Machine configuration, material processing, and application requirements were reviewed in person.</div>
          </div>
        </div>

        <div class="dd-evidence-card">
          <div class="dd-img-frame">
            <span class="dd-label">MACHINE INSPECTION</span>
            <img src="{{ 'israel-customer-inspection.jpg' | asset_url }}" alt="Israel customer inspecting Dragon Diamond CNC router during factory visit" loading="lazy">
          </div>
          <div class="dd-card-body">
            <div class="dd-card-title">ON-SITE MACHINE CHECK</div>
            <div class="dd-card-text">The customer reviewed CNC router structure, components, cutting quality, and workflow before making the final purchasing decision.</div>
          </div>
        </div>

        <div class="dd-evidence-card">
          <div class="dd-img-frame">
            <span class="dd-label">FACTORY VISIT</span>
            <img src="{{ 'israel-factory-group-photo.jpg' | asset_url }}" alt="Israel customer group photo at Dragon Diamond factory entrance" loading="lazy">
          </div>
          <div class="dd-card-body">
            <div class="dd-card-title">FACTORY VISIT CONFIRMED</div>
            <div class="dd-card-text">A real factory visit provides stronger verification than online communication alone and helps build long-term trust.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

