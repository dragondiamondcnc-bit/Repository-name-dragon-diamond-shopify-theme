{% comment %}
  DD Home Hero V5 - Solution Provider Focus (Final Locked Version)
  Positioning: Sign Manufacturing Solution Provider
  Layout: 60/40 Split
  Visual: Single CO2 Acrylic Cutting Production Panel
{% endcomment %}

<!-- HERO V2.2 STABLE LOCKED VERSION -->
<section class="dd-hero-v5" id="hero-v5">
  <!-- 2. CO2 ACRYLIC CUTTING SCENE (SINGLE VISUAL SOURCE) -->
  <div class="dd-hero-visual">
    <img src="{{ 'hero-v22-co2-acrylic-cutting-progress.png' | asset_url }}">
  </div>

  <div class="dd-container">
    <div class="dd-hero-grid">
      
      <!-- 1. SOLUTION IDENTITY (60%) -->
      <div class="dd-hero-content">
        <div class="dd-industry-badge">Built For Sign Production Teams</div>
        <h1 class="dd-hero-h1">Production Solutions For Sign Manufacturers</h1>
        <p class="dd-hero-lead">
          Verified production deployments across multiple international markets, helping sign manufacturers build and expand production capabilities with CO2 laser, CNC router, fiber laser, and UV printing solutions.
        </p>
        
        <div class="dd-systems-preview">
          <span>CO2 Laser</span> <span class="dot">·</span> 
          <span>CNC Router</span> <span class="dot">·</span> 
          <span>Fiber Laser</span> <span class="dot">·</span> 
          <span>UV Flatbed</span>
        </div>

        <div class="dd-hero-actions">
          <a href="#v2_1_conversion" class="dd-btn-v5">Request A Quote</a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Base Reset & Variables */
  .dd-hero-v5 {
    position: relative;
    min-height: 100vh;
    padding: 0;
    background: #050607;
    overflow: hidden;
    border: 0;
    color: #FFFFFF;
  }

  .dd-hero-v5::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.74) 35%, rgba(0,0,0,0.22) 62%, rgba(0,0,0,0.08) 100%),
      linear-gradient(180deg, rgba(0,0,0,0.86) 0%, rgba(0,0,0,0.18) 28%, rgba(0,0,0,0.16) 72%, rgba(0,0,0,0.76) 100%);
    pointer-events: none;
  }

  .dd-hero-v5 .dd-container {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    width: 100%;
    min-height: 100vh;
    margin: 0 auto;
    padding: 152px 32px 88px;
    box-sizing: border-box;
  }

  .dd-hero-grid {
    min-height: calc(100vh - 240px);
    display: grid;
    grid-template-columns: minmax(0, 0.52fr) minmax(0, 0.48fr);
    gap: 56px;
    align-items: center;
  }

  /* Left: Content - Proportional Balance */
  .dd-hero-content { display: flex; flex-direction: column; justify-content: center; padding-left: 0; position: relative; z-index: 2; max-width: 590px; }
  .dd-industry-badge { display: inline-block; width: fit-content; background: transparent; color: #00D8E6; padding: 0; font-size: 13px; font-weight: 800; letter-spacing: 1.2px; text-transform: uppercase; margin-bottom: 30px; }
  .dd-hero-h1 { font-size: clamp(48px, 5vw, 76px); font-weight: 850; color: #FFFFFF; line-height: 0.95; letter-spacing: 0; margin: 0 0 34px; text-transform: none; font-family: 'Archivo Narrow', sans-serif; }
  .dd-hero-lead { font-size: 18px; line-height: 1.6; color: rgba(255,255,255,0.74); max-width: 580px; margin-bottom: 32px; }

  .dd-systems-preview { font-size: 20px; font-weight: 700; color: #FFFFFF; text-transform: none; letter-spacing: 0; margin-bottom: 28px; border-top: 2px solid #00A3AD; width: fit-content; padding-top: 28px; display: flex; align-items: center; gap: 14px; }
  .dd-systems-preview .dot { color: #00A3AD; font-size: 20px; }

  .dd-btn-v5 { background: linear-gradient(180deg, #04A6D8 0%, #007BB0 100%); color: #FFF; padding: 22px 48px; text-decoration: none; font-weight: 800; letter-spacing: 1.5px; display: inline-block; font-size: 13px; transition: opacity 0.3s; }
  .dd-btn-v5:hover { opacity: 0.86; }

  /* Right: Stable single-source image */
  .dd-hero-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .dd-hero-visual img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100vh;
    object-fit: cover;
    object-position: center right;
  }

  @media (max-width: 1024px) {
    .dd-hero-v5 .dd-container { padding: 124px 24px 64px; }
    .dd-hero-grid { grid-template-columns: 1fr; min-height: calc(100vh - 188px); gap: 0; align-items: center; }
    .dd-hero-h1 { font-size: 40px; margin-bottom: 24px; }
    .dd-hero-lead { font-size: 15px; margin-bottom: 24px; }
    .dd-systems-preview { flex-wrap: wrap; font-size: 16px; }
    .dd-hero-visual img { min-height: 100vh; object-position: 68% center; }
  }
</style>

{% schema %}
{
  "name": "DD Home Hero V5",
  "settings": [],
  "presets": [{"name": "DD Home Hero V5"}]
}
{% endschema %}
