{% comment %}
  DD Home Hero V5 - Solution Provider Focus (Final Locked Version)
  Positioning: Sign Manufacturing Solution Provider
  Layout: 60/40 Split
  Visual: Single CO2 Acrylic Cutting Production Panel
{% endcomment %}

<!-- HERO V2.2 STABLE LOCKED VERSION -->
<section class="dd-hero-v5" id="hero-v5">
  <div class="dd-container">
    <div class="dd-hero-grid">
      
      <!-- 1. SOLUTION IDENTITY (60%) -->
      <div class="dd-hero-content">
        <div class="dd-industry-badge">Built For Sign Production Teams</div>
        <h1 class="dd-hero-h1">Production Solutions For Sign Manufacturers</h1>
        <p class="dd-hero-lead">
          Verified production deployments across multiple international markets, helping sign manufacturers build and expand production capabilities with CO2 laser, CNC router, fiber laser, and UV printing solutions.
        </p>
        
        <div class="dd-systems-preview">
          <span>CO2 Laser</span> <span class="dot">·</span> 
          <span>CNC Router</span> <span class="dot">·</span> 
          <span>Fiber Laser</span> <span class="dot">·</span> 
          <span>UV Flatbed</span>
        </div>

        <div class="dd-hero-actions">
          <a href="#v2_1_conversion" class="dd-btn-v5">Request A Quote</a>
        </div>
      </div>

      <!-- 2. CO2 ACRYLIC CUTTING SCENE (40%) -->
      <div class="dd-hero-visual">
        <img src="{{ 'hero-v22-co2-acrylic-cutting-progress.png' | asset_url }}">
      </div>

    </div>
  </div>
</section>

<style>
  /* Base Reset & Variables */
  .dd-hero-v5 {
    position: relative;
    min-height: 100vh;
    padding: 0;
    background: #050607;
    overflow: hidden;
    border: 0;
    color: #FFFFFF;
  }

  .dd-hero-v5 .dd-container {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    width: 100%;
    min-height: 100vh;
    margin: 0 auto;
    padding: 150px 32px 96px;
    box-sizing: border-box;
  }

  .dd-hero-grid {
    min-height: calc(100vh - 246px);
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 64px;
    align-items: center;
  }

  /* Left: Content - Proportional Balance */
  .dd-hero-content { padding-left: 0; position: relative; z-index: 2; }
  .dd-industry-badge { display: inline-block; background: #00A3AD; color: #FFF; padding: 6px 14px; font-size: 10px; font-weight: 800; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 32px; }
  .dd-hero-h1 { font-size: 56px; font-weight: 850; color: #FFFFFF; line-height: 0.95; letter-spacing: -3px; margin: 0 0 32px; text-transform: uppercase; font-family: 'Archivo Narrow', sans-serif; }
  .dd-hero-lead { font-size: 18px; line-height: 1.6; color: rgba(255,255,255,0.74); max-width: 580px; margin-bottom: 32px; }

  .dd-systems-preview { font-size: 13px; font-weight: 700; color: #FFFFFF; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 40px; border-top: 1px solid rgba(0,163,173,0.75); padding-top: 24px; display: flex; align-items: center; gap: 12px; }
  .dd-systems-preview .dot { color: #00A3AD; font-size: 20px; }

  .dd-btn-v5 { background: #00A3AD; color: #FFF; padding: 22px 48px; text-decoration: none; font-weight: 800; letter-spacing: 1.5px; display: inline-block; font-size: 13px; transition: 0.3s; }
  .dd-btn-v5:hover { background: #008B94; }

  /* Right: Stable single-source image */
  .dd-hero-visual {
    position: absolute;
    inset: 0;
    z-index: 1;
    transform: none;
    border-radius: 0;
    overflow: hidden;
    border: 0;
    pointer-events: none;
  }

  .dd-hero-visual img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 100vh;
    object-fit: cover;
    object-position: center right;
    opacity: 0.72;
  }

  @media (max-width: 1024px) {
    .dd-hero-v5 .dd-container { padding: 120px 24px 72px; }
    .dd-hero-grid { grid-template-columns: 1fr; gap: 48px; }
    .dd-hero-h1 { font-size: 40px; margin-bottom: 24px; }
    .dd-hero-lead { font-size: 15px; margin-bottom: 24px; }
    .dd-hero-visual { width: 100%; max-width: none; margin: 0; }
    .dd-hero-visual img { min-height: 100vh; opacity: 0.42; }
  }
</style>

{% schema %}
{
  "name": "DD Home Hero V5",
  "settings": [],
  "presets": [{"name": "DD Home Hero V5"}]
}
{% endschema %}
