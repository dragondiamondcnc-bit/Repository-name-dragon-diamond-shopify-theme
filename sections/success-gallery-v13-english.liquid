<section class="success-gallery-section v-english-v16-xxl" id="success-gallery-{{ section.id }}">
  <div class="container-v2">
    <div class="section-header-v2">
      <h2 class="section-title-v2">SUCCESS CASE GALLERY</h2>
      <p class="section-subtitle-v2">Explore how Dragon Diamond's Industrial 4.0 solutions empower global signage, textile, and furniture manufacturers.</p>
    </div>

    <div class="success-grid">
      <!-- Card 1 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H724740e42dd24a6f93f4c7d211467496j.png" alt="Signage Excellence (Uganda)" loading="lazy">
          <span class="industry-tag">SIGNAGE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Signage Excellence (Uganda)</h3>
          <p class="card-market">Market: Africa / Uganda / Kampala</p>
          <p class="card-desc">High-precision acrylic cutting for 3D premium branding and display solutions.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/Hbb59fa86a8404b7f9ffa7a197985b759t.png" alt="Textile Precision (Uzbekistan)" loading="lazy">
          <span class="industry-tag">TEXTILE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Textile Precision (Uzbekistan)</h3>
          <p class="card-market">Market: Uzbekistan / Central Asia / Tashkent</p>
          <p class="card-desc">Automated laser tailoring for large-format textile processing and efficiency gains.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H5592889fd05a4926af9c895580fc0a58l.png" alt="Custom Furniture (Georgia)" loading="lazy">
          <span class="industry-tag">FURNITURE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Custom Furniture (Georgia)</h3>
          <p class="card-market">Market: Georgia / Tbilisi (Mr. Gocha)</p>
          <p class="card-desc">ATC Auto-tool change CNC solution for high-end furniture customization.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H909e78c2eeb54708a31b02b6b4ca8e9aQ.png" alt="Acrylic Design (Italy)" loading="lazy">
          <span class="industry-tag">ACRYLIC</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Acrylic Design (Italy)</h3>
          <p class="card-market">Market: Italy / Venice / Industrial Design</p>
          <p class="card-desc">Equipped with 100W-200W dedicated UV system for complex high-speed acrylic cutting.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* V16 XXL Layout - 300px Images + Bold Typography */
  .success-gallery-section.v-english-v16-xxl {
    background: #ffffff !important;
    padding: 120px 0 !important;
    font-family: 'Archivo Narrow', sans-serif !important;
    display: block !important;
    overflow-x: hidden !important;
  }
  .v-english-v16-xxl .container-v2 {
    max-width: 1700px !important; /* Massive container for 300px cards */
    margin: 0 auto !important;
    width: 95% !important;
  }
  .v-english-v16-xxl .section-header-v2 {
    text-align: center !important;
    margin-bottom: 80px !important;
  }
  .v-english-v16-xxl .section-title-v2 {
    font-size: 48px !important; /* Even larger section title */
    font-weight: 800 !important;
    color: #1a1a1a !important;
    letter-spacing: 3px !important;
    text-transform: uppercase !important;
    margin: 0 0 20px 0 !important;
  }
  .v-english-v16-xxl .section-subtitle-v2 {
    font-size: 20px !important; /* Larger subtitle text */
    line-height: 1.6 !important;
    color: #444 !important;
    max-width: 1000px !important;
    margin: 0 auto !important;
  }
  .v-english-v16-xxl .success-grid {
    display: flex !important;
    flex-wrap: wrap !important;
    justify-content: center !important;
    gap: 40px !important; /* Increased gap */
    width: 100% !important;
  }
  .v-english-v16-xxl .success-card {
    background: #ffffff !important;
    border: 1px solid #eeeeee !important;
    padding: 40px !important; /* Increased padding */
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) !important;
    width: calc(25% - 30px) !important;
    min-width: 380px !important;
    box-sizing: border-box !important;
    box-shadow: 0 10px 30px rgba(0,0,0,0.04) !important;
  }
  .v-english-v16-xxl .success-card:hover {
    transform: translateY(-12px) !important;
    box-shadow: 0 20px 50px rgba(0,0,0,0.1) !important;
    border-color: #006841 !important;
  }
  .v-english-v16-xxl .card-image-wrapper {
    position: relative !important;
    width: 300px !important; /* Upped to 300px */
    height: 300px !important; /* Upped to 300px */
    margin-bottom: 35px !important;
    border-radius: 20px !important;
    overflow: hidden !important;
    border: 1px solid #f0f0f0 !important;
  }
  .v-english-v16-xxl .card-image-wrapper img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
  .v-english-v16-xxl .industry-tag {
    position: absolute !important;
    top: 15px !important;
    left: 15px !important;
    background: #006841 !important;
    color: #ffffff !important;
    font-size: 12px !important;
    font-weight: 700 !important;
    padding: 8px 16px !important;
    border-radius: 6px !important;
    text-transform: uppercase !important;
    z-index: 10 !important;
  }
  .v-english-v16-xxl .card-title {
    font-size: 24px !important; /* Larger card title */
    font-weight: 700 !important;
    color: #1a1a1a !important;
    margin: 0 0 15px 0 !important;
    min-height: 60px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    line-height: 1.2 !important;
  }
  .v-english-v16-xxl .card-market {
    font-size: 14px !important;
    color: #006841 !important;
    font-weight: 700 !important;
    margin-bottom: 20px !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
  }
  .v-english-v16-xxl .card-desc {
    font-size: 16px !important; /* Larger description text */
    line-height: 1.6 !important;
    color: #555 !important;
    margin-bottom: 35px !important;
    min-height: 80px !important;
  }
  .v-english-v16-xxl .card-link {
    font-size: 14px !important;
    font-weight: 700 !important;
    color: #006841 !important;
    text-decoration: none !important;
    text-transform: uppercase !important;
    letter-spacing: 1.5px !important;
    border-bottom: 2px solid transparent !important;
    transition: all 0.2s ease !important;
  }
  .v-english-v16-xxl .card-link:hover {
    border-bottom-color: #006841 !important;
  }

  @media (max-width: 1600px) {
    .v-english-v16-xxl .success-card { width: calc(50% - 20px) !important; }
  }
  @media (max-width: 850px) {
    .v-english-v16-xxl .success-card { width: 100% !important; }
    .v-english-v16-xxl .card-image-wrapper { width: 100% !important; height: auto !important; aspect-ratio: 1/1 !important; }
  }
</style>

{% schema %}
{
  "name": "SG V16 XXL",
  "settings": [],
  "presets": [{ "name": "SG V16 XXL" }]
}
{% endschema %}
