        </div>
        <div class="dd-doc-card">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">QC LOG</span>
            <img src="https://sc01.alicdn.com/kf/A202f475557324a20ab9c688469d64cd8e.jpg" alt="ATC QC Testing" class="dd-evidence-img">
          </div>
