      <div class="dd-section-title">Scaling with Industrial Automation</div>
      <div class="dd-doc-grid-2">
        <div class="dd-doc-card">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">ORDER LOG</span>
            <img src="https://sc01.alicdn.com/kf/Adf752a43e9c243fd9d28f17f6b65336cc.jpg" alt="2026 ATC CNC Order" class="dd-evidence-img dd-vertical-adjust">
