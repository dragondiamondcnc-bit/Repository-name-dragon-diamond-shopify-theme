            <div class="dd-spec"><span>VACUUM SYSTEM</span><strong>High-Flow 7.5KW Pump</strong></div>
          </div>
        </div>
        <div class="dd-equipment-cta">
          <a href="/products/lz-1325-atc-cnc-router" class="dd-btn-primary">VIEW PRODUCT SPECS</a>
          <a href="#consultation" class="dd-btn-secondary">CUSTOMIZE MY SYSTEM</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 07: PRODUCTION ASSETS -->
