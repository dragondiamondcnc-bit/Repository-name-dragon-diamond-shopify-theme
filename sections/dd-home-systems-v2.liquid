{% comment %}
  DD Home Systems V2 - Machine Toolkits
{% endcomment %}
<section class="dd-home-systems">
  <div class="dd-container">
    <div class="dd-section-header" style="margin-bottom: 64px;">
      <span class="dd-sub">TOOLKITS // PRODUCTION_SYSTEMS</span>
      <h2 class="dd-title" style="font-size: 48px; margin: 16px 0; font-weight: 800; color: #FFF;">SIGN MANUFACTURING SYSTEMS</h2>
    </div>
    <div class="dd-systems-grid">
      <!-- 01 CO2 -->
      <div class="dd-system-item">
        <span style="color: #00A3AD; font-weight: 700; letter-spacing: 2px; font-size: 11px;">01 // CO2_LASER</span>
        <h3>CO2 Laser Systems</h3>
        <p>Precision acrylic cutting, signage engraving, and fabric processing.</p>
        <div class="dd-sys-footer">
          <a href="/collections/co2-laser" class="dd-sys-btn">EXPLORE SYSTEMS //</a>
        </div>
      </div>
      <!-- 02 CNC -->
      <div class="dd-system-item">
        <span style="color: #00A3AD; font-weight: 700; letter-spacing: 2px; font-size: 11px;">02 // CNC_ROUTER</span>
        <h3>CNC Router Systems</h3>
        <p>Heavy-duty MDF/PVC routing, and event display production.</p>
        <div class="dd-sys-footer">
          <a href="/collections/cnc-router" class="dd-sys-btn">EXPLORE SYSTEMS //</a>
        </div>
      </div>
      <!-- 03 Fiber -->
      <div class="dd-system-item">
        <span style="color: #00A3AD; font-weight: 700; letter-spacing: 2px; font-size: 11px;">03 // FIBER_LASER</span>
        <h3>Fiber Laser Systems</h3>
        <p>Metal signage fabrication and stainless steel channel letters.</p>
        <div class="dd-sys-footer">
          <a href="/collections/fiber-laser" class="dd-sys-btn">EXPLORE SYSTEMS //</a>
        </div>
      </div>
      <!-- 04 UV -->
      <div class="dd-system-item">
        <span style="color: #00A3AD; font-weight: 700; letter-spacing: 2px; font-size: 11px;">04 // UV_PRINTING</span>
        <h3>UV Printing Systems</h3>
        <p>Direct-to-substrate graphics and high-fidelity sign production.</p>
        <div class="dd-sys-footer">
          <a href="/collections/uv-printer" class="dd-sys-btn">EXPLORE SYSTEMS //</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .dd-home-systems { padding: 120px 0; background: #0F1115; color: #FFF; }
  .dd-systems-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 48px; }
  .dd-system-item { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); padding: 48px; }
  .dd-system-item h3 { font-size: 32px; font-weight: 800; margin: 16px 0; }
  .dd-sys-footer { margin-top: 32px; }
  .dd-sys-btn { background: #FFF; color: #000; padding: 15px 30px; text-decoration: none; font-weight: 700; font-size: 12px; display: block; text-align: center; }
</style>
