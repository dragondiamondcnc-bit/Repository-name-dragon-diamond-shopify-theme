<section class="success-gallery-section v-english-v15-xl" id="success-gallery-{{ section.id }}">
  <div class="container-v2">
    <div class="section-header-v2">
      <h2 class="section-title-v2">SUCCESS CASE GALLERY</h2>
      <p class="section-subtitle-v2">Explore how Dragon Diamond's Industrial 4.0 solutions empower global signage, textile, and furniture manufacturers.</p>
    </div>

    <div class="success-grid">
      <!-- Card 1 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H724740e42dd24a6f93f4c7d211467496j.png" alt="Signage Excellence (Africa)" loading="lazy">
          <span class="industry-tag">SIGNAGE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Signage Excellence (Uganda)</h3>
          <p class="card-market">Market: Africa / Uganda / Kampala</p>
          <p class="card-desc">High-precision acrylic cutting for 3D premium branding and display solutions.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/Hbb59fa86a8404b7f9ffa7a197985b759t.png" alt="Textile Precision (Uzbekistan)" loading="lazy">
          <span class="industry-tag">TEXTILE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Textile Precision (Uzbekistan)</h3>
          <p class="card-market">Market: Uzbekistan / Central Asia / Tashkent</p>
          <p class="card-desc">Automated laser tailoring for large-format textile processing and efficiency gains.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H5592889fd05a4926af9c895580fc0a58l.png" alt="Custom Furniture (Georgia)" loading="lazy">
          <span class="industry-tag">FURNITURE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Custom Furniture (Georgia)</h3>
          <p class="card-market">Market: Georgia / Tbilisi (Mr. Gocha)</p>
          <p class="card-desc">ATC Auto-tool change CNC solution for high-end furniture customization.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H909e78c2eeb54708a31b02b6b4ca8e9aQ.png" alt="Acrylic Design (Italy)" loading="lazy">
          <span class="industry-tag">ACRYLIC</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Acrylic Design (Italy)</h3>
          <p class="card-market">Market: Italy / Venice / Industrial Design</p>
          <p class="card-desc">Equipped with 100W-200W dedicated UV system for complex high-speed acrylic cutting.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* V15 XL Layout - 260px Images + Larger Subtitle */
  .success-gallery-section.v-english-v15-xl {
    background: #ffffff !important;
    padding: 100px 0 !important;
    font-family: 'Archivo Narrow', sans-serif !important;
    display: block !important;
    overflow-x: hidden !important;
  }
  .v-english-v15-xl .container-v2 {
    max-width: 1500px !important; /* Expanded for 260px cards */
    margin: 0 auto !important;
    width: 95% !important;
  }
  .v-english-v15-xl .section-header-v2 {
    text-align: center !important;
    margin-bottom: 70px !important;
  }
  .v-english-v15-xl .section-title-v2 {
    font-size: 42px !important; /* Larger section title */
    font-weight: 800 !important;
    color: #1a1a1a !important;
    letter-spacing: 2px !important;
    text-transform: uppercase !important;
    margin: 0 0 15px 0 !important;
  }
  .v-english-v15-xl .section-subtitle-v2 {
    font-size: 18px !important; /* Larger subtitle text */
    line-height: 1.6 !important;
    color: #555 !important; /* Slightly darker for better readability at larger size */
    max-width: 900px !important;
    margin: 0 auto !important;
  }
  .v-english-v15-xl .success-grid {
    display: flex !important;
    flex-wrap: wrap !important;
    justify-content: center !important;
    gap: 30px !important;
    width: 100% !important;
  }
  .v-english-v15-xl .success-card {
    background: #ffffff !important;
    border: 1px solid #f0f0f0 !important;
    padding: 35px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
    transition: all 0.3s ease !important;
    width: calc(25% - 23px) !important;
    min-width: 320px !important;
    box-sizing: border-box !important;
    box-shadow: 0 5px 20px rgba(0,0,0,0.03) !important;
  }
  .v-english-v15-xl .success-card:hover {
    transform: translateY(-8px) !important;
    box-shadow: 0 15px 40px rgba(0,0,0,0.08) !important;
    border-color: #006841 !important;
  }
  .v-english-v15-xl .card-image-wrapper {
    position: relative !important;
    width: 260px !important; /* Upped to 260px */
    height: 260px !important; /* Upped to 260px */
    margin-bottom: 30px !important;
    border-radius: 15px !important;
    overflow: hidden !important;
    border: 1px solid #f0f0f0 !important;
  }
  .v-english-v15-xl .card-image-wrapper img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
  .v-english-v15-xl .industry-tag {
    position: absolute !important;
    top: 12px !important;
    left: 12px !important;
    background: #006841 !important;
    color: #ffffff !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    padding: 6px 14px !important;
    border-radius: 4px !important;
    text-transform: uppercase !important;
    z-index: 10 !important;
  }
  .v-english-v15-xl .card-title {
    font-size: 20px !important; /* Larger card title */
    font-weight: 700 !important;
    color: #1a1a1a !important;
    margin: 0 0 15px 0 !important;
    min-height: 52px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    line-height: 1.2 !important;
  }
  .v-english-v15-xl .card-market {
    font-size: 13px !important;
    color: #006841 !important;
    font-weight: 700 !important;
    margin-bottom: 15px !important;
    text-transform: uppercase !important;
  }
  .v-english-v15-xl .card-desc {
    font-size: 15px !important; /* Larger description text */
    line-height: 1.6 !important;
    color: #666 !important;
    margin-bottom: 30px !important;
    min-height: 72px !important;
  }
  .v-english-v15-xl .card-link {
    font-size: 13px !important;
    font-weight: 700 !important;
    color: #006841 !important;
    text-decoration: none !important;
    text-transform: uppercase !important;
    letter-spacing: 1.2px !important;
    border-bottom: 2px solid transparent !important;
    transition: all 0.2s ease !important;
  }
  .v-english-v15-xl .card-link:hover {
    border-bottom-color: #006841 !important;
  }

  @media (max-width: 1400px) {
    .v-english-v15-xl .success-card { width: calc(50% - 15px) !important; }
  }
  @media (max-width: 750px) {
    .v-english-v15-xl .success-card { width: 100% !important; }
    .v-english-v15-xl .card-image-wrapper { width: 100% !important; height: auto !important; aspect-ratio: 1/1 !important; }
  }
</style>

{% schema %}
{
  "name": "SG V15 XL",
  "settings": [],
  "presets": [{ "name": "SG V15 XL" }]
}
{% endschema %}
