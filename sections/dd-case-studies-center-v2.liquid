{% comment %}
  Dragon Diamond Case Studies Center - Final Authority Edition
  Deployment Evidence // Global Validation Hub
{% endcomment %}

<div class="dd-case-center dd-industrial-v4">
  <!-- HERO SECTION -->
  <section class="dd-center-hero">
    <div class="dd-container">
      <h1 class="dd-title">GLOBAL DEPLOYMENT EVIDENCE</h1>
      <p class="dd-subtitle">Verified CNC Router, Laser Cutting and Laser Marking System Installations Across Multiple Industries.</p>
      
      <div class="dd-intro-text">
        <p>Dragon Diamond supports manufacturers, sign makers, furniture workshops and industrial fabricators worldwide. This evidence center documents real machine deployments, factory visits, technical training, export delivery and production validation from global customers.</p>
      </div>
    </div>
  </section>

  <!-- CASE GRID SECTION -->
  <section class="dd-case-grid-section">
    <div class="dd-container">
      <div class="dd-case-grid">
        <!-- CASE_001: Uganda -->
        <div class="dd-case-card">
          <div class="dd-case-media">
            <img src="https://sc01.alicdn.com/kf/Ha2366552ccda4d7c999d224a8ab9810dj.jpg" alt="Uganda Signage Factory">
            <div class="dd-case-tag">CASE_001</div>
          </div>
          <div class="dd-case-content">
            <div class="dd-case-meta">
              <div class="dd-meta-item"><span>COUNTRY</span><strong>UGANDA</strong></div>
              <div class="dd-meta-item"><span>INDUSTRY</span><strong>COMMERCIAL SIGN MAKING</strong></div>
            </div>
            <div class="dd-case-summary">
              <p>Factory-direct deployment for acrylic letters, illuminated signs and commercial branding production.</p>
            </div>
            <div class="dd-case-specs">
              <div class="dd-spec-row"><span>SYSTEM</span><strong>LZ-1390 LASER CUTTING MACHINE</strong></div>
              <div class="dd-spec-row"><span>STATUS</span><strong class="status-running">PRODUCTION RUNNING</strong></div>
            </div>
            <a href="/pages/case-uganda-sign-factory" class="dd-btn-outline">VIEW DEPLOYMENT LOG</a>
          </div>
        </div>

        <!-- CASE_002: Georgia -->
        <div class="dd-case-card">
          <div class="dd-case-media">
            <img src="https://sc02.alicdn.com/kf/A21a6f4b6f987470cb208f13ec8b08bacN.png" alt="Georgia Furniture Workshop" style="--zoom: 1.5; --pos: center 40%;">
            <div class="dd-case-tag">CASE_002</div>
          </div>
          <div class="dd-case-content">
            <div class="dd-case-meta">
              <div class="dd-meta-item"><span>COUNTRY</span><strong>GEORGIA</strong></div>
              <div class="dd-meta-item"><span>INDUSTRY</span><strong>FURNITURE MANUFACTURING</strong></div>
            </div>
            <div class="dd-case-summary">
              <p>Verified referral purchase in 2023 followed by a larger 2026 ATC CNC Router upgrade. 2023-2026 repeat purchase journey.</p>
            </div>
            <div class="dd-case-specs">
              <div class="dd-spec-row"><span>SYSTEM</span><strong>1325 CNC + 2128 ATC</strong></div>
              <div class="dd-spec-row"><span>STATUS</span><strong class="status-orders">REPEAT PURCHASE</strong></div>
            </div>
            <a href="/pages/case-study-georgia" class="dd-btn-outline">VIEW DEPLOYMENT LOG</a>
          </div>
        </div>

        <!-- CASE_005: Ethiopia -->
        <div class="dd-case-card">
          <div class="dd-case-media">
            <img src="https://sc02.alicdn.com/kf/A40abebafe10d44009c1d8f37f7cd0e06E.png" alt="Ethiopia Advertising Production">
            <div class="dd-case-tag">CASE_005</div>
          </div>
          <div class="dd-case-content">
            <div class="dd-case-meta">
              <div class="dd-meta-item"><span>COUNTRY</span><strong>ETHIOPIA</strong></div>
              <div class="dd-meta-item"><span>INDUSTRY</span><strong>ADVERTISING & SIGNAGE</strong></div>
            </div>
            <div class="dd-case-summary">
              <p>Verified production deployment of CO2 Laser and CNC solutions for the Addis Ababa advertising market.</p>
            </div>
            <div class="dd-case-specs">
              <div class="dd-spec-row"><span>SYSTEM</span><strong>CNC + CO2 LASER</strong></div>
              <div class="dd-spec-row"><span>STATUS</span><strong class="status-running">PRODUCTION RUNNING</strong></div>
            </div>
            <a href="/pages/case-study-005-ethiopia" class="dd-btn-outline">VIEW DEPLOYMENT LOG</a>
          </div>
        </div>

        <!-- CASE_004: Israel -->
        <div class="dd-case-card">
          <div class="dd-case-media">
            <img src="https://sc02.alicdn.com/kf/A02931f37b93640579151ac6f67b16c798.png" alt="Israel Event Decoration Workshop">
            <div class="dd-case-tag">CASE_004</div>
          </div>
          <div class="dd-case-content">
            <div class="dd-case-meta">
              <div class="dd-meta-item"><span>COUNTRY</span><strong>ISRAEL</strong></div>
              <div class="dd-meta-item"><span>INDUSTRY</span><strong>EVENT DECORATION</strong></div>
            </div>
            <div class="dd-case-summary">
              <p>Documented journey from factory verification to commercial event production in Israel using LZ-1325 CNC Router.</p>
            </div>
            <div class="dd-case-specs">
              <div class="dd-spec-row"><span>SYSTEM</span><strong>CNC ROUTER SYSTEM</strong></div>
              <div class="dd-spec-row"><span>STATUS</span><strong class="status-running">PRODUCTION RUNNING</strong></div>
            </div>
            <a href="/pages/case-study-israel" class="dd-btn-outline">VIEW DEPLOYMENT LOG</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE SECTION -->
  <section class="dd-why-choose">
    <div class="dd-container">
      <div class="dd-section-header">
        <h2 class="dd-title">WHY GLOBAL MANUFACTURERS CHOOSE DRAGON DIAMOND</h2>
      </div>
      
      <div class="dd-why-grid">
        <div class="dd-why-col">
          <div class="dd-why-icon">01</div>
          <h3>FACTORY VERIFICATION</h3>
          <p>Real customer visits and machine inspections at our manufacturing facility to verify engineering standards.</p>
        </div>
        <div class="dd-why-col">
          <div class="dd-why-icon">02</div>
          <h3>TECHNICAL TRAINING</h3>
          <p>Comprehensive factory-based and remote technical support programs to ensure rapid deployment and operational stability.</p>
        </div>
        <div class="dd-why-col">
          <div class="dd-why-icon">03</div>
          <h3>PRODUCTION VALIDATION</h3>
          <p>Real production results and performance verification from actual customer environments across the globe.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="dd-case-cta">
    <div class="dd-container">
      <div class="dd-cta-box">
        <h2 class="dd-title">NEED A PRODUCTION SOLUTION?</h2>
        <a href="#consultation" class="dd-btn-solid">REQUEST TECHNICAL CONSULTATION</a>
      </div>
    </div>
  </section>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;500;600;700&display=swap');

  .dd-case-center { background: #0F1115; color: #FFF; font-family: 'Archivo Narrow', sans-serif; }
  .dd-center-hero { padding: 120px 0 80px; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .dd-subtitle { font-size: 24px; color: #00A3AD; margin: 24px 0; font-weight: 700; letter-spacing: -1px; }
  .dd-intro-text { max-width: 800px; opacity: 0.6; line-height: 1.8; font-size: 16px; margin-top: 40px; }
  
  .dd-case-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; padding: 100px 32px 100px 0; }
  .dd-case-card { background: #1A1C20; border: 1px solid rgba(255,255,255,0.05); display: flex; flex-direction: column; height: 100%; }
  .dd-case-media { position: relative; aspect-ratio: 16/10; overflow: hidden; }
  .dd-case-media img { 
    width: 100%; height: 100%; object-fit: cover; 
    filter: contrast(1.1); 
    transform: scale(var(--zoom, 1.1)); 
    object-position: var(--pos, center);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.4s ease; 
  }
  .dd-case-card:hover .dd-case-media img { 
    transform: scale(calc(var(--zoom, 1.1) * 1.03)); 
    filter: brightness(1.05); 
  }
  .dd-case-tag { position: absolute; top: 0; left: 0; background: #00A3AD; color: #000; font-size: 10px; font-weight: 700; padding: 8px 16px; letter-spacing: 2px; z-index: 10; }
  
  .dd-case-content { padding: 32px; flex-grow: 1; display: flex; flex-direction: column; }
  .dd-case-meta { display: grid; grid-template-columns: 1fr; gap: 16px; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .dd-meta-item span { display: block; font-size: 8px; opacity: 0.4; letter-spacing: 2px; margin-bottom: 4px; font-weight: 700; }
  .dd-meta-item strong { display: block; font-size: 12px; font-weight: 700; letter-spacing: 0.5px; color: #FFF; }
  
  .dd-case-summary { margin-bottom: 24px; flex-grow: 1; }
  .dd-case-summary p { font-size: 13px; line-height: 1.6; opacity: 0.6; margin: 0; }
  
  .dd-case-specs { margin-bottom: 32px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.05); }
  .dd-spec-row { margin-bottom: 16px; }
  .dd-spec-row:last-child { margin-bottom: 0; }
  .dd-spec-row span { display: block; font-size: 8px; opacity: 0.4; letter-spacing: 2px; margin-bottom: 4px; font-weight: 700; }
  .dd-spec-row strong { display: block; font-size: 11px; color: #FFF; font-weight: 700; letter-spacing: 0.5px; }
  .dd-spec-row strong.status-running { color: #00FF88; }
  .dd-spec-row strong.status-orders { color: #00A3AD; }
  .dd-spec-row strong.status-training { color: #FFCC00; }
  .dd-spec-row strong.status-remote { color: #00A3AD; }
  
  .dd-case-card .dd-btn-outline { align-self: flex-start; }
  
  .dd-why-choose { padding: 120px 0; background: rgba(255,255,255,0.02); }
  .dd-why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 64px; margin-top: 80px; }
  .dd-why-icon { font-size: 12px; font-weight: 700; color: #00A3AD; border: 1px solid #00A3AD; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; margin-bottom: 32px; }
  .dd-why-col h3 { font-size: 16px; font-weight: 700; letter-spacing: 2px; margin-bottom: 24px; color: #FFF; }
  .dd-why-col p { font-size: 14px; opacity: 0.5; line-height: 1.8; margin: 0; }
  
  .dd-case-cta { padding: 120px 0; }
  .dd-cta-box { background: #00A3AD; padding: 100px; text-align: center; }
  .dd-cta-box h2 { font-size: 48px; font-weight: 700; letter-spacing: -2px; margin-bottom: 48px; color: #000; }
  .dd-cta-box .dd-btn-solid { background: #000; color: #FFF; border-color: #000; padding: 24px 64px; }
  .dd-cta-box .dd-btn-solid:hover { background: #FFF; color: #000; }
  
  @media (max-width: 1024px) {
    .dd-case-grid, .dd-why-grid { grid-template-columns: 1fr; }
    .dd-cta-box { padding: 60px 40px; }
    .dd-cta-box h2 { font-size: 32px; }
  }
</style>

{% schema %}
{
  "name": "Case Studies Center Final",
  "settings": [],
  "presets": [{"name": "Case Studies Center Final"}]
}
{% endschema %}
