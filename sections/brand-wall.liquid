{% comment %}
  Brand Wall (Partner Logos) for DRAGON DIAMOND
  Displays a row of trusted industrial component brands.
{% endcomment %}

<div class="brand-wall-section" style="background-color: #FFFFFF; padding: 100px 0; border-top: 1px solid #EEEEEE;">
  <div class="page-width">
    <div class="section-header" style="text-align: center; margin-bottom: 60px;">
      <h2 style="color: #1A1A1B; font-size: 32px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 800;">The DRAGON DIAMOND Supply Chain</h2>
      <p style="color: #666; font-size: 16px; margin: 20px 0 0;">We partner with the world's leading component brands to ensure every DRAGON DIAMOND machine delivers peak industrial performance.</p>
      <div style="width: 70px; height: 4px; background-color: #008F5A; margin: 15px auto 0;"></div>
    </div>
    
    <div class="brand-image-container" style="max-width: 1100px; margin: 0 auto; transition: all 0.4s ease; padding: 20px; background: #FFFFFF; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.03);">
      <img src="https://sc04.alicdn.com/kf/Hcaceafdef6db4ff9adfc64cd86497843Q/202269980/Hcaceafdef6db4ff9adfc64cd86497843Q.jpg" alt="DRAGON DIAMOND Partners: Reci, Ruida, HIWIN, Leadshine, S&A" style="width: 100%; display: block; filter: grayscale(100%); transition: filter 0.5s ease;">
    </div>

    <div class="partner-names" style="display: flex; justify-content: center; flex-wrap: wrap; gap: 30px; margin-top: 50px; color: #BBB; font-size: 14px; font-weight: 600; letter-spacing: 0.15em;">
      <span>RECI™</span> <span>RUIDA™</span> <span>HIWIN™</span> <span>LEADSHINE™</span> <span>S&A™</span>
    </div>
  </div>
</div>

<style>
.brand-image-container:hover {
  box-shadow: 0 20px 60px rgba(0,0,0,0.08);
}
.brand-image-container:hover img {
  filter: grayscale(0%);
}
@media screen and (max-width: 749px) {
  .section-header h2 { font-size: 24px !important; }
  .partner-names { font-size: 11px; gap: 15px; }
}
</style>