{% comment %}
  Industry Applications Section for DRAGON DIAMOND
  Displays 4 key sectors with dark industrial styling and hover details.
{% endcomment %}

<div class="industry-apps-section" style="background-color: #1A1A1B; padding: 120px 0; border-bottom: 1px solid #333;">
  <div class="page-width">
    <div class="section-header" style="text-align: center; margin-bottom: 80px;">
      <h2 style="color: #FFFFFF; font-size: 40px; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 800;">DRIVING EFFICIENCY ACROSS INDUSTRIES</h2>
      <p style="color: #888; font-size: 18px; margin: 20px 0 0;">Precision-engineered solutions for every industrial application.</p>
      <div style="width: 80px; height: 5px; background-color: #008F5A; margin: 15px auto 0;"></div>
    </div>

    <div class="apps-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; height: 550px;">
      
      <!-- Advertising & Signage -->
      <div class="app-card" style="position: relative; overflow: hidden; background-color: #000;">
        <img src="https://sc04.alicdn.com/kf/H7ca0a69b124e454c85907a5f65e9aebfD/202269980/H7ca0a69b124e454c85907a5f65e9aebfD.png" alt="Advertising & Signage" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.7; transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);">
        <div class="app-overlay" style="position: absolute; bottom: 0; left: 0; right: 0; padding: 40px 30px; background: linear-gradient(transparent, rgba(0, 143, 90, 0.95)); color: #FFFFFF; transform: translateY(60px); transition: all 0.4s ease;">
          <h3 style="margin: 0; font-size: 22px; font-weight: 700;">Advertising & Signage</h3>
          <p style="margin: 20px 0 0; font-size: 14px; line-height: 1.6; opacity: 0; transition: opacity 0.3s ease;">High-precision cutting for 3D acrylic letters and lightboxes.</p>
          <a href="/pages/advertising-signage" style="display: inline-block; margin-top: 20px; color: #FFFFFF; text-decoration: none; font-size: 13px; font-weight: bold; border-bottom: 2px solid #FFFFFF; padding-bottom: 5px; opacity: 0;">LEARN MORE</a>
        </div>
      </div>

      <!-- Arts & Crafts -->
      <div class="app-card" style="position: relative; overflow: hidden; background-color: #000;">
        <img src="https://sc02.alicdn.com/kf/H1dabd39b4b59427a8054c4004783fabdU.jpg" alt="Arts & Crafts" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.7; transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);">
        <div class="app-overlay" style="position: absolute; bottom: 0; left: 0; right: 0; padding: 40px 30px; background: linear-gradient(transparent, rgba(0, 143, 90, 0.95)); color: #FFFFFF; transform: translateY(60px); transition: all 0.4s ease;">
          <h3 style="margin: 0; font-size: 22px; font-weight: 700;">Arts & Crafts</h3>
          <p style="margin: 20px 0 0; font-size: 14px; line-height: 1.6; opacity: 0; transition: opacity 0.3s ease;">Intricate engraving on wood, leather, and personalized gifts.</p>
          <a href="/pages/crafts-gifts" style="display: inline-block; margin-top: 20px; color: #FFFFFF; text-decoration: none; font-size: 13px; font-weight: bold; border-bottom: 2px solid #FFFFFF; padding-bottom: 5px; opacity: 0;">LEARN MORE</a>
        </div>
      </div>

      <!-- Woodworking -->
      <div class="app-card" style="position: relative; overflow: hidden; background-color: #000;">
        <img src="https://sc02.alicdn.com/kf/H2357b979868242ba844b84d7fdc6e7da6.jpg" alt="Woodworking" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.7; transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);">
        <div class="app-overlay" style="position: absolute; bottom: 0; left: 0; right: 0; padding: 40px 30px; background: linear-gradient(transparent, rgba(0, 143, 90, 0.95)); color: #FFFFFF; transform: translateY(60px); transition: all 0.4s ease;">
          <h3 style="margin: 0; font-size: 22px; font-weight: 700;">Woodworking</h3>
          <p style="margin: 20px 0 0; font-size: 14px; line-height: 1.6; opacity: 0; transition: opacity 0.3s ease;">Heavy-duty routing for furniture, doors, and architectural decor.</p>
          <a href="/pages/woodworking" style="display: inline-block; margin-top: 20px; color: #FFFFFF; text-decoration: none; font-size: 13px; font-weight: bold; border-bottom: 2px solid #FFFFFF; padding-bottom: 5px; opacity: 0;">LEARN MORE</a>
        </div>
      </div>

      <!-- Apparel & Textiles -->
      <div class="app-card" style="position: relative; overflow: hidden; background-color: #000;">
        <img src="https://sc02.alicdn.com/kf/H18d9684359a8414c9302313e3c057f3c9.jpg" alt="Apparel & Textiles" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.7; transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);">
        <div class="app-overlay" style="position: absolute; bottom: 0; left: 0; right: 0; padding: 40px 30px; background: linear-gradient(transparent, rgba(0, 143, 90, 0.95)); color: #FFFFFF; transform: translateY(60px); transition: all 0.4s ease;">
          <h3 style="margin: 0; font-size: 22px; font-weight: 700;">Apparel & Textiles</h3>
          <p style="margin: 20px 0 0; font-size: 14px; line-height: 1.6; opacity: 0; transition: opacity 0.3s ease;">High-speed nesting and cutting for fabrics, badges, and fashion.</p>
          <a href="/pages/apparel-textiles" style="display: inline-block; margin-top: 20px; color: #FFFFFF; text-decoration: none; font-size: 13px; font-weight: bold; border-bottom: 2px solid #FFFFFF; padding-bottom: 5px; opacity: 0;">LEARN MORE</a>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
.app-card:hover img {
  transform: scale(1.15);
  opacity: 1;
}
.app-card:hover .app-overlay {
  transform: translateY(0);
}
.app-card:hover .app-overlay p, .app-card:hover .app-overlay a {
  opacity: 1 !important;
}
@media screen and (max-width: 1199px) {
  .apps-grid { grid-template-columns: repeat(2, 1fr); height: auto; }
  .app-card { height: 450px; }
}
@media screen and (max-width: 749px) {
  .apps-grid { grid-template-columns: 1fr; }
  .section-header h2 { font-size: 28px !important; }
}
</style>