<style>
  .dd-download-center { background: #0F1115; color: #FFF; padding-bottom: 120px; }
  .dd-center-hero { padding: 120px 0 80px; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .dd-download-category { margin-top: 80px; }
  .dd-cat-title { display: block; font-size: 10px; letter-spacing: 3px; font-weight: 700; opacity: 0.4; border-left: 2px solid #00A3AD; padding-left: 20px; margin-bottom: 40px; }
  .dd-doc-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.05); }
  .dd-doc-card { background: #1A1C20; padding: 48px; display: flex; justify-content: space-between; align-items: center; transition: background 0.3s ease; }
  .dd-doc-card:hover { background: #202226; }
  .dd-doc-info h3 { font-size: 16px; font-weight: 700; margin: 0 0 8px 0; letter-spacing: 1px; }
  .dd-doc-info span { font-size: 10px; opacity: 0.4; letter-spacing: 1px; }
  .dd-btn-icon { width: 48px; height: 48px; border: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
  .dd-btn-icon span { font-size: 8px; font-weight: 700; transform: rotate(-90deg); display: block; }
  .dd-btn-icon:hover { border-color: #00A3AD; color: #00A3AD; }
  @media (max-width: 1024px) {
    .dd-doc-grid { grid-template-columns: 1fr; }
    .dd-doc-card { padding: 32px; }
  }
</style>

{% schema %}
{
  "name": "Download Center",
  "settings": [],
  "presets": [{"name": "Download Center"}]
}
{% endschema %}
