<style>
  /* 1390 ADVANCED LAYOUT */
  .p-1390-wrapper { background: #fff; font-family: 'Archivo Narrow', sans-serif; }
  .p-container { max-width: 1300px; margin: 0 auto; width: 95%; }
  
  .p-1390-hero { padding: 60px 0; }
  .p-hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: start; }
  
  /* GALLERY (Matching Reference Image) */
  .p-hero-gallery { position: sticky; top: 20px; }
  .main-img-wrapper { border: 1px solid #f0f0f0; margin-bottom: 20px; background: #fff; }
  .main-img-wrapper img { width: 100%; height: auto; display: block; }
  
  .thumb-carousel-container { position: relative; display: flex; align-items: center; gap: 10px; padding: 0 30px; }
  .thumb-scroll-window { overflow-x: auto; scroll-behavior: smooth; display: flex; scrollbar-width: none; -ms-overflow-style: none; }
  .thumb-scroll-window::-webkit-scrollbar { display: none; }
  
  .thumb-grid-v2 { display: flex; gap: 10px; padding: 5px 0; }
  .thumb-v2 { width: 85px; height: 85px; object-fit: cover; border: 1px solid #ddd; cursor: pointer; transition: 0.2s; flex-shrink: 0; }
  .thumb-v2:hover { border-color: #004d30; }
  .thumb-v2.active { border-color: #006841; border-width: 2px; }

  .nav-arrow { position: absolute; background: #fff; border: 1px solid #ddd; color: #666; width: 24px; height: 50px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 18px; z-index: 5; transition: 0.2s; }
  .nav-arrow:hover { background: #f5f5f5; color: #000; }
  .nav-arrow.left { left: 0; }
  .nav-arrow.right { right: 0; }

  /* CONTENT (Matching Reference Image) */
  .p-title { font-size: 28px; font-weight: 800; color: #1a1a1a; margin: 0 0 15px 0; line-height: 1.2; }
  .p-description { font-size: 15px; color: #555; line-height: 1.6; margin-bottom: 25px; }
  
  .p-info-block { margin-bottom: 25px; }
  .info-header { font-size: 16px; font-weight: 800; color: #1a1a1a; margin-bottom: 12px; }
  .info-list { padding-left: 18px; margin: 0; list-style-type: decimal; }
  .info-list li { font-size: 14px; color: #555; margin-bottom: 8px; line-height: 1.4; }
  .info-list.bullet { list-style-type: disc; }
  .info-list.bullet li strong { color: #333; }
  
  .p-actions { margin-top: 35px; }
  .btn-primary-v2 { background: #004d30; color: #fff; text-decoration: none; padding: 15px 45px; font-weight: 700; font-size: 14px; border-radius: 2px; display: inline-block; transition: 0.3s; letter-spacing: 0.5px; }
  .btn-primary-v2:hover { background: #006841; }
  
  /* TRUST BAR */
  .p-trust-bar { padding: 30px 0; border-top: 1px solid #f0f0f0; }
  .trust-grid { display: flex; gap: 40px; }
  .trust-item { display: flex; align-items: center; gap: 12px; }
  .trust-item .icon { color: #006841; font-weight: 900; }
  .trust-item strong { font-size: 14px; color: #1a1a1a; }
  .trust-item span { font-size: 12px; color: #888; margin-left: 5px; }

  @media (max-width: 900px) {
    .p-hero-grid { grid-template-columns: 1fr; }
    .p-hero-gallery { position: static; }
  }
</style>

<script>
function changeImg(el) {
  const main = document.getElementById('main-product-img');
  main.src = el.src;
  
  const thumbs = document.querySelectorAll('.thumb-v2');
  thumbs.forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

function scrollThumbs(direction) {
  const container = document.getElementById('thumb-scroll');
  const scrollAmount = 100;
  container.scrollBy({ left: scrollAmount * direction, behavior: 'smooth' });
}
</script>
