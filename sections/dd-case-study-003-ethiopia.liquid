{% comment %}
  Dragon Diamond Case Study - Ethiopia Advertising Production
  Phase XV-B-03-V1 // Factory Visit + ChatGPT Discovery
  Documentary Style // Evidence-Based Trust Architecture
{% endcomment %}

<div class="dd-case-ethiopia">
  <!-- SECTION 01: HERO (FACTORY VISIT) -->
  <header class="dd-hero-ethiopia">
    <div class="dd-hero-bg">
      <img src="https://sc02.alicdn.com/kf/A40abebafe10d44009c1d8f37f7cd0e06E.png" alt="Ethiopian sign-making team factory visit to Dragon Diamond Guangzhou headquarters" title="Ethiopia Factory Visit">
      <div class="dd-hero-overlay">
        <div class="dd-container">
          <div class="dd-hero-text">
            <p class="dd-subtitle">CASE STUDY: ETHIOPIA</p>
            <h1 class="dd-title">From ChatGPT Search<br>To Factory Verification</h1>
            <p class="dd-support">An Addis Ababa signage company discovered Dragon Diamond through ChatGPT, then traveled to Guangzhou to verify our manufacturing capability before deploying a complete advertising production solution in Ethiopia.</p>
            <div class="dd-hero-cta">
              <a href="#consultation" class="dd-btn-hero-primary">REQUEST FACTORY TOUR INFO</a>
              <a href="#consultation" class="dd-btn-hero-secondary">GET A QUOTE</a>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="dd-overview-ethiopia">
      <div class="dd-container">
        <div class="dd-ov-grid">
          <div class="dd-ov-card"><span>LOCATION</span><strong>ETHIOPIA (ADDIS ABABA)</strong></div>
          <div class="dd-ov-card"><span>INDUSTRY</span><strong>ADVERTISING & SIGNAGE</strong></div>
          <div class="dd-ov-card"><span>SOLUTION</span><strong>CNC ROUTER + CO2 LASER</strong></div>
          <div class="dd-ov-card"><span>STATUS</span><strong class="status-deployment">TRANS-AFRICA DEPLOYMENT</strong></div>
        </div>
      </div>
    </div>
  </header>

  <!-- SECTION 02: HOW THE CUSTOMER FOUND DRAGON DIAMOND (V4.1) -->
  <section class="dd-section-ethiopia dd-dark">
    <div class="dd-container">
      <div class="dd-discovery-box-v4">
        <div class="dd-discovery-left">
          <h2 class="dd-sec-title">02. How The Customer Found Dragon Diamond</h2>
          <div class="dd-doc-text">
            <p>The customer searched for reliable CNC Router and Laser Cutting Machine suppliers in China capable of producing acrylic signage, MDF displays, PVC graphics, and ACP advertising panels.</p>
            <p>Dragon Diamond was identified through ChatGPT due to our specialization in signage production equipment and factory-direct engineering support.</p>
          </div>
        </div>
        <div class="dd-discovery-right">
          <div class="dd-chatgpt-card">
            <div class="dd-chat-msg">
              <span class="dd-chat-label">USER</span>
              <p class="dd-chat-text">Looking for reliable CNC router and laser cutting machine suppliers in China for advertising and signage production.</p>
            </div>
            <div class="dd-chat-divider"><span>CHATGPT RESPONSE</span></div>
            <div class="dd-chat-msg">
              <span class="dd-chat-label">DRAGON DIAMOND TECHNOLOGY</span>
              <p class="dd-chat-text" style="margin-bottom: 20px;">Guangzhou, China — Recommended for:</p>
              <ul class="dd-chat-results">
                <li><span>✓</span> CNC Router Systems</li>
                <li><span>✓</span> CO2 Laser Cutting Machines</li>
                <li><span>✓</span> Acrylic Sign Production</li>
                <li><span>✓</span> Export Experience</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 03: MACHINE VERIFICATION -->
  <section class="dd-section-ethiopia dd-white">
    <div class="dd-container">
      <h2 class="dd-sec-title">03. Machine Verification</h2>
      <div class="dd-doc-grid-v3">
        <div class="dd-doc-item">
          <div class="dd-evidence-frame-v3">
            <div class="dd-privacy-top-mask-v3"></div>
            <img src="https://sc01.alicdn.com/kf/Ac15df9101a4147e59abab72c68eb22d0o.png" alt="Camera positioning contour cutting on printed PVC foam board" class="dd-evidence-img-v3">
          </div>
          <p class="dd-doc-caption">CAMERA-ASSISTED PRINTED GRAPHIC CONTOUR CUTTING</p>
          <p class="dd-doc-desc">The customer verified camera-assisted contour cutting on printed PVC foam board (KT board). The positioning system automatically detects registration marks and follows the printed outline with high precision.</p>
        </div>
        <div class="dd-doc-item">
          <div class="dd-evidence-frame-v3">
            <div class="dd-privacy-top-mask-v3"></div>
            <img src="https://sc01.alicdn.com/kf/A4929117a0e344064b9360b54ed59a519i.png" alt="PVC lettering precision routing on CNC router" class="dd-evidence-img-v3">
          </div>
          <p class="dd-doc-caption">PVC LETTERING PRECISION ROUTING</p>
          <p class="dd-doc-desc">The CNC router was tested for clean letter routing on PVC advertising materials, confirming edge accuracy and spindle stability during signage production.</p>
        </div>
        <div class="dd-doc-item">
          <div class="dd-evidence-frame-v3">
            <div class="dd-privacy-top-mask-v3"></div>
            <img src="https://sc01.alicdn.com/kf/A012052b8a58e486ca431fb0429928fcfx.jpg" alt="Ethiopian customer observing live machine testing at factory" class="dd-evidence-img-v3">
          </div>
          <p class="dd-doc-caption">CUSTOMER OBSERVING LIVE MACHINE TESTING</p>
          <p class="dd-doc-desc">The customer observed live machine testing on the factory floor and reviewed machining performance directly with Dragon Diamond engineers.</p>
        </div>
        <div class="dd-doc-item">
          <div class="dd-evidence-frame-v3">
            <div class="dd-privacy-top-mask-v3"></div>
            <img src="https://sc02.alicdn.com/kf/Ab3fe7b455806491a9bb2f9b77552cb48A.png" alt="Technical requirement review with customer" class="dd-evidence-img-v3">
          </div>
          <p class="dd-doc-caption">TECHNICAL REQUIREMENT REVIEW</p>
          <p class="dd-doc-desc">Technical requirements, materials, production workflow, and machine configuration were reviewed with the customer before final confirmation.</p>
        </div>
      </div>
      <div class="dd-doc-text-center">
        <p>Real-world performance was verified through live processing of Advertising materials (Acrylic/PVC). The customer observed high-speed lettering and precision contour tracing to ensure the machines met their strict export quality requirements.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 04: HANDS-ON TRAINING & TECHNICAL TRANSFER -->
  <section class="dd-section-ethiopia dd-dark">
    <div class="dd-container">
      <h2 class="dd-sec-title">04. Hands-On Training & Technical Transfer</h2>
      <div class="dd-training-grid-v4">
        <div class="dd-training-unit-v4">
          <div class="dd-training-item-v4">
            <img src="https://sc02.alicdn.com/kf/A17477961d4c84a3798f25561c9f9b2acG.png" alt="Software Workflow Training">
          </div>
          <p class="dd-training-caption-v4">SOFTWARE WORKFLOW TRAINING</p>
        </div>
        <div class="dd-training-unit-v4">
          <div class="dd-training-item-v4">
            <img src="https://sc02.alicdn.com/kf/A2202b42ebe314b48b51a7e4230661e17d.png" alt="Parameter Configuration">
          </div>
          <p class="dd-training-caption-v4">PARAMETER CONFIGURATION</p>
        </div>
        <div class="dd-training-unit-v4">
          <div class="dd-training-item-v4">
            <img src="https://sc02.alicdn.com/kf/A3ea0c6d090404ff1928c3c5e2f69d7be0.png" alt="Controller Operation Practice">
          </div>
          <p class="dd-training-caption-v4">CONTROLLER OPERATION PRACTICE</p>
        </div>
        <div class="dd-training-unit-v4">
          <div class="dd-training-item-v4">
            <img src="https://sc01.alicdn.com/kf/A78a42bdcddd445d39b8ad391033794fa2.png" alt="Technical Documentation Transfer">
          </div>
          <p class="dd-training-caption-v4">TECHNICAL DOCUMENTATION TRANSFER</p>
        </div>
      </div>
      <div class="dd-doc-text-center">
        <p>A comprehensive training cycle covered sign-making software, nesting efficiency, and hands-on machine operation. This technical transfer ensures the team in Addis Ababa can operate with factory-level precision from day one.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 05: EQUIPMENT CONFIGURATION SELECTED -->
  <section class="dd-section-ethiopia dd-white">
    <div class="dd-container">
      <h2 class="dd-sec-title">05. Equipment Configuration Selected</h2>
      <div class="dd-solution-grid">
        <div class="dd-sol-card">
          <div class="dd-sol-img">
            <img src="https://sc02.alicdn.com/kf/A1c0a05f90fdf42e6bdeacae7722f5d273.png" alt="LZ-1390 CO2 Laser Cutting Machine for signage production">
          </div>
          <div class="dd-sol-info">
            <strong>CO2 LASER CUTTING SYSTEM</strong>
            <ul>
              <li>High-speed acrylic polishing cut</li>
              <li>Precision leather/fabric engraving</li>
              <li>Dual-head efficiency options</li>
            </ul>
          </div>
        </div>
        <div class="dd-sol-card">
          <div class="dd-sol-img">
            <img src="https://sc02.alicdn.com/kf/A2615550bf4024ff9a80701bb8753f492Q.png" alt="1325 CNC Router for advertising and woodworking">
          </div>
          <div class="dd-sol-info">
            <strong>INDUSTRIAL CNC ROUTER</strong>
            <ul>
              <li>Heavy-duty frame for ACP & MDF</li>
              <li>High-torque spindle for thick PVC</li>
              <li>Vacuum table for rapid material swaps</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="dd-doc-text" style="margin-top: 48px;">
        <p>A dual-machine setup designed as a complete advertising production solution. This configuration allows the customer to handle everything from intricate laser-engraved acrylic displays to large-scale CNC-routed ACP building signage.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 06: PRODUCTION CAPABILITY VERIFIED -->
  <section class="dd-section-ethiopia dd-dark">
    <div class="dd-container">
      <h2 class="dd-sec-title">06. Production Capability Verified</h2>
      <div class="dd-proof-feature">
        <img src="https://sc02.alicdn.com/kf/A726b07c3d3a249a0912a236228c55f3dX.png" alt="Professional illuminated signage produced with Dragon Diamond machines" loading="lazy">
        <div class="dd-proof-label">
          <span>PROJECT: ILLUMINATED SIGNAGE</span>
          <strong>20MM POLISHED ACRYLIC LETTERING</strong>
        </div>
      </div>
      <div class="dd-doc-text" style="margin-top: 40px;">
        <p>The ultimate verification: professional illuminated signage. The clean, 20mm polished acrylic edges produced by the 130W Laser and the dimensional accuracy of the CNC Router confirm the high-margin capability of this production line.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 07: EXPORT LOGISTICS TO ETHIOPIA -->
  <section class="dd-section-ethiopia dd-white">
    <div class="dd-container">
      <h2 class="dd-sec-title">07. EXPORT LOGISTICS TO ETHIOPIA</h2>
      
      <div class="dd-doc-text">
        <p>The machines were packed in reinforced export-grade plywood crates and documented during container loading before shipment to Ethiopia. This logistics record confirms that the equipment was prepared for long-distance transport with structural protection and alignment safety in mind.</p>
      </div>

      <div class="dd-logistics-grid-v4">
        <div class="dd-doc-unit">
          <div class="dd-logistics-item-v4">
            <div class="dd-privacy-top-mask-v3"></div>
            <img src="https://sc02.alicdn.com/kf/Af124c1f6d3574c30a10878d862c648bbz.png" alt="Export plywood crating">
          </div>
          <p class="dd-logistics-caption-v4">EXPORT-GRADE PLYWOOD CRATING</p>
        </div>

        <div class="dd-doc-unit">
          <div class="dd-logistics-item-v4">
            <div class="dd-privacy-top-mask-v3"></div>
            <img src="https://sc02.alicdn.com/kf/A70e6e03e09fc4c9590aa049ccdfeca77w.png" alt="Container loading for Ethiopia">
          </div>
          <p class="dd-logistics-caption-v4">CONTAINER LOADING & SECURING</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 08: PARTNERSHIP SUMMARY (V4.1) -->
  <section class="dd-section-ethiopia dd-dark">
    <div class="dd-container">
      <div class="dd-summary-card">
        <div class="dd-summary-left">
          <h2 class="dd-sec-title">08. Partnership Summary</h2>
          <div class="dd-doc-text">
            <p>This project demonstrates how a modern AI-assisted supplier search can evolve into a fully verified international manufacturing partnership.</p>
            <p>From initial discovery through ChatGPT to factory verification, technical training, export logistics, and production deployment, the customer completed every stage before launching operations in Addis Ababa.</p>
          </div>
          <div class="dd-timeline-v4">
            <div class="dd-tl-item">
              <div class="dd-tl-dot"></div>
              <div class="dd-tl-content"><strong>PHASE 01</strong><span>ChatGPT Discovery</span></div>
            </div>
            <div class="dd-tl-item">
              <div class="dd-tl-dot"></div>
              <div class="dd-tl-content"><strong>PHASE 02</strong><span>Guangzhou Factory Visit</span></div>
            </div>
            <div class="dd-tl-item">
              <div class="dd-tl-dot"></div>
              <div class="dd-tl-content"><strong>PHASE 03</strong><span>Intensive Training</span></div>
            </div>
            <div class="dd-tl-item">
              <div class="dd-tl-dot"></div>
              <div class="dd-tl-content"><strong>PHASE 04</strong><span>Ethiopia Deployment</span></div>
            </div>
            <div class="dd-tl-item">
              <div class="dd-tl-dot"></div>
              <div class="dd-tl-content"><strong>PHASE 05</strong><span>Production Scale-up</span></div>
            </div>
          </div>
        </div>
        <div class="dd-summary-right">
          <img src="https://sc02.alicdn.com/kf/Ada5624657b2f45aa8a0e0b7431912495r.png" alt="Ethiopian team thumbs up at Dragon Diamond factory gate" class="dd-summary-img">
        </div>
      </div>
      
      <div class="dd-section-cta" style="margin-top: 80px; text-align: center;">
        <a href="/pages/contact" class="dd-btn-hero-primary">REQUEST SIMILAR SIGNAGE PRODUCTION INFO</a>
      </div>
      
      <div class="dd-ethiopia-footer">
        <a href="/pages/case-studies" class="dd-back-hub">← ALL CASE STUDIES</a>
      </div>
    </div>
  </section>
</div>

<style>
  /* INDUSTRIAL DOCUMENTARY STYLE - ETHIOPIA (V3) */
  .dd-case-ethiopia { background: #0F1115; color: #FFF; font-family: 'Archivo Narrow', sans-serif; line-height: 1.5; -webkit-font-smoothing: antialiased; }
  .dd-container {
    max-width: 1240px;
    margin: 0 auto;
    padding-left: 32px;
    padding-right: 32px;
  }
  
  /* HERO */
  .dd-hero-ethiopia { position: relative; width: 100%; overflow: hidden; background: #000; }
  .dd-hero-bg { position: relative; width: 100%; height: 520px !important; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .dd-hero-bg img { width: 100%; height: 520px !important; object-fit: cover !important; opacity: 0.8; }
  .dd-hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 60px 0; background: linear-gradient(transparent, rgba(15,17,21,1)); }
  .dd-hero-text .dd-title { font-size: 32px; font-weight: 800; line-height: 1.1; margin-bottom: 16px; color: #FFF; text-transform: uppercase; }
  .dd-hero-text .dd-subtitle { font-size: 11px; color: #00A3AD; font-weight: 700; letter-spacing: 4px; margin-bottom: 8px; }
  .dd-hero-text .dd-support { font-size: 14px; opacity: 0.5; margin: 0; max-width: 600px; }
  
  .dd-hero-cta { display: flex; gap: 16px; margin-top: 32px; }
  .dd-btn-hero-primary { font-size: 10px; font-weight: 800; background: #00A3AD; color: #FFF; padding: 12px 24px; text-decoration: none; letter-spacing: 1px; border: 1px solid #00A3AD; transition: all 0.3s; display: inline-block; }
  .dd-btn-hero-secondary { font-size: 10px; font-weight: 800; color: #FFF; border: 1px solid #FFF; padding: 12px 24px; text-decoration: none; letter-spacing: 1px; display: inline-block; }

  .dd-overview-ethiopia { background: #1A1C20; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1); }
  .dd-ov-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; }
  .dd-ov-card span { display: block; font-size: 7px; opacity: 0.4; letter-spacing: 2px; font-weight: 700; margin-bottom: 6px; }
  .dd-ov-card strong { font-size: 11px; font-weight: 700; color: #FFF; }
  .status-deployment { color: #00A3AD !important; }

  /* DISCOVERY BOX (V4.1) */
  .dd-discovery-box-v4 { display: grid; grid-template-columns: 1fr 400px; gap: 80px; align-items: flex-start; }
  
  /* CHATGPT CARD STYLE */
  .dd-chatgpt-card {
    background: #1A1C20;
    border: 1px solid rgba(255,255,255,0.05);
    padding: 40px;
    border-radius: 4px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  }
  .dd-chat-msg { margin-bottom: 0; }
  .dd-chat-label { 
    display: inline-block; 
    font-size: 8px; 
    font-weight: 900; 
    color: #00A3AD; 
    letter-spacing: 2px; 
    margin-bottom: 12px;
    padding: 4px 8px;
    background: rgba(0,163,173,0.1);
  }
  .dd-chat-text { font-size: 14px; line-height: 1.5; color: #FFF; opacity: 0.8; margin: 0; }
  .dd-chat-divider { height: 1px; background: rgba(255,255,255,0.05); margin: 32px 0; display: flex; align-items: center; justify-content: center; }
  .dd-chat-divider span { background: #1A1C20; padding: 0 16px; font-size: 10px; color: #00A3AD; font-weight: 800; letter-spacing: 1px; }
  .dd-chat-results { list-style: none; padding: 0; margin: 0; }
  .dd-chat-results li { 
    font-size: 13px; 
    margin-bottom: 12px; 
    color: #FFF; 
    display: flex; 
    align-items: center; 
    gap: 12px;
  }
  .dd-chat-results li span { color: #00A3AD; font-weight: 800; }

  /* SECTION STRUCTURE */
  .dd-section-ethiopia { padding: 100px 0; }
  .dd-white { background: #FFF; color: #000; }
  .dd-dark { background: #0F1115; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .dd-sec-title { font-size: 20px; font-weight: 800; margin-bottom: 60px; letter-spacing: -0.5px; text-transform: uppercase; border-left: 3px solid #00A3AD; padding-left: 16px; }
  
  .dd-doc-grid-v3 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
  .dd-evidence-frame-v3 { width: 100%; max-width: 640px; height: 320px; margin: 0 auto; overflow: hidden; background: #f4f4f4; position: relative; border: 1px solid rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center; }
  .dd-evidence-img-v3 { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; position: relative; z-index: 5; }
  .dd-privacy-top-mask-v3 { position: absolute; top: 0; left: 0; width: 100%; height: 40px; background: #f4f4f4; z-index: 10; }
  .dd-doc-caption { font-size: 11px; font-weight: 800; letter-spacing: 1px; color: #00A3AD; text-transform: uppercase; margin-top: 16px; margin-bottom: 8px; }
  .dd-doc-desc { font-size: 13px; line-height: 1.5; opacity: 0.6; margin: 0; }
  .dd-dark .dd-doc-caption { color: #00A3AD; }
  .dd-dark .dd-doc-desc { color: #FFF; }
  .dd-doc-text-center { margin-top: 60px; font-size: 16px; line-height: 1.7; opacity: 0.8; max-width: 800px; margin-left: auto; margin-right: auto; text-align: center; }

  /* SOLUTION GRID */
  .dd-solution-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .dd-sol-card { background: #F8F9FA; border: 1px solid rgba(0,0,0,0.05); }
  .dd-sol-img { background: #FFF; padding: 40px; text-align: center; border-bottom: 1px solid rgba(0,0,0,0.05); }
  .dd-sol-img img { max-width: 100%; height: auto; max-height: 240px; object-fit: contain; }
  .dd-sol-info { padding: 40px; }
  .dd-sol-info strong { display: block; font-size: 14px; font-weight: 800; margin-bottom: 24px; color: #000; letter-spacing: 0.5px; }
  .dd-sol-info ul { list-style: none; padding: 0; margin: 0; }
  .dd-sol-info li { font-size: 12px; opacity: 0.6; margin-bottom: 12px; position: relative; padding-left: 20px; color: #000; }
  .dd-sol-info li::before { content: "→"; position: absolute; left: 0; color: #00A3AD; }

  /* PROOF FEATURE */
  .dd-proof-feature { position: relative; width: 100%; }
  .dd-proof-feature img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
  .dd-proof-label { position: absolute; bottom: 40px; right: 40px; background: #00A3AD; color: #FFF; padding: 24px 32px; text-align: right; }
  .dd-proof-label span { display: block; font-size: 8px; letter-spacing: 2px; font-weight: 700; opacity: 0.8; margin-bottom: 8px; }
  .dd-proof-label strong { display: block; font-size: 14px; font-weight: 800; letter-spacing: 1px; }

  /* PACKAGING */
  .dd-pack-frame { background: #f4f4f4; padding: 20px; border: 1px solid rgba(0,0,0,0.05); }
  .dd-pack-frame img { width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block; }

  /* SUMMARY CARD */
  .dd-summary-card { display: grid; grid-template-columns: 1fr 400px; gap: 80px; align-items: center; background: #1A1C20; padding: 60px; border: 1px solid rgba(255,255,255,0.05); }
  .dd-summary-img { width: 100%; aspect-ratio: 4/3; object-fit: cover; border: 1px solid rgba(255,255,255,0.1); }

  /* SECTION 07 CLEANUP V4.3 */
  .dd-logistics-grid-v4 { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 48px; }
  .dd-logistics-item-v4 { position: relative; width: 100%; height: 420px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); }
  .dd-logistics-item-v4 img { width: 100%; height: 100%; object-fit: cover; }
  .dd-logistics-caption-v4 { font-size: 10px; font-weight: 800; color: #000; letter-spacing: 1px; margin-top: 12px; text-transform: uppercase; }

  /* SECTION 04 - TRAINING CONTACT SHEET (V4.5) */
  .dd-training-grid-v4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; margin-top: 48px; }
  .dd-training-item-v4 { position: relative; height: 520px; overflow: hidden; border: 1px solid rgba(255,255,255,0.05); }
  .dd-training-item-v4 img { width: 100%; height: 110%; object-fit: cover; object-position: top; }
  .dd-training-caption-v4 { font-size: 10px; font-weight: 800; color: #00A3AD; letter-spacing: 1px; margin-top: 12px; text-transform: uppercase; }

  /* TIMELINE V4 */
