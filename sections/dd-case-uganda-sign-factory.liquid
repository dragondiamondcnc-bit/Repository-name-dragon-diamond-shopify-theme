{% comment %}
  Dragon Diamond Case Study - Uganda Signage Factory
  Phase VII-A // Hero SEO + Decision Timeline + Featured Equipment + H2 Semantics
  Industrial Documentary Style // Evidence-First Trust Architecture
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;500;600;700&display=swap');

  .dd-case-v9-5 {
    background: #0F1115;
    color: #FFF;
    font-family: 'Archivo Narrow', sans-serif;
    overflow-x: hidden;
  }

  .dd-container {
    max-width: 1240px;
    margin: 0 auto;
    padding-left: 32px;
    padding-right: 32px;
  }

  .dd-kicker {
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 18px;
    display: block;
    border-left: 3px solid #00A3AD;
    padding-left: 16px;
  }

  .dd-section-title {
    font-size: 42px;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -1px;
    margin: 0 0 24px;
    color: #fff;
  }

  .dd-section-copy {
    max-width: 760px;
    font-size: 17px;
    line-height: 1.75;
    color: rgba(255,255,255,0.68);
  }

  /* HERO SECTION */
  .dd-hero-v9-5 { position: relative; width: 100%; height: 85vh; overflow: hidden; background: #000; }
  .dd-hero-bg { width: 100%; height: 100%; }
  .dd-hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .dd-hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(90deg, rgba(15,17,21,0.95) 0%, rgba(15,17,21,0.6) 50%, rgba(15,17,21,0) 100%); display: flex; align-items: center; }
  .dd-hero-text { max-width: 820px; }
  
  .dd-hero-title { font-size: 72px; line-height: 1.05; font-weight: 800; margin-bottom: 24px; letter-spacing: -2px; color: #fff; text-transform: uppercase; }
  
  /* HERO SEO SUBHEADLINE */
  .dd-hero-seo-line {
    max-width: 760px;
    margin-bottom: 42px;
    font-size: 21px;
    line-height: 1.55;
    color: rgba(255,255,255,0.78);
    font-weight: 500;
  }

  .dd-hero-cta { display: flex; gap: 20px; }
  .dd-btn-primary { background: #00A3AD; color: #FFF; padding: 20px 36px; font-weight: 800; font-size: 13px; text-decoration: none; letter-spacing: 1px; text-transform: uppercase; display: inline-block; }
  .dd-btn-secondary { border: 1px solid rgba(255,255,255,0.3); color: #FFF; padding: 20px 36px; font-weight: 800; font-size: 13px; text-decoration: none; letter-spacing: 1px; text-transform: uppercase; display: inline-block; }

  /* PROJECT INFO CARD */
  .dd-hero-project-card { position: absolute; bottom: 40px; right: 40px; background: rgba(15, 17, 21, 0.85); padding: 24px; border-left: 3px solid #00A3AD; z-index: 10; backdrop-filter: blur(4px); }
  .dd-pc-row { margin-bottom: 12px; }
  .dd-pc-row:last-child { margin-bottom: 0; }
  .dd-pc-row span { display: block; font-size: 7px; opacity: 0.5; letter-spacing: 1px; font-weight: 700; margin-bottom: 4px; text-transform: uppercase; }
  .dd-pc-row strong { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.5px; color: #fff; }
  .status-running { color: #00FF85 !important; }

  /* DECISION TIMELINE */
  .dd-decision-timeline {
    padding: 110px 0;
    background: #11141A;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .dd-timeline-grid {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 18px;
  }

  .dd-timeline-step {
    position: relative;
    min-height: 190px;
    padding: 28px 22px;
    background: #171A20;
    border: 1px solid rgba(255,255,255,0.07);
  }

  .dd-timeline-step::after {
    content: "";
    position: absolute;
    top: 50%;
    right: -18px;
    width: 18px;
    height: 1px;
    background: rgba(0,163,173,0.45);
  }

  .dd-timeline-step:last-child::after {
    display: none;
  }

  .dd-step-num {
    font-family: "Archivo Narrow", sans-serif;
    font-size: 13px;
    color: #00A3AD;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 18px;
  }

  .dd-step-title {
    font-size: 18px;
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 12px;
  }

  .dd-step-copy {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255,255,255,0.58);
  }

  /* DOCUMENTARY MODULES */
  .dd-doc-section { padding: 110px 0; }
  .dd-dark { background: #0F1115; }
  .dd-white { background: #FFF; color: #111; }
  .dd-white .dd-section-title { color: #111; }
  .dd-white .dd-section-copy { color: #555; }
  
  .dd-doc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; margin-top: 56px; }
  .dd-doc-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 56px; }
  .dd-doc-card { display: flex; flex-direction: column; }
  
  .dd-evidence-frame-v3 {
    position: relative;
    width: 100%;
    height: 320px;
    background: #181B20;
    overflow: hidden;
    margin-bottom: 24px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .dd-evidence-label {
    position: absolute;
    left: 14px;
    top: 14px;
    z-index: 2;
    padding: 7px 10px;
    background: rgba(15,17,21,0.85);
    border: 1px solid rgba(0,163,173,0.45);
    color: #fff;
    font-family: "Archivo Narrow", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
  }

  .dd-evidence-img { width: 100%; height: 100%; object-fit: cover; }
  .dd-vertical-adjust { height: 480px !important; object-fit: contain !important; background: #181B20; }
  
  .dd-card-caption { font-family: "Archivo Narrow", sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 1.5px; color: #00A3AD; margin-bottom: 12px; text-transform: uppercase; }
  .dd-card-desc { font-size: 15px; line-height: 1.65; color: rgba(255,255,255,0.6); }
  .dd-white .dd-card-desc { color: #555; }
  .dd-white .dd-card-caption { color: #00A3AD; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 12px; }

  /* FEATURED EQUIPMENT */
  .dd-featured-equipment {
    padding: 110px 0;
    background: #11141A;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .dd-equipment-panel {
    margin-top: 50px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    background: #171A20;
    border: 1px solid rgba(255,255,255,0.07);
    padding: 46px;
  }

  .dd-equipment-name {
    font-size: 34px;
    font-weight: 800;
    margin-bottom: 20px;
    color: #fff;
  }

  .dd-equipment-specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
    margin-top: 32px;
  }

  .dd-spec {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 16px;
  }

  .dd-spec span {
    display: block;
    font-family: "Archivo Narrow", sans-serif;
    color: #00A3AD;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .dd-spec strong {
    font-size: 16px;
    color: #fff;
  }

  .dd-equipment-cta {
    align-self: end;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* FEEDBACK SECTION */
  .dd-feedback-v9-5 { display: grid; grid-template-columns: 0.4fr 0.6fr; gap: 80px; align-items: flex-start; margin-top: 56px; }
  .dd-feedback-screenshot { position: relative; }
  .dd-blur-personal { filter: blur(6px); transition: filter 0.4s; }
  .dd-blur-personal:hover { filter: blur(0); }
  
  .dd-testi-v9-5 { display: flex; flex-direction: column; gap: 32px; }
  .dd-quote-card-v9-5 { background: #1A1C20; padding: 48px; border-left: 4px solid #00A3AD; position: relative; }
  .dd-quote-card-v9-5 p { font-size: 28px; font-weight: 800; font-style: italic; color: #FFF; margin: 0 0 20px 0; line-height: 1.2; }
  .dd-testi-label { display: block; font-size: 8px; font-weight: 700; letter-spacing: 2px; opacity: 0.4; text-transform: uppercase; }

  /* LIGHTBOX */
  .dd-lightbox { display: none; position: fixed; z-index: 9999; padding-top: 100px; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.9); cursor: pointer; }
  .dd-lightbox-content { margin: auto; display: block; width: 80%; max-width: 1000px; animation: zoom 0.3s; }
  @keyframes zoom { from {transform:scale(0)} to {transform:scale(1)} }

  /* MOBILE RESPONSIVE */
  @media (max-width: 1024px) {
    .dd-container { padding: 0 22px; }
    .dd-hero-v9-5 { height: auto; }
    .dd-hero-title { font-size: 42px; }
    .dd-hero-seo-line { font-size: 18px; }
    .dd-hero-project-card { position: static; width: 100%; margin-top: -1px; }
    .dd-timeline-grid, .dd-doc-grid, .dd-doc-grid-2, .dd-equipment-panel, .dd-feedback-v9-5 { grid-template-columns: 1fr; }
    .dd-timeline-step::after { display: none; }
    .dd-timeline-step { min-height: auto; }
    .dd-evidence-frame-v3 { height: 280px; }
    .dd-vertical-adjust { height: 360px !important; }
    .dd-equipment-specs { grid-template-columns: 1fr; }
  }
</style>

<div class="dd-case-v9-5">
  <!-- SECTION 01: HERO -->
  <header class="dd-hero-v9-5">
    <div class="dd-hero-bg">
      <img src="https://sc01.alicdn.com/kf/A1a405c3ce75b406db9ded79e5af0eef9H.jpg" alt="Uganda Customer with Dragon Diamond Team">
    </div>
    
    <div class="dd-hero-project-card">
      <div class="dd-pc-row"><span>INSTALLED MACHINE</span><strong>LZ-1390 CO2 LASER CUTTER</strong></div>
      <div class="dd-pc-row"><span>WORKING AREA</span><strong>1300 × 900 MM</strong></div>
      <div class="dd-pc-row"><span>LOCATION</span><strong>UGANDA</strong></div>
      <div class="dd-pc-row"><span>STATUS</span><strong class="status-running">PRODUCTION RUNNING</strong></div>
    </div>

    <div class="dd-hero-overlay">
      <div class="dd-container">
        <div class="dd-hero-text">
          <span class="dd-kicker">CASE STUDY: UGANDA</span>
          <h1 class="dd-hero-title">Production Intelligence Deployment</h1>
          <p class="dd-hero-seo-line">How a leading Uganda signage manufacturer optimized their high-volume fabrication with Dragon Diamond's LZ-1390 CO2 Laser technology and technical support.</p>
          <div class="dd-hero-cta">
            <a href="#consultation" class="dd-btn-primary">GET MACHINE RECOMMENDATION</a>
            <a href="#consultation" class="dd-btn-secondary">REQUEST A QUOTE</a>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- SECTION 02: DECISION TIMELINE -->
  <section class="dd-decision-timeline">
    <div class="dd-container">
      <span class="dd-kicker">01. DEPLOYMENT TIMELINE</span>
      <h2 class="dd-section-title">A Journey of Technical Trust</h2>
      <p class="dd-section-copy">From the initial factory audit to continuous repeat orders, this timeline documents the successful deployment of laser technology in Uganda.</p>
      
      <div class="dd-timeline-grid">
        <div class="dd-timeline-step">
          <div class="dd-step-num">STEP 01</div>
          <div class="dd-step-title">FACTORY VISIT</div>
          <p class="dd-step-copy">Customer representatives visited to audit manufacturing scale.</p>
        </div>
        <div class="dd-timeline-step">
          <div class="dd-step-num">STEP 02</div>
          <div class="dd-step-title">CONSULTATION</div>
          <p class="dd-step-copy">Technical discussion on LZ-1390 configuration for signage.</p>
        </div>
        <div class="dd-timeline-step">
          <div class="dd-step-num">STEP 03</div>
          <div class="dd-step-title">PREPARATION</div>
          <p class="dd-step-copy">Material testing and internal factory QC verification.</p>
        </div>
        <div class="dd-timeline-step">
          <div class="dd-step-num">STEP 04</div>
          <div class="dd-step-title">EXPORT</div>
          <p class="dd-step-copy">Reinforced crating for sea freight shipment to Uganda.</p>
        </div>
        <div class="dd-timeline-step">
          <div class="dd-step-num">STEP 05</div>
          <div class="dd-step-title">DELIVERY</div>
          <p class="dd-step-copy">Arrival and positioning in the customer's workshop.</p>
        </div>
        <div class="dd-timeline-step">
          <div class="dd-step-num">STEP 06</div>
          <div class="dd-step-title">INSTALLATION</div>
          <p class="dd-step-copy">System commissioning and initial software calibration.</p>
        </div>
        <div class="dd-timeline-step">
          <div class="dd-step-num">STEP 07</div>
          <div class="dd-step-title">RE-ORDER</div>
          <p class="dd-step-copy">Positive performance leading to future order discussions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 03: CONSULTATION & TESTING -->
  <section class="dd-doc-section dd-white">
    <div class="dd-container">
      <h2 class="dd-kicker">02. CUSTOMER VISIT & TECHNICAL CONSULTATION</h2>
      <div class="dd-section-title">In-Person Technical Verification</div>
      <div class="dd-doc-grid-2">
        <div class="dd-doc-card">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">FACTORY AUDIT</span>
            <img src="https://sc01.alicdn.com/kf/Acc6400f95ab44fbd8be24f0c0c8a7a44h.jpg" alt="Direct Factory Inspection" class="dd-evidence-img">
          </div>
          <p class="dd-card-caption">WORKFLOW DISCUSSION</p>
          <p class="dd-card-desc">Customer representatives verifying manufacturing scale and technical team capabilities.</p>
        </div>
        <div class="dd-doc-card">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">MATERIAL TEST</span>
            <img src="https://sc01.alicdn.com/kf/A83afc926872042919bcb522e4ea3183em.jpg" alt="Material Testing" class="dd-evidence-img">
          </div>
          <p class="dd-card-caption">ACCURACY FINALIZATION</p>
          <p class="dd-card-desc">Live testing on specific acrylic samples to confirm cutting edge quality.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 04: PRODUCTION RESULTS -->
  <section class="dd-doc-section dd-dark" id="results">
    <div class="dd-container">
      <h2 class="dd-kicker">03. PROJECTS PRODUCED AFTER INSTALLATION</h2>
      <div class="dd-section-title">High-Impact Commercial Signage</div>
      <p class="dd-section-copy">Commercial signage projects manufactured using the deployed LZ-1390 system in Uganda.</p>
      
      <div class="dd-doc-grid">
        <div class="dd-doc-card" onclick="openLightbox(0)">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">SUCCESS STORY</span>
            <img src="https://sc01.alicdn.com/kf/Ab0f5b58c766b4bb98f284664ac66c7eef.jpg" alt="Rise And Shine Monument" class="dd-evidence-img dd-vertical-adjust">
          </div>
          <p class="dd-card-caption">RISE AND SHINE HIGH SCHOOL</p>
          <p class="dd-card-desc">Custom acrylic monument sign produced with precision laser cutting.</p>
        </div>
        <div class="dd-doc-card" onclick="openLightbox(1)">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">PHARMACY</span>
            <img src="https://sc01.alicdn.com/kf/A6f78a48ea0b94f928b5b9aad833cd2a87.jpg" alt="Namirembe Pharmacy" class="dd-evidence-img">
          </div>
          <p class="dd-card-caption">NAMIREMBE PHARMACY</p>
          <p class="dd-card-desc">Commercial branding project featuring illuminated acrylic letters.</p>
        </div>
        <div class="dd-doc-card" onclick="openLightbox(2)">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">UNIVERSITY</span>
            <img src="https://sc01.alicdn.com/kf/Ade91ff174c604fabb5f3d543460bcf5f9.jpg" alt="Islamic University" class="dd-evidence-img">
          </div>
          <p class="dd-card-caption">ISLAMIC UNIVERSITY</p>
          <p class="dd-card-desc">Precision-cut signage for a major educational institution entrance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 05: FEATURED EQUIPMENT -->
  <section class="dd-featured-equipment">
    <div class="dd-container">
      <span class="dd-kicker">CORE TECHNOLOGY</span>
      <h2 class="dd-section-title">Featured Production System</h2>
      
      <div class="dd-equipment-panel">
        <div class="dd-equipment-info">
          <h3 class="dd-equipment-name">LZ-1390 CO2 Laser <br>Signage Edition</h3>
          <p class="dd-section-copy">The industry-standard for acrylic cutting and illuminated sign production, featuring high-speed Ruida control and reinforced frame.</p>
          
          <div class="dd-equipment-specs">
            <div class="dd-spec"><span>WORKING AREA</span><strong>1300 x 900 mm</strong></div>
            <div class="dd-spec"><span>LASER POWER</span><strong>100W / 130W / 150W</strong></div>
            <div class="dd-spec"><span>CONTROL SYSTEM</span><strong>Ruida RD-Works V8</strong></div>
            <div class="dd-spec"><span>APPLICATION</span><strong>Acrylic, MDF, Composite</strong></div>
          </div>
        </div>
        <div class="dd-equipment-cta">
          <a href="/products/lz-1390-co2-laser-cutter" class="dd-btn-primary">VIEW PRODUCT SPECS</a>
          <a href="#consultation" class="dd-btn-secondary">CUSTOMIZE MY SYSTEM</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 06: FEEDBACK & VERIFICATION -->
  <section class="dd-doc-section dd-dark">
    <div class="dd-container">
      <h2 class="dd-kicker">04. CUSTOMER VERIFIED FEEDBACK</h2>
      <div class="dd-section-title">Evidence of Long-Term Success</div>
      
      <div class="dd-feedback-v9-5">
        <div class="dd-feedback-screenshot">
          <img src="https://sc02.alicdn.com/kf/A5c5af97ff3e748328f1e61b56c6d3b69w.png" alt="WhatsApp Feedback" class="dd-blur-personal dd-vertical-adjust">
          <span class="dd-evidence-label">CHAT LOG</span>
        </div>
        <div class="dd-testi-v9-5">
          <div class="dd-quote-card-v9-5">
            <p>“The machine is good. Hope next year we place another order.”</p>
            <span class="dd-testi-label">PERFORMANCE VALIDATION</span>
          </div>
          <div class="dd-doc-desc">
            Several months after installation, the customer shared production videos and confirmed that the machine was performing well in daily sign manufacturing.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 07: PACKAGING -->
  <section class="dd-doc-section dd-white">
    <div class="dd-container">
      <h2 class="dd-kicker">05. INTERNATIONAL SHIPMENT PREPARATION</h2>
      <div class="dd-section-title">Zero-Damage Global Logistics</div>
      <div class="dd-doc-grid-2">
        <div class="dd-doc-card">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">PROTECTION</span>
            <img src="https://sc02.alicdn.com/kf/A50268399c77c4d5d86217f8b518afffcW.png" alt="Stretch Film Protection" class="dd-evidence-img">
          </div>
          <p class="dd-card-caption">MOISTURE BARRIER</p>
          <p class="dd-card-desc">Multi-layer stretch film protection to prevent corrosion during sea freight.</p>
        </div>
        <div class="dd-doc-card">
          <div class="dd-evidence-frame-v3">
            <span class="dd-evidence-label">CRATING</span>
            <img src="https://sc02.alicdn.com/kf/Ab9b44aee4cb8414f991cb6aa7989a600Q.png" alt="Plywood Export Crating" class="dd-evidence-img">
          </div>
          <p class="dd-card-caption">EXPORT PLYWOOD</p>
          <p class="dd-card-desc">Reinforced fumigation-free plywood crates for safe handling and stacking.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 08: FINAL CTA -->
  <section class="dd-doc-section dd-white" id="consultation">
    <div class="dd-container" style="text-align: center;">
      <h2 class="dd-section-title">Looking For A Similar Signage Setup?</h2>
      <p class="dd-section-copy" style="margin: 0 auto 48px;">Tell us your materials, production requirements and business goals. Our team will recommend a suitable laser system based on your application.</p>
      <div class="dd-hero-cta" style="justify-content: center;">
        <a href="#consultation" class="dd-btn-primary">GET MACHINE RECOMMENDATION</a>
        <a href="#consultation" class="dd-btn-secondary">REQUEST A QUOTE</a>
      </div>
      
      <div style="margin-top: 80px; border-top: 1px solid rgba(0,0,0,0.1); padding-top: 40px; text-align: left;">
        <a href="/pages/case-studies" style="font-size: 10px; font-weight: 700; letter-spacing: 2px; color: #000; opacity: 0.5; text-decoration: none;">← ALL CASE STUDIES</a>
      </div>
    </div>
  </section>

  <!-- LIGHTBOX CONTAINER -->
  <div id="dd-lightbox" class="dd-lightbox" onclick="closeLightbox()">
    <img class="dd-lightbox-content" id="dd-lightbox-img">
  </div>
</div>

<script>
  function openLightbox(idx) {
    const gallery = [
      'https://sc01.alicdn.com/kf/Ab0f5b58c766b4bb98f284664ac66c7eef.jpg',
      'https://sc01.alicdn.com/kf/A6f78a48ea0b94f928b5b9aad833cd2a87.jpg',
      'https://sc01.alicdn.com/kf/Ade91ff174c604fabb5f3d543460bcf5f9.jpg'
    ];
    document.getElementById('dd-lightbox').style.display = "block";
    document.getElementById('dd-lightbox-img').src = gallery[idx];
  }
  function closeLightbox() {
    document.getElementById('dd-lightbox').style.display = "none";
  }
</script>

{% schema %}
{
  "name": "DD Case Study 001 Uganda",
  "settings": [],
  "presets": [{"name": "DD Case Study 001 Uganda"}]
}
{% endschema %}
