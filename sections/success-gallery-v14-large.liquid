<section class="success-gallery-section v-english-v14-final" id="success-gallery-{{ section.id }}">
  <div class="container-v2">
    <div class="section-header-v2">
      <h2 class="section-title-v2">SUCCESS CASE GALLERY</h2>
      <p class="section-subtitle-v2">Explore how Dragon Diamond's Industrial 4.0 solutions empower global signage, textile, and furniture manufacturers.</p>
    </div>

    <div class="success-grid">
      <!-- Card 1 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H724740e42dd24a6f93f4c7d211467496j.png" alt="Signage Excellence (Africa)" loading="lazy">
          <span class="industry-tag">SIGNAGE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Signage Excellence (Africa)</h3>
          <p class="card-market">Market: Africa / Nigeria / Lagos</p>
          <p class="card-desc">High-precision acrylic cutting for 3D premium branding and display solutions.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/Hbb59fa86a8404b7f9ffa7a197985b759t.png" alt="Textile Precision (Uzbekistan)" loading="lazy">
          <span class="industry-tag">TEXTILE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Textile Precision (Uzbekistan)</h3>
          <p class="card-market">Market: Uzbekistan / Central Asia / Tashkent</p>
          <p class="card-desc">Automated laser tailoring for large-format textile processing and efficiency gains.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H5592889fd05a4926af9c895580fc0a58l.png" alt="Custom Furniture (Georgia)" loading="lazy">
          <span class="industry-tag">FURNITURE</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Custom Furniture (Georgia)</h3>
          <p class="card-market">Market: Georgia / Tbilisi (Mr. Gocha)</p>
          <p class="card-desc">ATC Auto-tool change CNC solution for high-end furniture customization.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="success-card">
        <div class="card-image-wrapper">
          <img src="https://sc01.alicdn.com/kf/H909e78c2eeb54708a31b02b6b4ca8e9aQ.png" alt="Acrylic Design (Italy)" loading="lazy">
          <span class="industry-tag">ACRYLIC</span>
        </div>
        <div class="card-info">
          <h3 class="card-title">Acrylic Design (Italy)</h3>
          <p class="card-market">Market: Italy / Venice / Industrial Design</p>
          <p class="card-desc">Equipped with 100W-200W dedicated UV system for complex high-speed acrylic cutting.</p>
          <a href="/pages/contact" class="card-link">VIEW SOLUTION &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* V14 Large Layout - 220px */
  .success-gallery-section.v-english-v14-final {
    background: #ffffff !important;
    padding: 100px 0 !important;
    font-family: 'Archivo Narrow', sans-serif !important;
    display: block !important;
    overflow-x: hidden !important;
  }
  .v-english-v14 .container-v2 {
    max-width: 1400px !important; /* Wider container for larger cards */
    margin: 0 auto !important;
    width: 95% !important;
  }
  .v-english-v14 .section-header-v2 {
    text-align: center !important;
    margin-bottom: 60px !important;
  }
  .v-english-v14 .section-title-v2 {
    font-size: 36px !important;
    font-weight: 800 !important;
    color: #1a1a1a !important;
    letter-spacing: 2px !important;
    text-transform: uppercase !important;
    margin: 0 0 15px 0 !important;
  }
  .v-english-v14 .section-subtitle-v2 {
    font-size: 16px !important;
    color: #888 !important;
    max-width: 800px !important;
    margin: 0 auto !important;
  }
  .v-english-v14 .success-grid {
    display: flex !important;
    flex-wrap: wrap !important;
    justify-content: center !important;
    gap: 30px !important;
    width: 100% !important;
  }
  .v-english-v14 .success-card {
    background: #ffffff !important;
    border: 1px solid #f0f0f0 !important;
    padding: 30px !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    text-align: center !important;
    transition: all 0.3s ease !important;
    width: calc(25% - 23px) !important;
    min-width: 300px !important;
    box-sizing: border-box !important;
    box-shadow: 0 4px 15px rgba(0,0,0,0.02) !important;
  }
  .v-english-v14 .success-card:hover {
    transform: translateY(-5px) !important;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05) !important;
    border-color: #006841 !important;
  }
  .v-english-v14 .card-image-wrapper {
    position: relative !important;
    width: 220px !important; /* Upped to 220px */
    height: 220px !important; /* Upped to 220px */
    margin-bottom: 25px !important;
    border-radius: 12px !important;
    overflow: hidden !important;
    border: 1px solid #f0f0f0 !important;
  }
  .v-english-v14 .card-image-wrapper img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
  .v-english-v14 .industry-tag {
    position: absolute !important;
    top: 10px !important;
    left: 10px !important;
    background: #006841 !important;
    color: #ffffff !important;
    font-size: 10px !important;
    font-weight: 700 !important;
    padding: 5px 12px !important;
    border-radius: 4px !important;
    text-transform: uppercase !important;
    z-index: 10 !important;
  }
  .v-english-v14 .card-title {
    font-size: 18px !important;
    font-weight: 700 !important;
    color: #1a1a1a !important;
    margin: 0 0 12px 0 !important;
    min-height: 48px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    line-height: 1.2 !important;
  }
  .v-english-v14 .card-market {
    font-size: 12px !important;
    color: #006841 !important;
    font-weight: 700 !important;
    margin-bottom: 12px !important;
    text-transform: uppercase !important;
  }
  .v-english-v14 .card-desc {
    font-size: 14px !important;
    line-height: 1.6 !important;
    color: #666 !important;
    margin-bottom: 25px !important;
    min-height: 68px !important;
  }
  .v-english-v14 .card-link {
    font-size: 12px !important;
    font-weight: 700 !important;
    color: #006841 !important;
    text-decoration: none !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
    border-bottom: 2px solid transparent !important;
    transition: all 0.2s ease !important;
  }
  .v-english-v14 .card-link:hover {
    border-bottom-color: #006841 !important;
  }

  @media (max-width: 1300px) {
    .v-english-v14 .success-card { width: calc(50% - 15px) !important; }
  }
  @media (max-width: 700px) {
    .v-english-v14 .success-card { width: 100% !important; }
    .v-english-v14 .card-image-wrapper { width: 100% !important; height: auto !important; aspect-ratio: 1/1 !important; }
  }
</style>

