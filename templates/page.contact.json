            "alignment": "center",
            "max_width": "normal"
          }
        },
        "content": {
          "type": "text",
          "name": "t:names.content",
          "settings": {
            "text": "<p>Need a customized laser solution or a bulk order quote? Our expert engineers are ready to assist you. Fill out the form below or contact us directly.</p>",
            "type_preset": "rte",
            "alignment": "center",
            "max_width": "narrow"
          }
        }
      },
      "block_order": [
        "title",
        "content"
      ]
    },
    "form": {
      "type": "section",
