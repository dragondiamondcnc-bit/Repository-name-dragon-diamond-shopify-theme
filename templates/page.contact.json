      "settings": {
        "section_width": "page-width",
        "content_direction": "row",
        "vertical_on_mobile": true,
        "horizontal_alignment": "space-between",
        "vertical_alignment": "flex-start",
        "gap": 64,
        "padding-block-start": 48,
        "padding-block-end": 84,
        "color_scheme": "scheme-1"
      },
      "blocks": {
        "contact_info": {
          "type": "text",
          "name": "Contact Details",
          "settings": {
            "text": "<h3>Direct Contact</h3><p><strong>Email:</strong> gzddlaser@gmail.com<br><strong>WhatsApp/WeChat:</strong> +86 139 2215 5005<br><strong>Address:</strong> Guangzhou Dragon Diamond Technology Co., Ltd., China</p><h3>Business Hours</h3><p>Monday - Friday: 9:00 AM - 6:00 PM (GMT+8)<br>24/7 Inquiry Response via Email/WhatsApp</p>",
